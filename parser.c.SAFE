static int is_struct_assign_node(Node *node);
static Node *parse_return_struct_assign_member_expr(void);
static Node *parse_struct_assign_member_sum(Node **setup_out);
static Node *parse_struct_assign_member_expr_core(Node **setup_out);
static Node *parse_call_statement_with_struct_assign_member_arg(void);
static Node *parse_if_with_struct_assign_member_condition(void);
static Node *parse_struct_return_assignment_statement(void);
static Node *parse_struct_return_discard_statement(void);
static Node *parse_statement(void);
static Node *parse_function_pointer_declaration_statement(void);
static Node *parse_switch_statement(void);
static Node *parse_expr(void);
static Node *parse_assignment(void);
static Node *parse_unary(void);
static Node *append_stmt(Node **cur, Node *stmt);
static Node *parse_arg_list(void);
static Node *make_scalar_var_node(const char *name);
static Node *build_local_zero_fill_block(const char *name, int offset, int bytes, Node *decl);
static Node *make_incdec(Node *node, TokenKind op, int is_postfix);
static Type *parse_type_name(void);
static Type *parse_enum_specifier(void);
static void parse_union_definition(void);
static int is_type_start_token(TokenKind kind, const char *text);

static StructDef *find_struct(const char *name);
static Type *type_for_size(int size);
static Type *type_local(const char *name);
static Type *type_for_size_unsigned(int size, int is_unsigned);
static Field *find_field(const char *struct_name, const char *field_name);

/* v174_parse_post_pointer_qualifiers */
static void 
skip_pointer_qualifiers(void)
{
	while (lexer_peek()->kind == TOK_CONST)
		lexer_next();
}

static Node *
append_node(Node *head, Node *node)
{
	if (!head)
		return node;

	Node *tail = head;
	while (tail->next)
		tail = tail->next;
	tail->next = node;
	return head;
}

static int 
align_to(int value, int align)
{
	if (align <= 1)
		return value;
	return (value + align - 1) & ~(align - 1);
}

static int 
aggregate_align(StructDef *def)
{
	return def && def->align > 0 ? def->align : 4;
}

static ExprValue 
expr_value_none(void)
{
	ExprValue result;
	result.setup = NULL;
	result.value = NULL;
	return result;
}

static ExprValue 
expr_value_make(Node *setup, Node *value)
{
	ExprValue result;
	result.setup = setup;
	result.value = value;
	return result;
}

static Node *
expr_value_statement(Node *setup, Node *stmt)
{
	if (!setup)
		return stmt;

	return new_block(append_node(setup, stmt));
}

static int 
field_index_by_name_offset(StructDef *def, Field *field)
{
	if (!def || !field)
		return -1;

	for (int i = 0; i < def->field_count && i < MAX_STRUCT_FIELDS; i++) {
		if (STRCMP(def->fields[i].name, field->name) == 0 &&
		        def->fields[i].offset == field->offset)
			return i;
	}

	return -1;
}

static Node *append_struct_zero_fill(Node *head, StructDef *def, const char *struct_name, int base_offset, int seen[MAX_STRUCT_FIELDS]);

static Node *
parse_struct_initializer_values(StructDef *def, const char *struct_name, int base_offset, Node *head)
{
	int field_index = 0;
	int seen[MAX_STRUCT_FIELDS] = {0};

	while (lexer_peek()->kind != TOK_RBRACE) {
		Field *field = NULL;

		if (lexer_peek()->kind == TOK_DOT) {
			lexer_next();

			const Token *field_name = lexer_peek();
			if (field_name->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '.' in struct initializer\n");
				exit(1);
			}

			lexer_next();
			expect(TOK_ASSIGN);

			field = find_field(struct_name, field_name->text);
			{
				int di = field_index_by_name_offset(def, field);
				if (di >= 0 && field_index <= di) {
					field_index = di + 1;
					while (field_index < def->field_count &&
					       field->size > 0 &&
					       def->fields[field_index].size > 0 &&
					       def->fields[field_index].offset == field->offset)
						field_index++;
				}
			}
		} else {
			if (field_index >= def->field_count) {
				/* All fields consumed — stop; remaining values belong to outer initializer. */
				break;
			}

			field = &def->fields[field_index++];

			/*
			 * Anonymous unions are represented by promoted fields with the
			 * same offset. Positional initialization gets one slot for the
			 * anonymous union, not one slot per promoted member.
			 */
			while (field_index < def->field_count &&
			       field->size > 0 &&
			       def->fields[field_index].size > 0 &&
			       def->fields[field_index].offset == field->offset)
				field_index++;
		}

		{
			int idx = field_index_by_name_offset(def, field);
			if (idx >= 0) {
				seen[idx] = 1;

				/*
				 * Mark all aliases at this offset as seen so zero-fill does
				 * not wipe a value initialized through another union member.
				 */
				if (field->size > 0) {
					for (int si = 0; si < def->field_count && si < MAX_STRUCT_FIELDS; si++)
						if (def->fields[si].size > 0 &&
						    def->fields[si].offset == field->offset)
							seen[si] = 1;
				}
			}
		}

		if (field->is_struct) {
			if (lexer_peek()->kind == TOK_LBRACE) {
				/* Braced sub-struct: "{val, val, ...}" */
				lexer_next();
				StructDef *nested = find_struct(field->struct_name);
				head = parse_struct_initializer_values(nested, field->struct_name, base_offset + field->offset, head);
				expect(TOK_RBRACE);
			} else if (lexer_peek()->kind != TOK_IDENT &&
			           lexer_peek()->kind != TOK_LPAREN &&
			           lexer_peek()->kind != TOK_STAR) {
				/*
				 * Brace elision for local nested struct fields.
				 *
				 *   struct S { u8 a,b; u8 c[2]; };
				 *   struct U { u8 a; struct S s; u8 b; struct T t; };
				 *   struct U u = {3, 5,6,7,8, 4, "txt", 9};
				 *
				 * The scalar/string sequence initializes the nested object; do
				 * not treat only the first scalar as a struct copy expression.
				 * Keep identifiers, parenthesized expressions/compound literals,
				 * and *ptr in the expression-copy path below so cases such as
				 * {3, ls, 4, ...}, {3, (ls), 4, ...}, and {3, *pls, 4, ...}
				 * continue to copy a complete struct value.
				 */
				StructDef *nested = find_struct(field->struct_name);
				head = parse_struct_initializer_values(nested, field->struct_name, base_offset + field->offset, head);
				/* The recursive brace-elided parse consumes the separator before
				 * the next parent field; continue rather than stopping the parent. */
				continue;
			} else {
				/* Flat init: struct field given as a single expression (e.g. struct var copy).
				 * "struct U lu1 = {3, ls, 4}" -> s = ls (copy). */
				Node *member = new_member(field->name, base_offset + field->offset);
				member->elem_size = field->size;
				member->type = type_for_size(field->size);
				STRNCPY(member->struct_name, struct_name, sizeof(member->struct_name) - 1);
				head = append_node(head, new_assign(member, parse_expr()));
			}
		} else if (field->is_array) {
			/* Array field: can be braced "{v0, v1}" or flat "v0, v1, ..." */
			int arr_max = (field->elem_size > 0) ? field->size / field->elem_size : 1;
			int arr_offset = base_offset + field->offset;
			int ae = 0;
			if (lexer_peek()->kind == TOK_LBRACE) {
				/* Braced array initializer: { v0, v1, ... } */
				lexer_next();
				while (lexer_peek()->kind != TOK_RBRACE && ae < arr_max) {
					/* strip optional braces around element */
					int brace = (lexer_peek()->kind == TOK_LBRACE);
					if (brace) lexer_next();
					Node *elem = new_member(field->name, arr_offset + ae * field->elem_size);
					elem->elem_size = field->elem_size;
					elem->type = type_for_size(field->elem_size);
					head = append_node(head, new_assign(elem, parse_expr()));
					if (brace) expect(TOK_RBRACE);
					ae++;
					if (lexer_peek()->kind == TOK_COMMA) lexer_next();
				}
				expect(TOK_RBRACE);
			} else if (field->elem_size == 1 && lexer_peek()->kind == TOK_STRING) {
				/* String literal initializes char array */
				const Token *str = lexer_peek();
				lexer_next();
				const char *s = str->text ? str->text : "";
				for (int ci = 0; ci < arr_max && s[ci]; ci++) {
					Node *elem = new_member(field->name, arr_offset + ci);
					elem->elem_size = 1;
					elem->type = type_char();
					head = append_node(head, new_assign(elem, new_num(s[ci])));
				}
			} else {
				/* Flat: consume up to arr_max values from the outer initializer list */
				while (ae < arr_max && lexer_peek()->kind != TOK_RBRACE) {
					int brace = (lexer_peek()->kind == TOK_LBRACE);
					if (brace) lexer_next();
					Node *elem = new_member(field->name, arr_offset + ae * field->elem_size);
					elem->elem_size = field->elem_size;
					elem->type = type_for_size(field->elem_size);
					head = append_node(head, new_assign(elem, parse_expr()));
					if (brace) expect(TOK_RBRACE);
					ae++;
					if (ae < arr_max && lexer_peek()->kind == TOK_COMMA) {
						/* peek: if next value would start a new top-level field, stop */
						/* (we always consume the comma and let the outer loop re-check) */
						/* For flat arrays, keep consuming */
						const Token *nxt = lexer_peek_next();
						if (nxt->kind == TOK_RBRACE) break;
						lexer_next(); /* consume comma */
					}
				}
			}
		} else {
			Node *member = new_member(field->name, base_offset + field->offset);
			member->elem_size = field->size;
			member->type = type_for_size(field->size);
			STRNCPY(member->struct_name, struct_name, sizeof(member->struct_name) - 1);

			/* Strip optional parentheses around scalar: { (1) } */
			head = append_node(head, new_assign(member, parse_expr()));
		}

		/*
		 * Consume commas between initializer clauses.  A designated
		 * initializer may name an earlier field even after field_index has
		 * advanced to the end, e.g. { .y = 41, .x = 1 }.  Do not treat
		 * field_index >= field_count as meaning the local initializer is
		 * complete when the next clause is another designator.
		 */
		if (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
			if (field_index >= def->field_count &&
			    lexer_peek()->kind != TOK_DOT &&
			    lexer_peek()->kind != TOK_LBRACKET) {
				/* All positional fields consumed; leave any outer value alone. */
				break;
			}
			continue;
		}

		if (field_index >= def->field_count)
			break;

		break;
	}

	head = append_struct_zero_fill(head, def, struct_name, base_offset, seen);
	return head;
}

static Node *
append_struct_zero_fill(Node *head, StructDef *def, const char *struct_name, int base_offset, int seen[MAX_STRUCT_FIELDS])
{
	for (int i = 0; i < def->field_count && i < MAX_STRUCT_FIELDS; i++) {
		if (seen[i])
			continue;

		Field *field = &def->fields[i];

		if (field->is_struct) {
			StructDef *nested = find_struct(field->struct_name);
			int nested_seen[MAX_STRUCT_FIELDS] = {0};
			head = append_struct_zero_fill(head, nested, field->struct_name, base_offset + field->offset, nested_seen);
			continue;
		}

		Node *member = new_member(field->name, base_offset + field->offset);
		member->elem_size = field->size;
		member->type = type_for_size(field->size);
		STRNCPY(member->struct_name, struct_name, sizeof(member->struct_name) - 1);

		head = append_node(head, new_assign(member, new_num(0)));
	}

	return head;
}

static Node *
parse_struct_array_initializer_block(const char *var_name, const char *struct_name, int base_offset,
        int array_len,
        Node *decl_node)
{
	expect(TOK_ASSIGN);
	expect(TOK_LBRACE);

	StructDef *def = find_struct(struct_name);
	Node *head = decl_node;
	int index = 0;

	while (lexer_peek()->kind != TOK_RBRACE) {
		if (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();

			const Token *idx_tok = lexer_peek();
			if (idx_tok->kind != TOK_NUM) {
				fatal_cur("Expected numeric designated struct array index\n");
				exit(1);
			}

			index = idx_tok->value;
			lexer_next();
			expect(TOK_RBRACKET);
			expect(TOK_ASSIGN);
		}

		if (index >= array_len) {
			fatal_cur("Struct array initializer index out of range\n");
			exit(1);
		}

		if (lexer_peek()->kind != TOK_LBRACE) {
			fatal_cur("Struct array initializer element must use { ... }\n");
			exit(1);
		}

		lexer_next();
		head = parse_struct_initializer_values(def, struct_name,
		                                       base_offset + index * def->size,
		                                       head);
		expect(TOK_RBRACE);

		index++;

		if (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
		} else {
			break;
		}
	}

	expect(TOK_RBRACE);
	expect(TOK_SEMI);

	(void)var_name;
	return new_block(head);
}

static Node *
parse_struct_initializer_block(const char *var_name, const char *struct_name, int base_offset, Node *decl_node)
{
	if (lexer_peek()->kind != TOK_ASSIGN) {
		expect(TOK_SEMI);
		return decl_node;
	}

	lexer_next();

	if (lexer_peek()->kind == TOK_IDENT &&
	        lexer_peek_next()->kind == TOK_LPAREN) {
		const Token *func = lexer_peek();
		FuncInfo *fi = find_func(func->text);

		lexer_next(); /* consume func name */
		expect(TOK_LPAREN);
		Node *args = parse_arg_list();
		expect(TOK_RPAREN);
		expect(TOK_SEMI);

		StructDef *struct_def = find_struct(struct_name);

		Node *lhs = new_var(var_name, base_offset);
		lhs->type = type_struct(struct_name, struct_def->size);
		lhs->elem_size = struct_def->size;
		STRNCPY(lhs->struct_name, struct_name, sizeof(lhs->struct_name) - 1);

		Node *call = new_call(func->text, args);
		call->returns_struct = 1;

		if (fi && fi->returns_struct) {
			call->struct_return_size = fi->struct_size;
			call->type = type_struct(fi->struct_name, fi->struct_size);
			STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);
		} else {
			/*
			 * Bootstrap fallback: when the destination type is a known struct,
			 * allow "StructType local = helper(...)" even if helper's
			 * prototype/definition has not been recorded yet.  Treat the call
			 * as returning the destination struct type.
			 */
			call->struct_return_size = struct_def->size;
			call->type = type_struct(struct_name, struct_def->size);
			STRNCPY(call->return_struct_name, struct_name, sizeof(call->return_struct_name) - 1);
		}

		Node *assign = new_assign(lhs, call);
		return new_block(append_node(decl_node, assign));
	}

	if (lexer_peek()->kind != TOK_LBRACE) {
		/* Try: struct Foo dst = src_var  (struct copy from variable) */
		if (lexer_peek()->kind == TOK_IDENT) {
			const Token *src = lexer_peek();
			/* check it's a local or global struct variable, not a function call */
			if (lexer_peek_next()->kind == TOK_SEMI || lexer_peek_next()->kind == TOK_COMMA) {
				lexer_next(); /* consume src name */
				expect(TOK_SEMI);

				StructDef *struct_def = find_struct(struct_name);
				Node *lhs = new_var(var_name, base_offset);
				lhs->type = type_struct(struct_name, struct_def->size);
				lhs->elem_size = struct_def->size;
				STRNCPY(lhs->struct_name, struct_name, sizeof(lhs->struct_name) - 1);

				Node *rhs = make_scalar_var_node(src->text);
				if (!rhs->type || rhs->type->kind != TY_STRUCT) {
					rhs->type = type_struct(struct_name, struct_def->size);
					rhs->elem_size = struct_def->size;
					STRNCPY(rhs->struct_name, struct_name, sizeof(rhs->struct_name) - 1);
				}

				Node *assign = new_struct_assign(lhs, rhs, struct_def->size);
				return new_block(append_node(decl_node, assign));
			}
		}

		/* Try: struct Foo dst = *ptr;  (copy from pointed-to struct object) */
		if (lexer_peek()->kind == TOK_STAR && lexer_peek_next()->kind == TOK_IDENT) {
			lexer_next(); /* * */
			const Token *src = lexer_peek();
			lexer_next();
			expect(TOK_SEMI);

			Node *src_base = make_scalar_var_node(src->text);
			if (!src_base->type || src_base->type->kind != TY_PTR ||
			    !src_base->type->base || src_base->type->base->kind != TY_STRUCT) {
				fatal_cur("Struct initializer dereference must use pointer-to-struct source");
				exit(1);
			}
			if (STRCMP(src_base->type->base->struct_name, struct_name) != 0) {
				fatal_cur("Struct initializer type mismatch");
				exit(1);
			}

			src_base->is_pointer = 1;
			src_base->elem_size = 8;
			STRNCPY(src_base->struct_name, struct_name, sizeof(src_base->struct_name) - 1);

			return new_block(append_struct_copy_from_ptr_fields(decl_node, var_name, base_offset,
			                 src_base, struct_name, 0));
		}

		/*
		 * General struct-valued initializer expression.  This is needed for
		 * stdarg.h's va_arg macro when TYPE is a struct: after preprocessing it
		 * typically has the shape
		 *
		 *     struct S x = *(struct S *)((ap) += 8, (ap) - 8);
		 *
		 * The earlier special cases handle simple identifiers, calls, and
		 * plain *ptr.  Let the normal expression parser handle casts, comma
		 * expressions, and pointer arithmetic, then copy the resulting struct
		 * value into the newly declared object.
		 */
		{
			StructDef *struct_def = find_struct(struct_name);
			Node *lhs = new_var(var_name, base_offset);
			lhs->type = type_struct(struct_name, struct_def->size);
			lhs->elem_size = struct_def->size;
			STRNCPY(lhs->struct_name, struct_name, sizeof(lhs->struct_name) - 1);

			Node *rhs = parse_expr();
			expect(TOK_SEMI);

			if (!rhs->type || rhs->type->kind != TY_STRUCT ||
			    STRCMP(rhs->type->struct_name, struct_name) != 0) {
				fatal_cur("Struct initializer expression type mismatch");
				exit(1);
			}

			Node *assign = new_struct_assign(lhs, rhs, struct_def->size);
			return new_block(append_node(decl_node, assign));
		}

	}

	lexer_next();

	if (consume_all_zero_initializer()) {
		StructDef *struct_def = find_struct(struct_name);
		expect(TOK_SEMI);
		return build_local_zero_fill_block(var_name, base_offset, struct_def->size, decl_node);
	}

	StructDef *def = find_struct(struct_name);
	Node *head = parse_struct_initializer_values(def, struct_name, base_offset, decl_node);

	expect(TOK_RBRACE);
	expect(TOK_SEMI);

	return new_block(head);
}

static Node *
parse_struct_compound_assignment_statement(void)
{
	const Token *var = lexer_peek();

	if (var->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_ASSIGN ||
	        lexer_peek_after_next()->kind != TOK_LPAREN ||
	        lexer_peek_third()->kind != TOK_STRUCT)
		return NULL;

	if (!is_struct_local(var->text))
		return NULL;

	lexer_next(); /* var */
	lexer_next(); /* = */
	lexer_next(); /* ( */
	lexer_next(); /* struct */

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in compound literal\n");
		exit(1);
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_LBRACE) {
		fatal_cur("Expected initializer list in compound literal\n");
		exit(1);
	}
	lexer_next();

	const char *lhs_struct = struct_name_local(var->text);
	if (STRCMP(lhs_struct, struct_name->text) != 0) {
		fatal_cur("Compound literal assignment type mismatch\n");
		exit(1);
	}

	StructDef *def = find_struct(struct_name->text);
	Node *head = parse_struct_initializer_values(def, struct_name->text, find_local(var->text), NULL);

	expect(TOK_RBRACE);
	expect(TOK_SEMI);

	return new_block(head);
}

static Type *
type_for_size(int size)
{
	if (size == 1)
		return type_char();
	if (size == 2)
		return type_short();
	return type_int();
}

static Type *
type_for_size_unsigned(int size, int is_unsigned)
{
	if (size == 1)
		return is_unsigned ? type_uchar() : type_char();
	if (size == 2)
		return is_unsigned ? type_ushort() : type_short();
	return is_unsigned ? type_uint() : type_int();
}

static void 
expect(TokenKind kind)
{
	const Token *token = lexer_peek();

	if (token->kind != kind)
		fatal_token(token, "Unexpected token while parsing: expected=%s actual=%s",
		            token_debug_name(kind), token_debug_name(token->kind));

	lexer_next();
}

static Global *
find_global(const char *name)
{
	for (int i = 0; i < global_count; i++) {
		if (STRCMP(globals[i].name, name) == 0)
			return &globals[i];
	}

	return NULL;
}

static int 
is_global(const char *name)
{
	return find_global(name) != NULL;
}

static void 
commit_global_definition(Global *g)
{
	g->is_static = current_file_static;

	Global *existing = find_global(g->name);

	if (existing && existing != g) {
		if (existing->is_extern) {
			memcpy(existing, g, sizeof(*existing));
			existing->is_extern = 0;
			existing->is_static = g->is_static;
			memset(g, 0, sizeof(*g));
			return;
		}

		/* Tentative definition: "int x;" with no initializer may repeat.
		 * If new entry has an initializer and existing doesn't, update existing. */
		int new_has_init = (g->init_count > 0 || g->init_value != 0 ||
		                    g->is_string || g->is_addr || g->is_string_array);
		int old_has_init = (existing->init_count > 0 || existing->init_value != 0 ||
		                    existing->is_string || existing->is_addr || existing->is_string_array);
		if (!new_has_init) {
			/* Tentative redeclaration: discard new, keep existing */
			memset(g, 0, sizeof(*g));
			return;
		}
		if (new_has_init && !old_has_init) {
			/* Definition after tentative: update existing with initializer */
			char saved_name[64];
			STRNCPY(saved_name, existing->name, sizeof(saved_name) - 1);
			memcpy(existing, g, sizeof(*existing));
			STRNCPY(existing->name, saved_name, sizeof(existing->name) - 1);
			memset(g, 0, sizeof(*g));
			return;
		}

		fatal_cur("Global already defined: %s\n", g->name);
		exit(1);
	}

	global_count++;
}

static int 
is_global_array(const char *name)
{
	Global *g = find_global(name);
	return g && g->is_array;
}

static int 
is_global_struct(const char *name)
{
	Global *g = find_global(name);
	return g && g->is_struct;
}

static const char *
global_struct_name(const char *name)
{
	Global *g = find_global(name);
	if (!g)
		return "";
	if (g->struct_name[0])
		return g->struct_name;
	if (!g->is_struct)
		return "";
	return g->struct_name;
}

static int 
global_elem_size(const char *name)
{
	Global *g = find_global(name);
	if (!g) {
		fatal_cur("Undefined global: %s\n", name);
		exit(1);
	}

	return g->elem_size;
}

static Type *
global_array_decay_type(const char *name, int *out_elem_size)
{
	Global *g = find_global(name);
	if (!g || !g->is_array) {
		if (out_elem_size)
			*out_elem_size = global_elem_size(name);
		return type_ptr(type_for_size(global_elem_size(name)));
	}

	Type *elem = type_for_size(g->elem_size ? g->elem_size : 4);
	if (g->array_dim_count > 1)
		elem = build_array_type_from_dims(elem, g->array_dims + 1, g->array_dim_count - 1);

	if (out_elem_size)
		*out_elem_size = elem->size;
	return type_ptr(elem);
}

static int 
is_global_unsigned(const char *name)
{
	Global *g = find_global(name);
	return g ? g->is_unsigned : 0;
}

static int 
expr_is_unsigned_for_compare(Node *node)
{
	if (!node)
		return 0;

	if (node->is_unsigned)
		return 1;

	if (node->type && node->type->is_unsigned)
		return 1;

	if ((node->kind == ND_VAR || node->kind == ND_GLOBAL || node->kind == ND_GLOBAL_INDEX) && node->name[0]) {
		if (is_global(node->name))
			return is_global_unsigned(node->name);

		Type *t = type_local(node->name);
		return t && t->is_unsigned;
	}

	return 0;
}

static int 
is_global_pointer(const char *name)
{
	Global *g = find_global(name);
	return g && !g->is_array && !g->is_struct && g->elem_size == 8;
}

static int 
global_pointer_elem_size(const char *name)
{
	Global *g = find_global(name);
	if (!g || !g->ptr_elem_size)
		return 1;
	return g->ptr_elem_size;
}

static void 
store_global_init_int(Global *g, int offset, int size, int value)
{
	if (offset < 0 || offset + size > 1024) {
		fatal_cur("Global struct initializer too large\n");
		exit(1);
	}

	if (size == 1) {
		g->init_values[offset] = value & 255;
			return;
	}

	for (int i = 0; i < size; i++)
		g->init_values[offset + i] = (value >> (i * 8)) & 255;
}

static void 
store_global_init_string(Global *g, int offset, int size, const char *value)
{
	if (offset < 0 || offset + size > 1024) {
		fatal_cur("Global struct initializer too large\n");
		exit(1);
	}

	int i = 0;
	for (; i < size && value[i]; i++)
		g->init_values[offset + i] = (unsigned char)value[i];
	if (i < size)
		g->init_values[offset + i++] = 0;
	for (; i < size; i++)
		g->init_values[offset + i] = 0;
}


static int try_parse_global_scalar_initializer_value(int *out);

static int
try_parse_global_scalar_primary(int *out)
{
	if (lexer_peek()->kind == TOK_LPAREN) {
		/* Cast around a constant, e.g. (u8)45 or (unsigned char)45. */
		if (is_type_start_token(lexer_peek_next()->kind, lexer_peek_next()->text)) {
			lexer_next(); /* ( */
			while (lexer_peek()->kind != TOK_RPAREN) {
				if (lexer_peek()->kind == TOK_EOF) {
					fatal_cur("Unterminated cast in global initializer\n");
					exit(1);
				}
				lexer_next();
			}
			expect(TOK_RPAREN);
			return try_parse_global_scalar_initializer_value(out);
		}

		/* Parenthesized constant, including nested forms like (((3))). */
		lexer_next();
		if (!try_parse_global_scalar_initializer_value(out))
			return 0;
		expect(TOK_RPAREN);
		return 1;
	}

	if (lexer_peek()->kind == TOK_MINUS) {
		lexer_next();
		if (!try_parse_global_scalar_primary(out))
			return 0;
		*out = -*out;
		return 1;
	}

	if (lexer_peek()->kind == TOK_PLUS) {
		lexer_next();
		return try_parse_global_scalar_primary(out);
	}

	if (lexer_peek()->kind == TOK_NUM) {
		*out = lexer_peek()->value;
		lexer_next();
		return 1;
	}

	if (lexer_peek()->kind == TOK_IDENT) {
		int enum_value = 0;
		if (find_enum_const(lexer_peek()->text, &enum_value)) {
			*out = enum_value;
			lexer_next();
			return 1;
		}
	}

	return 0;
}

static int
try_parse_global_scalar_initializer_value(int *out)
{
	int val = 0;

	if (!try_parse_global_scalar_primary(&val))
		return 0;

	/*
	 * File-scope aggregate initializers need integer constant expressions, not
	 * just bare numeric tokens.  This deliberately handles the small constant
	 * expression subset already accepted elsewhere by this compiler: arithmetic,
	 * shifts, bitwise and logical operators.  It stops before aggregate
	 * delimiters such as ',', '}', and ']'.
	 */
	while (lexer_peek()->kind == TOK_STAR || lexer_peek()->kind == TOK_PLUS ||
	       lexer_peek()->kind == TOK_MINUS || lexer_peek()->kind == TOK_SLASH ||
	       lexer_peek()->kind == TOK_PERCENT || lexer_peek()->kind == TOK_AND ||
	       lexer_peek()->kind == TOK_OR || lexer_peek()->kind == TOK_AMP ||
	       lexer_peek()->kind == TOK_PIPE || lexer_peek()->kind == TOK_CARET ||
	       lexer_peek()->kind == TOK_SHL || lexer_peek()->kind == TOK_SHR) {
		TokenKind op = lexer_peek()->kind;
		int rhs = 0;
		lexer_next();
		if (!try_parse_global_scalar_primary(&rhs))
			return 0;

		if (op == TOK_STAR) val *= rhs;
		else if (op == TOK_PLUS) val += rhs;
		else if (op == TOK_MINUS) val -= rhs;
		else if (op == TOK_SLASH) { if (rhs) val /= rhs; }
		else if (op == TOK_PERCENT) { if (rhs) val %= rhs; }
		else if (op == TOK_AND) val = val && rhs;
		else if (op == TOK_OR) val = val || rhs;
		else if (op == TOK_AMP) val &= rhs;
		else if (op == TOK_PIPE) val |= rhs;
		else if (op == TOK_CARET) val ^= rhs;
		else if (op == TOK_SHL) val <<= rhs;
		else if (op == TOK_SHR) val >>= rhs;
	}

	*out = val;
	return 1;
}



static int
array_dim_product(const int dims[MAX_ARRAY_DIMS], int start, int dim_count)
{
	int n = 1;
	for (int i = start; i < dim_count; i++) {
		if (dims[i] > 0)
			n *= dims[i];
	}
	return n;
}

static void
parse_global_int_array_initializer_level(Global *g, int dims[MAX_ARRAY_DIMS], int dim_count,
                                        int level, int base_index, int *max_used_index)
{
	if (lexer_peek()->kind != TOK_LBRACE) {
		int value = 0;
		if (!try_parse_global_scalar_initializer_value(&value)) {
			fatal_cur("Global array initializer must contain constant integers\n");
			exit(1);
		}
		if (base_index < 0 || base_index >= 1024) {
			fatal_cur("Too many global array initializers\n");
			exit(1);
		}
		g->init_values[base_index] = value;
		if (base_index + 1 > *max_used_index)
			*max_used_index = base_index + 1;
		return;
	}

	expect(TOK_LBRACE);
	int cur_idx = 0;
	int span = (level + 1 < dim_count) ? array_dim_product(dims, level + 1, dim_count) : 1;

	while (lexer_peek()->kind != TOK_RBRACE) {
		if (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next(); /* [ */
			int idx = 0;
			if (!try_parse_global_scalar_initializer_value(&idx)) {
				fatal_cur("Expected constant index in designated initializer\n");
				exit(1);
			}
			expect(TOK_RBRACKET);
			expect(TOK_ASSIGN);
			cur_idx = idx;
		}

		if (cur_idx < 0) {
			fatal_cur("Negative array designator index\n");
			exit(1);
		}

		if (dims[level] > 0 && cur_idx >= dims[level]) {
			fatal_cur("Too many initializers for global array\n");
			exit(1);
		}

		int elem_base = base_index + cur_idx * span;
		if (level + 1 < dim_count) {
			if (lexer_peek()->kind == TOK_LBRACE) {
				parse_global_int_array_initializer_level(g, dims, dim_count, level + 1, elem_base, max_used_index);
			} else {
				/* Allow partially-braced multidimensional initializers by filling
				 * consecutive scalar slots within this subobject. */
				parse_global_int_array_initializer_level(g, dims, dim_count, dim_count - 1, elem_base, max_used_index);
			}
		} else {
			parse_global_int_array_initializer_level(g, dims, dim_count, level, elem_base, max_used_index);
		}

		cur_idx++;
		if (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
		} else {
			break;
		}
	}

	expect(TOK_RBRACE);

	if (dims[level] == 0 && level == 0)
		dims[level] = cur_idx;
}

static int
parse_global_int_array_initializer(Global *g, int dims[MAX_ARRAY_DIMS], int dim_count)
{
	int max_used_index = 0;
	parse_global_int_array_initializer_level(g, dims, dim_count, 0, 0, &max_used_index);
	return max_used_index;
}

static int
try_parse_empty_global_compound_literal(void)
{
	/* Recognize exactly: (typedef_name){} or (_Bool){} etc. */
	if (lexer_peek()->kind != TOK_LPAREN)
		return 0;
	if (!is_type_start_token(lexer_peek_next()->kind, lexer_peek_next()->text))
		return 0;
	if (lexer_peek_after_next()->kind != TOK_RPAREN ||
	    lexer_peek_third()->kind != TOK_LBRACE ||
	    lexer_peek_fourth()->kind != TOK_RBRACE)
		return 0;

	lexer_next(); /* ( */
	lexer_next(); /* type name */
	expect(TOK_RPAREN);
	expect(TOK_LBRACE);
	expect(TOK_RBRACE);
	return 1;
}

static void 
parse_global_struct_initializer_body_ex(Global *g, StructDef *def, int base_offset, int allow_unbraced_end)
{
	int field_index = 0;

	while (lexer_peek()->kind != TOK_RBRACE) {
		Field *field = NULL;

		if (lexer_peek()->kind == TOK_DOT) {
			lexer_next();

			const Token *field_tok = lexer_peek();
			if (field_tok->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '.' in global struct initializer\n");
				exit(1);
			}

			lexer_next();
			expect(TOK_ASSIGN);
			field = find_field(def->name, field_tok->text);
			{
				int di = field_index_by_name_offset(def, field);
				if (di >= 0 && field_index <= di) {
					field_index = di + 1;
					while (field_index < def->field_count &&
					       field->size > 0 &&
					       def->fields[field_index].size > 0 &&
					       def->fields[field_index].offset == field->offset)
						field_index++;
				}
			}
		} else {
			if (field_index >= def->field_count) {
				if (allow_unbraced_end)
					return;
				break;
			}
			field = &def->fields[field_index++];

			/*
			 * Anonymous unions are flattened into multiple fields at the
			 * same offset. For positional initializers, consume only the
			 * first field in an offset run; the remaining promoted names are
			 * aliases, not extra initializer positions.
			 */
			while (field_index < def->field_count &&
			       field->size > 0 &&
			       def->fields[field_index].size > 0 &&
			       def->fields[field_index].offset == field->offset)
				field_index++;
		}

		const Token *value = lexer_peek();

		/* Optional braces around a scalar field, e.g. { (1) }. */
		if (value->kind == TOK_LBRACE && !field->is_array && !field->is_struct) {
			int scalar_value = 0;

			lexer_next(); /* consume { */
			if (!try_parse_global_scalar_initializer_value(&scalar_value)) {
				fatal_cur("Global scalar initializer must contain a constant integer\n");
				exit(1);
			}
			store_global_init_int(g, base_offset + field->offset, field->size, scalar_value);
			expect(TOK_RBRACE);

			if (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				if (lexer_peek()->kind == TOK_RBRACE)
					break;
			} else {
				break;
			}
			continue;
		}

		/* Nested initializer: { ... } for a struct/union or array field. */
		if (value->kind == TOK_LBRACE) {
			/* Array field: "int sub[2]" initializer "{2, 3}" */
			if (field->is_array) {
				lexer_next(); /* consume { */
				int arr_offset = base_offset + field->offset;
				int arr_elem = 0;
				int arr_max = field->size / (field->elem_size > 0 ? field->elem_size : 1);
				while (lexer_peek()->kind != TOK_RBRACE) {
					int av_val = 0;
					int braced_scalar = 0;

					/* Designated array element: {[0] = 1, 1+1}. */
					if (lexer_peek()->kind == TOK_LBRACKET) {
						lexer_next();
						arr_elem = eval_const_array_size();
						expect(TOK_RBRACKET);
						expect(TOK_ASSIGN);
					}

					/*
					 * Accept parenthesized constants and optional braces around
					 * individual array elements in aggregate initializers, e.g.
					 *
					 *     { (((3))), {4} }
					 */
					if (lexer_peek()->kind == TOK_LBRACE) {
						braced_scalar = 1;
						lexer_next();
					}

					if (!try_parse_global_scalar_initializer_value(&av_val)) {
						fatal_cur("Global array field initializer must contain constant integers\n");
						exit(1);
					}

					if (braced_scalar)
						expect(TOK_RBRACE);

					if (arr_elem < arr_max)
						store_global_init_int(g, arr_offset + arr_elem * field->elem_size, field->elem_size, av_val);
					arr_elem++;
					if (lexer_peek()->kind == TOK_COMMA) lexer_next(); else break;
				}
				expect(TOK_RBRACE);
				if (lexer_peek()->kind == TOK_COMMA) {
					lexer_next();
					if (lexer_peek()->kind == TOK_RBRACE) break;
				} else break;
				continue;
			}
			/* Skip over duplicate-offset union members to find the struct field. */
			while (!field->is_struct && field_index < def->field_count) {
				Field *nf = &def->fields[field_index];
				if (nf->is_struct) { field = nf; field_index++; break; }
				field_index++;
			}
			if (field->is_struct && field->struct_name[0]) {
				StructDef *nested = find_struct_or_null(field->struct_name);
				if (nested) {
					lexer_next(); /* consume { */
					parse_global_struct_initializer_body_ex(g, nested, base_offset + field->offset, 0);
					expect(TOK_RBRACE);
					if (lexer_peek()->kind == TOK_COMMA) {
						lexer_next();
						if (lexer_peek()->kind == TOK_RBRACE)
							break;
					} else {
						break;
					}
					continue;
				}
			}
		}

		/* Brace elision for nested struct fields inside aggregate initializers.
		 * Example:
		 *     struct U { unsigned char a; struct S s; unsigned char b; };
		 *     struct U gu = { 3, 5,6,7,8, 4 };
		 * The values 5,6,7,8 initialize the nested struct field. */
		if (field->is_struct && field->struct_name[0] &&
		    value->kind != TOK_LBRACE &&
		    value->kind != TOK_LPAREN &&
		    value->kind != TOK_RBRACE &&
		    value->kind != TOK_COMMA) {
			StructDef *nested = find_struct_or_null(field->struct_name);
			if (nested) {
				parse_global_struct_initializer_body_ex(g, nested,
				                                        base_offset + field->offset,
				                                        1);

				if (lexer_peek()->kind == TOK_COMMA) {
					lexer_next();
					if (lexer_peek()->kind == TOK_RBRACE)
						break;
				} else {
					break;
				}
				continue;
			}
		}

		/* Brace elision for array fields inside aggregate initializers.
		 * Example:
		 *     struct S { unsigned char a, b, c[2]; };
		 *     struct S gs = { 1, 2, 3, 4 };
		 * The final two scalars initialize c[0] and c[1]. */
		if (field->is_array &&
		    !(value->kind == TOK_STRING &&
		      field->type && field->type->kind == TY_ARRAY &&
		      field->type->base && field->type->base->kind == TY_CHAR)) {
			int arr_offset = base_offset + field->offset;
			int arr_elem = 0;
			int arr_max = field->size / (field->elem_size > 0 ? field->elem_size : 1);
			int parsed_array_values = 0;

			while (arr_elem < arr_max && lexer_peek()->kind != TOK_RBRACE) {
				int av_val = 0;

				if (!try_parse_global_scalar_initializer_value(&av_val))
					break;

				store_global_init_int(g,
				                      arr_offset + arr_elem * field->elem_size,
				                      field->elem_size,
				                      av_val);
				arr_elem++;
				parsed_array_values = 1;

				if (lexer_peek()->kind == TOK_COMMA) {
					/*
					 * In an unbraced aggregate initializer, a comma after the
					 * final element of an array field usually separates the next
					 * field in the same struct.  Leave it for the caller only if
					 * this array field is also the final field of the struct; then
					 * the comma separates the containing array's next struct.
					 *
					 * Example:
					 *   typedef struct { long c[4]; long b,e,k; } PT;
					 *   PT a[] = { c0,c1,c2,c3, b,e,k, ... };
					 * The comma after c3 must be consumed so b can be parsed.
					 */
					if (allow_unbraced_end && arr_elem >= arr_max &&
					    field_index >= def->field_count)
						break;
					lexer_next();
					if (lexer_peek()->kind == TOK_RBRACE)
						break;
				} else {
					break;
				}
			}

			if (parsed_array_values)
				continue;
		}

		if (field->is_struct && value->kind == TOK_LPAREN &&
		    try_parse_empty_global_compound_literal()) {
			/* Empty struct compound literal, e.g. (empty_s){}.  It contributes no bytes. */
		} else if (field->is_struct && value->kind == TOK_LPAREN && field->struct_name[0]) {
			StructDef *nested = find_struct_or_null(field->struct_name);
			if (!nested ||
			    !try_parse_global_struct_compound_initializer(g, nested,
			                                           field->struct_name,
			                                           base_offset + field->offset)) {
				fatal_cur("Invalid global struct compound literal initializer\n");
				exit(1);
			}
		} else if (try_parse_null_pointer_constant()) {
			store_global_init_int(g, base_offset + field->offset, field->size, 0);
		} else {
			int scalar_value = 0;
			if (try_parse_global_scalar_initializer_value(&scalar_value)) {
				store_global_init_int(g, base_offset + field->offset, field->size, scalar_value);
			} else if (value->kind == TOK_IDENT) {
				/* function pointer or global address initializer — store symbol */
				store_global_init_int(g, base_offset + field->offset, field->size, 0);
				if (g->init_sym_count < 128) {
					/* record slot index + symbol name */
					int slot = (base_offset + field->offset) / (field->size > 0 ? field->size : 4);
					if (slot < 128)
						STRNCPY(g->init_syms[slot], value->text, 63);
					g->init_sym_count++;
				}
				lexer_next();
			} else if (value->kind == TOK_STRING) {
				if (field->type && field->type->kind == TY_ARRAY &&
				    field->type->base && field->type->base->kind == TY_CHAR) {
					/* char[] field: store inline */
					store_global_init_string(g, base_offset + field->offset, field->size, value->text);
				} else {
					/* char* pointer field: create anon string global, store its address */
					char str_gname2[64];
					snprintf(str_gname2, sizeof(str_gname2), "__str_%d", next_string_label++);
					if (global_count + 1 < 512) {
						Global *sg2 = &globals[global_count + 1];
						memset(sg2, 0, sizeof(*sg2));
						sg2->is_string_array = 1;
						STRNCPY(sg2->name, str_gname2, sizeof(sg2->name)-1);
						STRNCPY(sg2->string_value, value->text, sizeof(sg2->string_value)-1);
						sg2->elem_size = 1;
						sg2->array_len = (int)strlen(value->text)+1;
						sg2->init_count = sg2->array_len;
						global_count++;
					}
					store_global_init_int(g, base_offset + field->offset, 8, 0);
					int pslot = (base_offset + field->offset) / 8;
					if (pslot < 128)
						STRNCPY(g->init_syms[pslot], str_gname2, 63);
					g->init_sym_count++;
				}
				lexer_next();
		} else if (value->kind == TOK_AMP && lexer_peek_next()->kind == TOK_IDENT) {
			/* &symbol — pointer initializer */
			lexer_next(); /* consume & */
			const Token *target = lexer_peek();
			lexer_next(); /* consume symbol name */
			store_global_init_int(g, base_offset + field->offset, field->size, 0);
			if (g->init_sym_count < 128) {
				int slot = (base_offset + field->offset) / (field->size > 0 ? field->size : 8);
				if (slot < 128)
					STRNCPY(g->init_syms[slot], target->text, 63);
				g->init_sym_count++;
			}
		} else {
			fatal_cur("Global struct initializer must contain constant integers or char-array strings\n");
			exit(1);
		}
	}

		/*
		 * For unbraced nested aggregate parsing, do not consume the
		 * comma after the nested struct's final field.  That comma is the
		 * separator in the containing initializer.
		 */
		if (allow_unbraced_end && field_index >= def->field_count)
			return;

		if (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
		} else {
			break;
		}
	}
}

static void
parse_global_struct_initializer_body(Global *g, StructDef *def, int base_offset)
{
	parse_global_struct_initializer_body_ex(g, def, base_offset, 0);
}

static int 
find_local(const char *name)
{
	/* Search in reverse order so most-recently-declared variable wins.
	 * This handles shadowing in for-loop inits where the same name is
	 * declared multiple times across sibling scopes. */
	for (int i = local_count - 1; i >= 0; i--) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].offset;
	}

	fatal_cur("Undefined variable: %s\n", name);
}

static int 
add_local_sized(const char *name, int slots, int is_array)
{
	/* Check only within the current scope level (locals visible from saved_local_count
	 * to local_count) for duplicates. Same-name variables in sibling blocks are valid C. */
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0 && !locals[i].is_static) {
			/* allow redeclaration if it's a shadow of an outer scope - only error
			 * if declared at the exact same block depth, which we can't easily track.
			 * For now, silently allow shadowing to match C semantics. */
			break;
		}
	}

	if (local_count >= 256) {
		fatal_cur("Too many local variables\n");
	}

	stack_size += slots * 4;

	STRNCPY(locals[local_count].name, name, sizeof(locals[local_count].name) - 1);
	locals[local_count].offset = -stack_size;
	locals[local_count].is_array = is_array;
	locals[local_count].array_len = slots;
	locals[local_count].is_pointer = 0;
	locals[local_count].elem_size = 4;
	locals[local_count].is_struct = 0;
	locals[local_count].struct_name[0] = '\0';
	locals[local_count].type = type_int();
	locals[local_count].struct_by_ref = 0;
	local_count++;

	return -stack_size;
}

static int 
add_local(const char *name)
{
	return add_local_sized(name, 1, 0);
}

static int 
add_static_local(const char *name, const char *global_name, Type *type, int elem_size, int is_array, int array_len)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			fatal_cur("Variable already declared: %s\n", name);
		}
	}

	if (local_count >= 256) {
		fatal_cur("Too many local variables\n");
	}

	STRNCPY(locals[local_count].name, name, sizeof(locals[local_count].name) - 1);
	locals[local_count].offset = 0;
	locals[local_count].is_array = is_array;
	locals[local_count].array_len = array_len;
	locals[local_count].is_pointer = 0;
	locals[local_count].elem_size = elem_size;
	locals[local_count].is_struct = 0;
	locals[local_count].struct_name[0] = '\0';
	locals[local_count].type = type;
	locals[local_count].struct_by_ref = 0;
	locals[local_count].is_static = 1;
	STRNCPY(locals[local_count].static_global_name, global_name, sizeof(locals[local_count].static_global_name) - 1);
	local_count++;
	return 0;
}

static int 
is_static_local(const char *name)
{
	for (int i = 0; i < local_count; i++)
		if (STRCMP(locals[i].name, name) == 0 && locals[i].is_static)
			return 1;
	return 0;
}

static const char *
static_global_name_local(const char *name)
{
	for (int i = 0; i < local_count; i++)
		if (STRCMP(locals[i].name, name) == 0 && locals[i].is_static)
			return locals[i].static_global_name;
	return "";
}

static int 
static_local_elem_size(const char *name)
{
	for (int i = 0; i < local_count; i++)
		if (STRCMP(locals[i].name, name) == 0 && locals[i].is_static)
			return locals[i].elem_size ? locals[i].elem_size : 4;
	return 4;
}

static int 
is_static_array_local(const char *name)
{
	for (int i = 0; i < local_count; i++)
		if (STRCMP(locals[i].name, name) == 0 && locals[i].is_static)
			return locals[i].is_array;
	return 0;
}

static int 
add_char_local(const char *name)
{
	int offset = add_local_sized(name, 1, 0);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].elem_size = 1;
			locals[i].type = type_char();
			return offset;
		}
	}

	return offset;
}

static int 
add_array_local(const char *name, int len, int elem_size)
{
	if (len <= 0) {
		fatal_cur("Array length must be positive: %s\n", name);
	}

	int bytes = len * elem_size;
	int slots = (bytes + 3) / 4;
	int offset = add_local_sized(name, slots, 1);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].array_len = len;
			locals[i].elem_size = elem_size;
			locals[i].type = type_array(elem_size == 1 ? type_char() : type_int(), len);
			return offset;
		}
	}

	return offset;
}

static int 
add_pointer_local(const char *name, int elem_size)
{
	int offset = add_local_sized(name, 2, 0);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].is_pointer = 1;
			locals[i].elem_size = elem_size;
			locals[i].type = type_ptr(type_for_size(elem_size));
			return offset;
		}
	}

	return offset;
}


static int add_typed_local(const char *name, Type *type)
{
	if (!type)
		return add_local(name);

	if (type->kind == TY_CHAR)
		return add_char_local(name);

	if (type->kind == TY_PTR) {
		int elem_size = type->base ? type->base->size : 4;
		int offset = add_pointer_local(name, elem_size);

		for (int i = 0; i < local_count; i++) {
			if (STRCMP(locals[i].name, name) == 0) {
				locals[i].type = clone_type(type);
				locals[i].is_pointer = 1;
				locals[i].elem_size = elem_size;
				if (type->base && type->base->kind == TY_STRUCT) {
					STRNCPY(locals[i].struct_name, type->base->struct_name, sizeof(locals[i].struct_name) - 1);
				}
				return offset;
			}
		}

		return offset;
	}

	if (type->kind == TY_ARRAY) {
		int bytes = type->size;
		int slots = (bytes + 3) / 4;
		int offset = add_local_sized(name, slots, 1);

		for (int i = 0; i < local_count; i++) {
			if (STRCMP(locals[i].name, name) == 0) {
				locals[i].type = clone_type(type);
				locals[i].array_len = type->array_len;
				locals[i].elem_size = type->base ? type->base->size : type->size;
				if (type->base && type->base->kind == TY_STRUCT) {
					int n=sizeof(locals[i].struct_name) - 1;
					STRNCPY(locals[i].struct_name, type->base->struct_name, n);
				}
				return offset;
			}
		}

		return offset;
	}

	if (type->kind == TY_STRUCT) {
		return add_struct_local(name, type->struct_name);
	}

	return add_local(name);
}

static int 
add_typed_array_local(const char *name, Type *base_type, int len)
{
	int elem_size = type_elem_size(base_type);
	int offset = add_array_local(name, len, elem_size);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].type = type_array(clone_type(base_type), len);
			locals[i].elem_size = elem_size;
			return offset;
		}
	}

	return offset;
}

static int 
is_pointer_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].is_pointer;
	}

	fatal_cur("Undefined variable: %s\n", name);
}

static int 
is_pointer_local_optional(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].is_pointer;
	}
	return 0;
}

static Type *
type_local(const char *name)
{
	for (int i = local_count - 1; i >= 0; i--) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].type ? locals[i].type : type_int();
	}

	fatal_cur("Undefined variable: %s\n", name);
}

static int 
elem_size_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].elem_size ? locals[i].elem_size : 4;
	}

	fatal_cur("Undefined variable: %s\n", name);
}

static int 
is_array_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].is_array;
	}
	return 0;
}

static StructDef *
find_struct(const char *name)
{
	for (int i = 0; i < struct_count; i++) {
		if (STRCMP(structs[i].name, name) == 0)
			return &structs[i];
	}

	fatal_cur("Unknown struct: %s\n", name);
}

static StructDef *
find_struct_or_null(const char *name)
{
	for (int i = 0; i < struct_count; i++) {
		if (STRCMP(structs[i].name, name) == 0)
			return &structs[i];
	}
	return NULL;
}

static StructDef *
get_or_add_forward_struct(const char *name)
{
	StructDef *def = find_struct_or_null(name);
	if (def)
		return def;
	if (struct_count >= 128) {
		fatal_cur("Too many structs\n");
	}
	def = &structs[struct_count++];
	memset(def, 0, sizeof(*def));
	STRNCPY(def->name, name, sizeof(def->name) - 1);
	def->align = 1;
	return def;
}

static void __attribute__((unused)) 
skip_balanced_brace_body(void)
{
	expect(TOK_LBRACE);
	int depth = 1;
	while (depth > 0) {
		const Token *t = lexer_peek();
		if (t->kind == TOK_EOF) {
			fatal_cur("Unexpected EOF in aggregate body\n");
		}
		lexer_next();
		if (t->kind == TOK_LBRACE)
			depth++;
		else if (t->kind == TOK_RBRACE)
			depth--;
	}
}

static void 
parse_struct_body_into(StructDef *def)
{
	expect(TOK_LBRACE);

	int offset = 0;
	int max_align = 1;

	while (lexer_peek()->kind != TOK_RBRACE) {
		const Token *type = lexer_peek();
		int field_size = 4;
		int field_align = 4;
		int field_is_struct = 0;
		char field_struct_name[64] = {0};
		Type *field_type = NULL;

		if (!is_type_start_token(type->kind, type->text)) {
			fatal_cur("Only int, char, typedef, and nested aggregate fields are supported in structs for now\n");
		}

		field_type = parse_type_name();
		if (field_type->kind == TY_PTR) {
			field_size = 8;
			field_align = 8;
		} else if (field_type->kind == TY_CHAR) {
			field_size = 1;
			field_align = 1;
		} else if (field_type->kind == TY_SHORT) {
			field_size = 2;
			field_align = 2;
		} else if (field_type->kind == TY_STRUCT) {
			field_size = field_type->size;
			{
				StructDef *nested = find_struct_or_null(field_type->struct_name);
				field_align = aggregate_align(nested);
			}
			field_is_struct = 1;
			STRNCPY(field_struct_name, field_type->struct_name, sizeof(field_struct_name) - 1);
		} else {
			field_size = 4;
			field_align = 4;
		}

		if (lexer_peek()->kind == TOK_LPAREN &&
		        lexer_peek_next()->kind == TOK_STAR) {
			lexer_next();
			lexer_next();

			const Token *field = lexer_peek();
			if (field->kind != TOK_IDENT) {
				fatal_cur("Expected function pointer field name\n");
			}
			char fp_name_buf[64] = {0};
			STRNCPY(fp_name_buf, field->text ? field->text : "", sizeof(fp_name_buf) - 1);
			lexer_next();
			expect(TOK_RPAREN);
			expect(TOK_LPAREN);
			while (lexer_peek()->kind != TOK_RPAREN)
				lexer_next();
			expect(TOK_RPAREN);
			expect(TOK_SEMI);

			if (def->field_count >= MAX_STRUCT_FIELDS) {
				fatal_cur("Too many struct fields\n");
			}

			offset = (offset + 7) & ~7;

			Field *f = &def->fields[def->field_count++];
			STRNCPY(f->name, fp_name_buf, sizeof(f->name) - 1);
			f->offset = offset;
			f->size = 8;
			f->is_struct = 0;
			f->type = type_ptr(type_int());
			offset += 8;
			if (max_align < 8)
				max_align = 8;
			continue;
		}

		/* Anonymous member: "struct/union { ... };" with no field name.
		 * Flatten the nested aggregate's fields into this struct. */
		if ((lexer_peek()->kind == TOK_SEMI) &&
		    field_type && field_type->kind == TY_STRUCT && field_struct_name[0]) {
			expect(TOK_SEMI);
			StructDef *anon = find_struct_or_null(field_struct_name);
			if (anon) {
				int base = def->is_union ? 0 : ((offset + field_align - 1) & ~(field_align - 1));
				for (int ai = 0; ai < anon->field_count && def->field_count < MAX_STRUCT_FIELDS; ai++) {
					Field *src = &anon->fields[ai];
					Field *dst = &def->fields[def->field_count++];
					*dst = *src;
					dst->offset = anon->is_union ? base : (base + src->offset);
				}
				if (!def->is_union)
					offset = base + anon->size;
				else if (anon->size > offset)
					offset = anon->size;
				if (anon->align > max_align)
					max_align = anon->align;
			}
			continue;
		}

		/* consume pointer stars: "char *p" — parse_type_name gave TY_CHAR, star here */
		while (lexer_peek()->kind == TOK_STAR) {
			lexer_next();
			field_type = type_ptr(field_type);
			field_size = 8;
			field_align = 8;
		}

		const Token *field = lexer_peek();
		if (field->kind != TOK_IDENT || !field->text) {
			fatal_token(field, "Expected struct field name\n");
			exit(1);
		}

		/* Helper lambda (via macro pattern): commit one field then loop on comma */
		int flexible_array_member = 0;
		do {
			char field_name[64] = {0};
			if (field->kind != TOK_IDENT || !field->text) {
				fatal_token(field, "Expected struct field name\n");
			}
			STRNCPY(field_name, field->text, sizeof(field_name) - 1);
			lexer_next();

			Type *this_field_type = clone_type(field_type);
			int this_field_size = field_size;

			while (lexer_peek()->kind == TOK_LBRACKET) {
				lexer_next();

				if (lexer_peek()->kind == TOK_RBRACKET) {
					/*
					 * C99 flexible array member:
					 *
					 *     struct outer { int n; struct S s[]; };
					 *
					 * It contributes no size to the containing struct and must
					 * be the final member.
					 */
					if (def->is_union) {
						fatal_cur("Flexible array member not allowed in union\n");
					}
					flexible_array_member = 1;
					this_field_type = type_array(this_field_type, 0);
					this_field_size = 0;
					lexer_next();
					break;
				}

				const Token *len = lexer_peek();
				if (len->kind != TOK_NUM || len->value <= 0) {
					fatal_cur("Expected positive numeric struct field array length\n");
				}
				this_field_type = type_array(this_field_type, len->value);
				this_field_size = this_field_type->size;
				lexer_next();
				expect(TOK_RBRACKET);
			}
			/* Bitfield: "type name : N" -- skip the bit width specifier */
			if (lexer_peek()->kind == TOK_COLON) {
				lexer_next(); /* : */
				if (lexer_peek()->kind == TOK_NUM) lexer_next(); /* N */
			}

			if (def->field_count >= MAX_STRUCT_FIELDS) {
				fatal_cur("Too many struct fields\n");
			}

			offset = (offset + field_align - 1) & ~(field_align - 1);

			Field *f = &def->fields[def->field_count++];
			STRNCPY(f->name, field_name, sizeof(f->name) - 1);
			f->offset = def->is_union ? 0 : offset;
			f->size = this_field_size;
			f->is_struct = field_is_struct;
			f->type = clone_type(this_field_type);
			f->is_array = (this_field_type->kind == TY_ARRAY);
			f->elem_size = f->is_array ? type_elem_size(this_field_type->base ? this_field_type->base : this_field_type) : this_field_size;
			if (field_is_struct)
				STRNCPY(f->struct_name, field_struct_name, sizeof(f->struct_name) - 1);
			if (!def->is_union)
				offset += this_field_size;
			else if (this_field_size > offset)
				offset = this_field_size;

			if (field_align > max_align)
				max_align = field_align;

			/* A flexible array member must be the final member declaration. */
			if (flexible_array_member && lexer_peek()->kind != TOK_SEMI) {
				fatal_cur("Flexible array member must be final struct field\n");
			}

			/* comma: next declarator of same base type, possibly with * */
			if (lexer_peek()->kind != TOK_COMMA) break;
			lexer_next(); /* consume , */
			/* allow extra pointer depth per declarator: "int *p, q;" */
			Type *next_type = clone_type(field_type);
			int next_size = field_size;
			int next_align = field_align;
			while (lexer_peek()->kind == TOK_STAR) {
				lexer_next();
				next_type = type_ptr(next_type);
				next_size = 8; next_align = 8;
			}
			field = lexer_peek();
			field_type = next_type;
			field_size = next_size;
			field_align = next_align;
		} while (1);

		expect(TOK_SEMI);
		if (flexible_array_member && lexer_peek()->kind != TOK_RBRACE) {
			fatal_cur("Flexible array member must be final struct field\n");
		}
	}

	expect(TOK_RBRACE);
	def->align = max_align;
	def->size = align_to(offset, max_align);
}

static Field *
find_field(const char *struct_name, const char *field_name)
{
	StructDef *def = find_struct(struct_name);

	for (int i = 0; i < def->field_count; i++) {
		if (STRCMP(def->fields[i].name, field_name) == 0)
			return &def->fields[i];
	}

	if (def->field_count == 0) {
		Field *field = &def->fields[def->field_count++];
		STRNCPY(field->name, field_name, sizeof(field->name) - 1);
		field->offset = 0;
		field->size = 4;
		return field;
	}

	fatal_cur("Unknown field %s.%s\n", struct_name, field_name);
}

static void 
apply_field_type(Node *node, Field *field)
{
	if (!node || !field)
		return;

	node->is_array_field = field->is_array;

	if (field->type) {
		node->type = clone_type(field->type);
		/* elem_size is the STORAGE size of the field, not the pointee size.
		 * Pointer fields are always 8 bytes on arm64 (and 4 on 32-bit targets,
		 * but we use 8 throughout since we target 64-bit). */
		if (field->type->kind == TY_PTR)
			node->elem_size = 8;
		else
			node->elem_size = type_elem_size(field->type);
		if (field->type->kind == TY_STRUCT)
			STRNCPY(node->struct_name, field->type->struct_name, sizeof(node->struct_name) - 1);
		else
			node->struct_name[0] = '\0';
		return;
	}

	node->elem_size = field->size;
	if (field->is_struct) {
		node->type = type_struct(field->struct_name, field->size);
		STRNCPY(node->struct_name, field->struct_name, sizeof(node->struct_name) - 1);
	} else {
		node->type = type_for_size(field->size);
		node->struct_name[0] = '\0';
	}
}

static int add_struct_local(const char *name, const char *struct_name)
{
	StructDef *def = find_struct(struct_name);
	int slots = (def->size + 3) / 4;
	int offset = add_local_sized(name, slots, 0);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].is_struct = 1;
			STRNCPY(locals[i].struct_name, struct_name, sizeof(locals[i].struct_name) - 1);
			locals[i].type = type_struct(struct_name, def->size);
			return offset;
		}
	}

	return offset;
}

static int add_struct_pointer_local(const char *name, const char *struct_name)
{
	StructDef *def = find_struct(struct_name);
	int offset = add_local_sized(name, 2, 0);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].is_pointer = 1;
			locals[i].elem_size = def->size;
			STRNCPY(locals[i].struct_name, struct_name, sizeof(locals[i].struct_name) - 1);
			locals[i].type = type_ptr(type_struct(struct_name, def->size));
			return offset;
		}
	}

	return offset;
}

static int 
add_struct_byref_param_local(const char *name, const char *struct_name)
{
	int offset = add_struct_pointer_local(name, struct_name);

	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			locals[i].struct_by_ref = 1;
			return offset;
		}
	}

	return offset;
}

static int 
is_struct_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].is_struct;
	}
	return 0;
}

static int 
is_struct_by_ref_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].struct_by_ref;
	}

	return 0;
}

static const char *
struct_name_local(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].struct_name;
	}
	return "";
}

static const char *
struct_name_local_optional(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0)
			return locals[i].struct_name;
	}

	return "";
}

static FuncInfo *
find_func(const char *name)
{
	for (int i = 0; i < func_count; i++) {
		if (STRCMP(funcs[i].name, name) == 0)
			return &funcs[i];
	}

	return NULL;
}

static void 
add_func_info(const char *name, int returns_struct, const char *struct_name, int struct_size, int returns_pointer, int return_elem_size)
{
	if (func_count >= 512) {
		fatal_cur("Too many functions\n");
	}

	STRNCPY(funcs[func_count].name, name, sizeof(funcs[func_count].name) - 1);
	funcs[func_count].returns_struct = returns_struct;
	funcs[func_count].struct_size = struct_size;
	funcs[func_count].returns_pointer = returns_pointer;
	funcs[func_count].return_elem_size = return_elem_size;
	funcs[func_count].is_variadic = 0;
	funcs[func_count].fixed_param_count = 0;
	if (struct_name)
		STRNCPY(funcs[func_count].struct_name, struct_name, sizeof(funcs[func_count].struct_name) - 1);
	func_count++;
}

static void skip_inline_qualifiers(void);

static int
is_gnu_attribute_token(const Token *t)
{
	return t && t->kind == TOK_IDENT && t->text && STRCMP(t->text, "__attribute__") == 0;
}

static void
skip_one_gnu_attribute(void)
{
	if (!is_gnu_attribute_token(lexer_peek()))
		return;

	lexer_next();
	expect(TOK_LPAREN);
	expect(TOK_LPAREN);

	int depth = 1;
	while (depth > 0) {
		const Token *t = lexer_peek();
		if (t->kind == TOK_EOF) {
			fatal_cur("Unexpected EOF in __attribute__\n");
			exit(1);
		}
		lexer_next();
		if (t->kind == TOK_LPAREN)
			depth++;
		else if (t->kind == TOK_RPAREN)
			depth--;
	}
	expect(TOK_RPAREN);
}


static void
skip_balanced_parenthesized_tokens(void)
{
	expect(TOK_LPAREN);
	int depth = 1;
	while (depth > 0) {
		const Token *t = lexer_peek();
		if (t->kind == TOK_EOF) {
			fatal_cur("Unexpected EOF in parenthesized declarator\n");
			exit(1);
		}
		lexer_next();
		if (t->kind == TOK_LPAREN)
			depth++;
		else if (t->kind == TOK_RPAREN)
			depth--;
	}
}

static int
try_parse_abstract_function_pointer_declarator(Type **ptype)
{
	if (lexer_peek()->kind != TOK_LPAREN)
		return 0;

	lexer_next();
	skip_inline_qualifiers();

	if (lexer_peek()->kind != TOK_STAR) {
		fatal_cur("Unsupported parenthesized abstract declarator in cast\n");
		exit(1);
	}

	lexer_next();
	skip_inline_qualifiers();
	expect(TOK_RPAREN);

	if (lexer_peek()->kind == TOK_LPAREN)
		skip_balanced_parenthesized_tokens();

	*ptype = type_ptr(*ptype);
	return 1;
}

static void 
skip_inline_qualifiers(void)
{
	for (;;) {
		const Token *t = lexer_peek();
		if (t->kind == TOK_INLINE ||
		        t->kind == TOK_STATIC ||
		        t->kind == TOK_EXTERN ||
		        t->kind == TOK_CONST) {
			lexer_next();
			continue;
		}

		if (t->kind == TOK_IDENT && t->text &&
		        (STRCMP(t->text, "volatile") == 0 ||
		         STRCMP(t->text, "__volatile__") == 0 ||
		         STRCMP(t->text, "__volatile") == 0 ||
		         STRCMP(t->text, "__restrict") == 0 ||
		         STRCMP(t->text, "__restrict__") == 0)) {
			lexer_next();
			continue;
		}

		if (is_gnu_attribute_token(t)) {
			skip_one_gnu_attribute();
			continue;
		}
		break;
	}
}

static int 
is_prototype_start(void)
{
	return lexer_is_function_prototype();
}

static void 
parse_prototype_param_metadata(int *is_variadic, int *fixed_params)
{
	int depth = 1;
	int param_n = 0;

	if (is_variadic)
		*is_variadic = 0;
	if (fixed_params)
		*fixed_params = 0;

	expect(TOK_LPAREN);

	while (depth > 0) {
		const Token *t = lexer_peek();

		if (t->kind == TOK_EOF) {
			fatal_cur("Unexpected EOF in prototype\n");
		}

		if (t->kind == TOK_LPAREN) {
			depth++;
			lexer_next();
			continue;
		}

		if (t->kind == TOK_RPAREN) {
			depth--;
			lexer_next();
			if (depth == 0)
				break;
			continue;
		}

		if (t->kind == TOK_COMMA && depth == 1) {
			param_n++;
			lexer_next();
			continue;
		}

		if (t->kind == TOK_DOT && depth == 1 &&
		        lexer_peek_next()->kind == TOK_DOT) {
			if (is_variadic)
				*is_variadic = 1;
			if (fixed_params)
				*fixed_params = param_n;

			while (lexer_peek()->kind != TOK_RPAREN &&
			        lexer_peek()->kind != TOK_EOF)
				lexer_next();

			if (lexer_peek()->kind == TOK_RPAREN)
				lexer_next();

			return;
		}

		lexer_next();
	}
}

static void  __attribute__((unused)) 
skip_param_list(void)
{
	parse_prototype_param_metadata(NULL, NULL);
}

static void 
parse_union_definition(void)
{
	expect(TOK_UNION);

	const Token *name = lexer_peek();
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected union name\n");
	}

	lexer_next();
	expect(TOK_LBRACE);

	/* Reuse an existing forward declaration.  This matters for:
	 *
	 *   typedef union tree_node *tree;
	 *   union tree_node { struct tree_common common; };
	 *
	 * The typedef creates a forward aggregate named tree_node.  If the
	 * later union definition creates a second entry with the same name,
	 * find_struct("tree_node") can return the empty forward entry and
	 * expressions like (convs)->common.code lose the type of common.
	 */
	StructDef *def = find_struct_or_null(name->text);
	if (!def) {
		if (struct_count >= 128) {
			fatal_cur("Too many aggregates\n");
		}

		def = &structs[struct_count++];
	}
	memset(def, 0, sizeof(*def));
	def->is_union = 1;
	STRNCPY(def->name, name->text, sizeof(def->name) - 1);

	int max_size = 0;
	int max_align = 1;

	while (lexer_peek()->kind != TOK_RBRACE) {
		const Token *type = lexer_peek();
		int field_size = 4;
		int field_align = 4;
		int field_is_struct = 0;
		char field_struct_name[64] = {0};
		Type *field_type = NULL;
		int field_elem_size = 4;

		/*
		 * Union fields need the same type handling as struct fields.  In
		 * particular, torture/00216 uses typedef aliases such as:
		 *
		 *     typedef unsigned char u8;
		 *     union U { u8 a; ... };
		 *
		 * The old union parser only accepted literal int/char/short tokens and
		 * rejected typedef scalar fields before the declarator name was reached.
		 */
		if (!is_type_start_token(type->kind, type->text)) {
			fatal_cur("Only int, char, typedef, and nested aggregate fields are supported in unions for now\n");
		}

		field_type = parse_type_name();

		if (field_type->kind == TY_PTR) {
			field_size = 8;
			field_align = 8;
		} else if (field_type->kind == TY_CHAR) {
			field_size = 1;
			field_align = 1;
		} else if (field_type->kind == TY_SHORT) {
			field_size = 2;
			field_align = 2;
		} else if (field_type->kind == TY_STRUCT) {
			StructDef *nested = find_struct(field_type->struct_name);
			field_size = nested->size;
			field_align = aggregate_align(nested);
			field_is_struct = 1;
			STRNCPY(field_struct_name, field_type->struct_name, sizeof(field_struct_name) - 1);
		} else {
			field_size = 4;
			field_align = 4;
		}
		field_elem_size = field_size;

		/*
		 * Anonymous aggregate member inside a union:
		 *
		 *     union U {
		 *         struct { u8 a, b; };
		 *         int x;
		 *     };
		 *
		 * There is no declarator name after the anonymous struct body; the
		 * nested fields are promoted as members of the containing union.  Since
		 * this is a union, the anonymous aggregate starts at offset zero, but
		 * its promoted fields keep their offsets within the anonymous struct.
		 */
		if (field_is_struct && lexer_peek()->kind == TOK_SEMI) {
			StructDef *anon = find_struct_or_null(field_struct_name);
			expect(TOK_SEMI);

			if (anon) {
				/*
				 * Preserve the anonymous aggregate itself as the first union
				 * field.  This lets a braced initializer such as:
				 *
				 *     union UV guv = {{6,5}};
				 *
				 * initialize the anonymous struct as one aggregate.  We still
				 * promote its members below so direct access like guv.a/guv.b
				 * and designated initializers such as {.b = 8} continue to work.
				 */
				if (def->field_count >= MAX_STRUCT_FIELDS) {
					fatal_cur("Too many union fields\n");
				}

				Field *agg = &def->fields[def->field_count++];
				STRNCPY(agg->name, field_struct_name, sizeof(agg->name) - 1);
				agg->offset = 0;
				agg->size = field_size;
				agg->is_struct = 1;
				STRNCPY(agg->struct_name, field_struct_name, sizeof(agg->struct_name) - 1);
				agg->type = type_struct(field_struct_name, field_size);

				for (int ai = 0; ai < anon->field_count; ai++) {
					if (def->field_count >= MAX_STRUCT_FIELDS) {
						fatal_cur("Too many union fields\n");
					}

					Field *src = &anon->fields[ai];
					Field *dst = &def->fields[def->field_count++];
					*dst = *src;
					/* promoted anonymous-struct members live inside the union at offset 0 */
					dst->offset = src->offset;
				}
			}

			if (field_size > max_size)
				max_size = field_size;
			if (field_align > max_align)
				max_align = field_align;
			continue;
		}

		const Token *field = lexer_peek();
		if (field->kind != TOK_IDENT || !field->text) {
			fatal_token(field, "Expected union field name\n");
			exit(1);
		}

		char field_name[64] = {0};
		STRNCPY(field_name, field->text, sizeof(field_name) - 1);

		lexer_next();

		if (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();
			const Token *len = lexer_peek();
			if (len->kind == TOK_NUM && len->value > 0) {
				field_type = type_array(field_type, len->value);
				field_size *= len->value;
				lexer_next();
			}
			expect(TOK_RBRACKET);
		}

		expect(TOK_SEMI);

		if (def->field_count >= MAX_STRUCT_FIELDS) {
			fatal_cur("Too many union fields\n");
		}

		Field *f = &def->fields[def->field_count++];
		STRNCPY(f->name, field_name, sizeof(f->name) - 1);
		f->offset = 0;
		f->size = field_size;
		f->is_struct = field_is_struct;
		f->is_array = field_type && field_type->kind == TY_ARRAY;
		f->elem_size = field_elem_size;
		if (field_is_struct) {
			STRNCPY(f->struct_name, field_struct_name, sizeof(f->struct_name) - 1);
			f->type = type_struct(field_struct_name, field_size);
		} else if (field_type) {
			f->type = clone_type(field_type);
		} else {
			f->type = type_for_size(field_size);
		}

		if (field_size > max_size)
			max_size = field_size;
		if (field_align > max_align)
			max_align = field_align;
	}

	expect(TOK_RBRACE);
	expect(TOK_SEMI);

	def->align = max_align;
	def->size = align_to(max_size, max_align);
}

static int 
try_parse_prototype(void)
{
	Debug(1, "TRY_PROTO: current=%s\n", token_debug_name(lexer_peek()->kind));
	if (!is_prototype_start()) {
		Debug(1, "TRY_PROTO: is_prototype_start=0\n");
		return 0;
	}
	Debug(1, "TRY_PROTO: is_prototype_start=1\n");

	Type *ret_type = parse_type_name();
	/* skip __attribute__((noreturn)) etc. between return type and function name */
	skip_inline_qualifiers();
	Debug(1, "TRY_PROTO: after type, current=%s text=%s\n",
	      token_debug_name(lexer_peek()->kind),
	      lexer_peek()->text ? lexer_peek()->text : "<null>");
	int returns_pointer = ret_type->kind == TY_PTR;
	int return_elem_size = 4;
	int returns_struct = 0;
	int struct_size = 0;
	char struct_name[64] = {0};

	if (ret_type->kind == TY_PTR) {
		return_elem_size = ret_type->base ? ret_type->base->size : 4;
	} else if (ret_type->kind == TY_CHAR) {
		return_elem_size = 1;
	} else if (ret_type->kind == TY_STRUCT) {
		returns_struct = 1;
		struct_size = ret_type->size;
		STRNCPY(struct_name, ret_type->struct_name, sizeof(struct_name) - 1);
	}

	const Token *name = lexer_peek();
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected function prototype name\n");
	}
	char proto_name[64] = {0};
	STRNCPY(proto_name, name->text ? name->text : "", sizeof(proto_name) - 1);

	lexer_next();

	int proto_is_variadic = 0;
	int proto_fixed_params = 0;
	parse_prototype_param_metadata(&proto_is_variadic, &proto_fixed_params);
	skip_inline_qualifiers();

	Debug(1, "TRY_PROTO: before semi check, current=%s\n",
	      token_debug_name(lexer_peek()->kind));
	if (lexer_peek()->kind != TOK_SEMI && lexer_peek()->kind != TOK_COMMA) {
		Debug(1, "TRY_PROTO: not semi, returning 0\n");
		return 0;
	}

	if (lexer_peek()->kind == TOK_SEMI) lexer_next();
	/* if comma: leave it; caller's comma loop will consume it */

	add_func_info(proto_name, returns_struct, struct_name, struct_size,
	              returns_pointer, return_elem_size);

	if (proto_is_variadic) {
		for (int _pi = func_count - 1; _pi >= 0; _pi--) {
			if (STRCMP(funcs[_pi].name, proto_name) == 0) {
				funcs[_pi].is_variadic = 1;
				funcs[_pi].fixed_param_count = proto_fixed_params;
				break;
			}
		}
	}

	return 1;
}

static Node *
parse_arg_list(void)
{
	Node head = {0};
	Node *cur = &head;

	if (lexer_peek()->kind == TOK_RPAREN)
		return NULL;

	for (;;) {
		Node *arg = parse_expr();
		if (arg->type && arg->type->kind == TY_STRUCT) {
			/* If arg is a struct-returning call, spill to temp first */
			if (arg->kind == ND_CALL && arg->returns_struct) {
				char temp_name[64];
				snprintf(temp_name, sizeof(temp_name), "__struct_arg_%d", struct_arg_temp_id++);
				const char *sname = arg->return_struct_name[0] ? arg->return_struct_name
				                    : (arg->type ? arg->type->struct_name : "");
				StructDef *def = find_struct(sname);
				int sz = def ? def->size : 8;
				int temp_off = add_struct_local(temp_name, sname);

				Node *lhs = new_var(temp_name, temp_off);
				lhs->type = type_struct(sname, sz);
				lhs->elem_size = sz;
				STRNCPY(lhs->struct_name, sname, sizeof(lhs->struct_name) - 1);

				Node *assign = new_assign(lhs, arg);

				Node *temp_ref = new_var(temp_name, temp_off);
				temp_ref->type = type_struct(sname, sz);
				temp_ref->elem_size = sz;
				STRNCPY(temp_ref->struct_name, sname, sizeof(temp_ref->struct_name) - 1);

				Node *addr = new_addr(temp_ref);
				addr->by_ref_arg = 1;

				arg = new_binary(ND_COMMA, assign, addr);
				arg->type = addr->type;
			} else {
				arg = new_addr(arg);
				arg->by_ref_arg = 1;
			}
		}

		cur->next = arg;
		cur = cur->next;

		if (lexer_peek()->kind != TOK_COMMA)
			break;

		lexer_next();
	}

	return head.next;
}

static const char *
ensure_current_func_name_global(void)
{
	static char gname[128];

	if (!current_func_name[0])
		return "";

	snprintf(gname, sizeof(gname), "__func__%s", current_func_name);

	if (find_global(gname))
		return gname;

	if (global_count >= 512) {
		fatal_cur("Too many globals\n");
	}

	Global *g = &globals[global_count];
	memset(g, 0, sizeof(*g));
	STRNCPY(g->name, gname, sizeof(g->name) - 1);
	g->is_array = 1;
	g->elem_size = 1;
	g->is_string_array = 1;
	g->is_static = 1;
	STRNCPY(g->string_value, current_func_name, sizeof(g->string_value) - 1);
	g->init_count = (int)strlen(current_func_name) + 1;
	g->array_len = g->init_count;
	global_count++;

	return gname;
}

static Node *
make_var_node(const char *name)
{
	/* __func__ — implicitly defined per C99 §6.4.2.2.
	 * Register the backing string lazily only when __func__ is referenced. */
	if (STRCMP(name, "__func__") == 0 && current_func_name[0]) {
		const char *gname = ensure_current_func_name_global();
		Node *node = new_func_addr(gname);
		node->is_pointer = 1;
		node->elem_size = 1;
		node->type = type_ptr(type_char());
		return node;
	}

	if (is_static_local(name)) {
		const char *gname = static_global_name_local(name);
		Node *node = new_global(gname);
		node->elem_size = static_local_elem_size(name);
		node->type = type_for_size(node->elem_size);
		return node;
	}


	if (is_global(name)) {
		/* Array globals decay to pointer-to-first-element (C99 §6.3.2.1).
		 * Emit addr_global (adrp+add) to get the address, not a load. */
		if (is_global_array(name) && !is_global_pointer(name)) {
			Node *node = new_func_addr(name);
			node->is_pointer = 1;
			node->type = global_array_decay_type(name, &node->elem_size);
			return node;
		}
		Node *node = new_global(name);
		node->is_pointer = is_global_pointer(name);
		node->elem_size = is_global_pointer(name) ? global_pointer_elem_size(name) : global_elem_size(name);
		node->is_unsigned = is_global_unsigned(name);
		if (is_global_struct(name)) {
			node->type = type_struct(global_struct_name(name), global_elem_size(name));
			STRNCPY(node->struct_name, global_struct_name(name), sizeof(node->struct_name) - 1);
		} else if (is_global_pointer(name) && global_struct_name(name)[0]) {
			node->type = type_ptr(type_struct(global_struct_name(name), node->elem_size));
			STRNCPY(node->struct_name, global_struct_name(name), sizeof(node->struct_name) - 1);
		} else {
			node->type = is_global_pointer(name) ? type_ptr(type_for_size(node->elem_size)) : type_for_size_unsigned(global_elem_size(name), is_global_unsigned(name));
		}
		return node;
	}

	/* Function name used as a value (function pointer): "v.fptr = foo;"
	 * Only when the name is NOT shadowed by a local variable or parameter. */
	{
		int _shadowed = 0;
		for (int _i = local_count - 1; _i >= 0; _i--) {
			if (STRCMP(locals[_i].name, name) == 0) { _shadowed = 1; break; }
		}
		if (!_shadowed && find_func(name)) {
			Node *fnode = new_func_addr(name);
			fnode->is_pointer = 1;
			fnode->elem_size = 8;
			fnode->type = type_ptr(type_int());
			return fnode;
		}
	}

	Node *node = new_var(name, find_local(name));
	node->type = type_local(name);
	node->is_unsigned = node->type && node->type->is_unsigned;

	if (is_array_local(name)) {
		Node *addr = new_addr(node);
		addr->is_pointer = 1;
		addr->elem_size = elem_size_local(name);
		if (node->type && node->type->kind == TY_ARRAY)
			addr->type = type_ptr(node->type->base);
		return addr;
	}

	node->is_pointer = is_pointer_local(name);
	node->elem_size = elem_size_local(name);
	node->is_unsigned = node->type && node->type->is_unsigned;
	if (is_struct_local(name))
		STRNCPY(node->struct_name, struct_name_local_optional(name), sizeof(node->struct_name) - 1);
	if (node->is_pointer && struct_name_local_optional(name)[0])
		STRNCPY(node->struct_name, struct_name_local_optional(name), sizeof(node->struct_name) - 1);
	return node;
}

static Node *
make_scalar_var_node(const char *name)
{
	/* __func__ — implicitly defined per C99 §6.4.2.2 */
	if (STRCMP(name, "__func__") == 0 && current_func_name[0]) {
		char gname[128];
		snprintf(gname, sizeof(gname), "__func__%s", current_func_name);
		/* __func__ is a char[] — we want its address, not its contents.
		 * Use ND_FUNC_ADDR so the IR emits addr_global (adrp+add) not a load. */
		Node *node = new_func_addr(gname);
		node->is_pointer = 1;
		node->elem_size = 1;
		node->type = type_ptr(type_char());
		return node;
	}

	if (is_static_local(name)) {
		const char *gname = static_global_name_local(name);
		Node *node = new_global(gname);
		node->elem_size = static_local_elem_size(name);
		node->type = type_for_size(node->elem_size);
		return node;
	}


	if (is_global(name)) {
		if (is_global_array(name) && !is_global_pointer(name)) {
			Node *node = new_func_addr(name);
			node->is_pointer = 1;
			node->type = global_array_decay_type(name, &node->elem_size);
			return node;
		}
		Node *node = new_global(name);
		node->is_pointer = is_global_pointer(name);
		node->elem_size = is_global_pointer(name) ? global_pointer_elem_size(name) : global_elem_size(name);
		node->is_unsigned = is_global_unsigned(name);
		if (is_global_struct(name)) {
			node->type = type_struct(global_struct_name(name), global_elem_size(name));
			STRNCPY(node->struct_name, global_struct_name(name), sizeof(node->struct_name) - 1);
		} else if (is_global_pointer(name) && global_struct_name(name)[0]) {
			node->type = type_ptr(type_struct(global_struct_name(name), node->elem_size));
			STRNCPY(node->struct_name, global_struct_name(name), sizeof(node->struct_name) - 1);
		} else {
			node->type = is_global_pointer(name) ? type_ptr(type_for_size(node->elem_size)) : type_for_size_unsigned(global_elem_size(name), is_global_unsigned(name));
		}
		return node;
	}

	Node *node = new_var(name, find_local(name));
	node->type = type_local(name);
	node->is_unsigned = node->type && node->type->is_unsigned;
	node->is_pointer = is_pointer_local(name);
	node->elem_size = elem_size_local(name);
	if (is_struct_local(name))
		STRNCPY(node->struct_name, struct_name_local_optional(name), sizeof(node->struct_name) - 1);
	if (node->is_pointer && struct_name_local_optional(name)[0])
		STRNCPY(node->struct_name, struct_name_local_optional(name), sizeof(node->struct_name) - 1);
	return node;
}

static Node *
parse_struct_compound_literal_member_expr(void)
{
	/*
	 * v112 expression subset:
	 *
	 *   ((struct Point){ .x = 1, .y = 41 }).y
	 *
	 * This supports direct member reads from a struct compound literal.  It
	 * does not materialize a temporary aggregate; instead it returns the
	 * selected initializer expression, defaulting omitted fields to 0.
	 */
	if (lexer_peek()->kind != TOK_LPAREN ||
	        lexer_peek_next()->kind != TOK_STRUCT)
		return NULL;

	lexer_next(); /* ( */
	lexer_next(); /* struct */

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in compound literal\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_LBRACE) {
		fatal_cur("Expected initializer list in compound literal\n");
	}
	lexer_next();

	StructDef *def = find_struct(struct_name->text);
	Node *values[128] = {0};
	int field_index = 0;

	while (lexer_peek()->kind != TOK_RBRACE) {
		Field *field = NULL;
		int selected = -1;

		if (lexer_peek()->kind == TOK_DOT) {
			lexer_next();

			const Token *field_name = lexer_peek();
			if (field_name->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '.' in compound literal\n");
			}
			lexer_next();
			expect(TOK_ASSIGN);

			field = find_field(struct_name->text, field_name->text);
			for (int i = 0; i < def->field_count; i++) {
				if (&def->fields[i] == field) {
					selected = i;
					break;
				}
			}
		} else {
			if (field_index >= def->field_count) {
				fatal_cur("Too many values in compound literal for %s\n", struct_name->text);
			}

			selected = field_index++;
			field = &def->fields[selected];
		}

		if (selected < 0 || selected >= 128) {
			fatal_cur("Invalid compound literal field\n");
		}

		values[selected] = parse_expr();

		if (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
		} else {
			break;
		}
	}

	expect(TOK_RBRACE);

	/*
	 * Accept both:
	 *
	 *   (struct Point){ .x = 1 }.x
	 *   ((struct Point){ .x = 1 }).x
	 *
	 * The second form arrives here with one extra ')' before the member dot.
	 */
	if (lexer_peek()->kind == TOK_RPAREN && lexer_peek_next()->kind == TOK_DOT)
		lexer_next();

	if (lexer_peek()->kind != TOK_DOT) {
		fatal_cur("Only direct member access on struct compound literals is supported for now\n");
	}

	lexer_next();

	const Token *member_name = lexer_peek();
	if (member_name->kind != TOK_IDENT) {
		fatal_cur("Expected field name after compound literal '.'\n");
	}
	lexer_next();

	Field *wanted = find_field(struct_name->text, member_name->text);
	int wanted_index = -1;
	for (int i = 0; i < def->field_count; i++) {
		if (&def->fields[i] == wanted) {
			wanted_index = i;
			break;
		}
	}

	if (wanted_index < 0 || wanted_index >= 128) {
		fatal_cur("Invalid compound literal selected field\n");
	}

	if (!values[wanted_index])
		return new_num(0);

	values[wanted_index]->type = type_for_size(wanted->size);
	values[wanted_index]->elem_size = wanted->size;
	return values[wanted_index];
}

static Node *
parse_statement_expression(void)
{
	Node head = {0};
	Node *cur = &head;
	Node *block;

	/* GNU C statement expression: ({ statements; expr; })
	 * The final expression statement leaves its value in the accumulator when
	 * the block is emitted as an expression.  This is enough for constructs such
	 * as:
	 *
	 *     int x = ({ int y = 1; y; });
	 *
	 * and for statement expressions in the inactive arm of ?: expressions. */
	expect(TOK_LPAREN);
	expect(TOK_LBRACE);

	while (lexer_peek()->kind != TOK_RBRACE) {
		if (lexer_peek()->kind == TOK_EOF) {
			fatal_cur("Unterminated statement expression\n");
			exit(1);
		}
		append_stmt(&cur, parse_statement());
	}

	expect(TOK_RBRACE);
	expect(TOK_RPAREN);

	block = new_block(head.next);
	block->type = type_int();
	block->elem_size = 4;
	return block;
}


static Node *parse_generic_selection(void)
{
	/* _Generic(controlling-expression, type1: val1, ..., default: valdn)
	 * C11 generic selection. We parse and do simple type matching. */
	expect(TOK_LPAREN);
	Node *ctrl = parse_expr();
	expect(TOK_COMMA);

	/* Determine the type of the controlling expression */
	int ctrl_is_ptr = 0;    /* is a pointer type */
	int ctrl_size = 4;      /* size in bytes */
	int ctrl_is_str = 0;    /* string literal (const char *) */
	int ctrl_is_long = 0;   /* long int */
	int ctrl_is_unsigned = 0;
	char ctrl_struct[64] = {0};  /* struct name if struct */

	if (ctrl) {
		if (ctrl->kind == ND_STRING) { ctrl_is_ptr=1; ctrl_is_str=1; ctrl_size=8; }
		else if (ctrl->type) {
			Type *t = ctrl->type;
			if (t->kind == TY_PTR) { ctrl_is_ptr=1; ctrl_size=8; }
			else if (t->kind == TY_STRUCT) { ctrl_size=t->size; STRNCPY(ctrl_struct, t->struct_name, sizeof(ctrl_struct)-1); }
			else { ctrl_size=t->size ? t->size : 4; ctrl_is_unsigned=t->is_unsigned; }
			ctrl_is_long = (t->size == 8 && t->kind != TY_PTR && t->kind != TY_STRUCT);
		} else {
			ctrl_size = ctrl->elem_size ? ctrl->elem_size : 4;
			ctrl_is_ptr = ctrl->is_pointer;
			ctrl_is_long = (ctrl_size == 8 && !ctrl_is_ptr);
		}
	}

	Node *result = NULL;
	Node *default_result = NULL;
	int matched = 0;

	while (lexer_peek()->kind != TOK_RPAREN && lexer_peek()->kind != TOK_EOF) {
		/* Parse type specifier or "default" */
		int is_default = 0;
		int arm_match = 0;

		if (lexer_peek()->kind == TOK_IDENT &&
		    lexer_peek()->text && STRCMP(lexer_peek()->text, "default") == 0) {
			lexer_next();
			is_default = 1;
		} else {
			/* Parse type specifier to match against ctrl */
			/* We do a lightweight parse: consume qualifiers + base type + modifiers */
			int arm_is_const = 0, arm_is_ptr = 0, arm_is_long = 0;
			int arm_size = 4, arm_is_unsigned = 0, arm_is_arr = 0;
			char arm_struct[64] = {0};

			/* Consume qualifiers and sign specifiers */
			while (lexer_peek()->kind == TOK_CONST ||
			       lexer_peek()->kind == TOK_UNSIGNED ||
			       lexer_peek()->kind == TOK_SIGNED ||
			       (lexer_peek()->kind == TOK_IDENT && lexer_peek()->text &&
			        STRCMP(lexer_peek()->text, "volatile") == 0)) {
				if (lexer_peek()->kind == TOK_CONST) arm_is_const=1;
				if (lexer_peek()->kind == TOK_UNSIGNED) arm_is_unsigned=1;
				lexer_next();
			}

			/* Base type */
			if (lexer_peek()->kind == TOK_INT) { arm_size=4; lexer_next(); }
			else if (lexer_peek()->kind == TOK_CHAR) { arm_size=1; lexer_next(); }
			else if (lexer_peek()->kind == TOK_LONG) {
				arm_size=8; arm_is_long=1; lexer_next();
				if (lexer_peek()->kind == TOK_LONG) { lexer_next(); arm_size=8; } /* long long */
				if (lexer_peek()->kind == TOK_INT) lexer_next();
			} else if (lexer_peek()->kind == TOK_SHORT) { arm_size=2; lexer_next();
				if (lexer_peek()->kind == TOK_INT) lexer_next();
			} else if (lexer_peek()->kind == TOK_STRUCT || lexer_peek()->kind == TOK_UNION) {
				lexer_next();
				if (lexer_peek()->kind == TOK_IDENT)
					{ STRNCPY(arm_struct, lexer_peek()->text, sizeof(arm_struct)-1); lexer_next(); }
			} else if (lexer_peek()->kind == TOK_IDENT && lexer_peek()->text) {
				/* typedef name */
				Type *td = find_typedef(lexer_peek()->text);
				if (td) { arm_size = td->size ? td->size : 4; lexer_next(); }
				else { /* unknown -- consume it */ lexer_next(); }
			} else { lexer_next(); } /* skip anything else */

			/* Qualifiers after base type */
			while (lexer_peek()->kind == TOK_CONST ||
			       (lexer_peek()->kind == TOK_IDENT && lexer_peek()->text &&
			        STRCMP(lexer_peek()->text, "volatile") == 0)) {
				if (lexer_peek()->kind == TOK_CONST) arm_is_const=1;
				lexer_next();
			}

			/* Pointer stars */
			while (lexer_peek()->kind == TOK_STAR) {
				arm_is_ptr++; lexer_next();
				if (lexer_peek()->kind == TOK_CONST) { arm_is_const=1; lexer_next(); }
			}

			/* Array subscript: int[4] */
			if (lexer_peek()->kind == TOK_LBRACKET) {
				arm_is_arr=1;
				while (lexer_peek()->kind != TOK_RBRACKET && lexer_peek()->kind != TOK_EOF)
					lexer_next();
				if (lexer_peek()->kind == TOK_RBRACKET) lexer_next();
			}
			(void)arm_is_const; (void)arm_is_arr; (void)arm_is_unsigned;

			/* Match */
			if (!matched) {
				if (arm_struct[0]) {
					arm_match = (ctrl_struct[0] && STRCMP(ctrl_struct, arm_struct) == 0);
				} else if (arm_is_ptr) {
					arm_match = ctrl_is_ptr;
				} else if (arm_is_long) {
					arm_match = ctrl_is_long;
				} else {
					arm_match = (!ctrl_is_ptr && !ctrl_is_long && ctrl_size == arm_size);
				}
			}
		}

		expect(TOK_COLON);
		Node *arm_val = parse_expr();

		if (is_default) {
			default_result = arm_val;
		} else if (arm_match && !matched) {
			result = arm_val;
			matched = 1;
		}

		if (lexer_peek()->kind == TOK_COMMA) lexer_next();
	}

	expect(TOK_RPAREN);

	if (!result) result = default_result;
	if (!result) result = new_num(0);
	return result;
}

static Node *
parse_factor(void)
{
	const Token *token = lexer_peek();

	if (token->kind == TOK_NUM) {
		lexer_next();
		return new_num(token->value);
	}

	if (token->kind == TOK_STRING) {
		lexer_next();
		/* concatenate adjacent string literals: "a" "b" -> "ab" */
		char buf[4096];
		int blen = 0;
		const char *s = token->text;
		while (*s && blen < 4095)
			buf[blen++] = *s++;
		while (lexer_peek()->kind == TOK_STRING) {
			const Token *next = lexer_next();
			s = next->text;
			while (*s && blen < 4095)
				buf[blen++] = *s++;
		}
		buf[blen] = '\0';
		return new_string(buf, next_string_label++);
	}

	if (token->kind == TOK_IDENT && token->text &&
	    STRCMP(token->text, "_Generic") == 0) {
		lexer_next();
		return parse_generic_selection();
	}

	if (token->kind == TOK_IDENT) {
		lexer_next();

		char ident_name[64];
		STRNCPY(ident_name, token->text, sizeof(ident_name) - 1);

		if (lexer_peek()->kind == TOK_LPAREN) {
			lexer_next();
			Node *args = parse_arg_list();
			expect(TOK_RPAREN);

			/*
			 * GCC/Clang branch prediction hint.  It has no required runtime
			 * semantics beyond evaluating and returning the first argument, so
			 * lower __builtin_expect(expr, expected) to expr and deliberately
			 * discard the expected-value argument.
			 */
			if (STRCMP(ident_name, "__builtin_expect") == 0) {
				if (!args) {
					fatal_cur("__builtin_expect requires at least one argument\n");
				}
				return args;
			}

			/*
			 * A call expression whose callee name denotes a function-pointer
			 * object must be emitted as an indirect call.  This applies to both
			 * locals/parameters and globals, e.g.:
			 *
			 *     int (*fprintfptr)(FILE *, const char *, ...) = &fprintf;
			 *     fprintfptr(stderr, "%d\\n", 42);
			 *
			 * Do not turn that into a direct branch to the data symbol
			 * _fprintfptr; load the pointer value and BLR through it.
			 */
			if (is_pointer_local_optional(ident_name) || is_global_pointer(ident_name)) {
				Node *callee = make_scalar_var_node(ident_name);
				return new_indirect_call(callee, args);
			}

			Node *call = new_call(ident_name, args);
			FuncInfo *fi = find_func(ident_name);
			if (fi && fi->returns_struct) {
				call->returns_struct = 1;
				call->struct_return_size = fi->struct_size;
				STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);
				call->type = type_struct(fi->struct_name, fi->struct_size);
			} else if (fi && fi->returns_pointer) {
				call->is_pointer = 1;
				call->elem_size = fi->return_elem_size;
				call->type = type_ptr(type_for_size(fi->return_elem_size));
			}
			return call;
		}

		if (lexer_peek()->kind == TOK_DOT && is_global_struct(ident_name)) {
			lexer_next();

			const Token *field_tok = lexer_peek();
			if (field_tok->kind != TOK_IDENT) {
				fatal_cur("Expected field name after global struct '.'\n");
			}
			lexer_next();

			StructDef *def = find_struct(global_struct_name(ident_name));
			Field *field = find_field(def->name, field_tok->text);

			if (field->is_struct && field->struct_name[0] && lexer_peek()->kind == TOK_DOT) {
				/* Nested struct: v.s.a — get byte address of v.s, then access .a */
				/* Use addr_gidx with byte offset to get &v.s, then chain dot access */
				Node *base = new_global_index(ident_name, new_num(field->offset), 1);
				base->is_array_field = 1; /* use addr_gidx to get pointer */
				base->is_pointer = 1;
				base->elem_size = field->size;
				STRNCPY(base->struct_name, field->struct_name, sizeof(base->struct_name) - 1);
				base->type = type_struct(field->struct_name, field->size);
				/* Now handle .next_field via member_ptr */
				lexer_next(); /* consume . */
				const Token *inner_tok = lexer_peek();
				if (inner_tok->kind != TOK_IDENT)
					fatal_cur("Expected field name after nested global struct '.'\n");
				lexer_next();
				StructDef *inner_def = find_struct(field->struct_name);
				Field *inner_field = find_field(inner_def->name, inner_tok->text);
				Node *member = new_member_ptr(inner_tok->text, base, inner_field->offset);
				member->elem_size = inner_field->size;
				apply_field_type(member, inner_field);
				return member;
			}

			/* Use addr_gidx (byte offset, scale=1) + load_deref for correct access.
			 * This avoids the elem_size multiply in gidx_load giving wrong byte offsets. */
			Node *addr = new_global_index(ident_name, new_num(field->offset), 1);
			addr->is_array_field = 1; /* emit addr_gidx to get pointer */
			addr->is_pointer = 1;
			addr->elem_size = field->size;
			Node *member = new_deref(addr);
			member->elem_size = field->size;
			apply_field_type(member, field);
			STRNCPY(member->struct_name, def->name, sizeof(member->struct_name) - 1);
			return member;
		}

		if (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();
			Node *index = parse_expr();
			expect(TOK_RBRACKET);

			if (is_global_array(ident_name) && is_global_struct(ident_name) &&
			        lexer_peek()->kind == TOK_DOT) {
				lexer_next();

				const Token *field_tok = lexer_peek();
				if (field_tok->kind != TOK_IDENT) {
					fatal_cur("Expected field name after global struct array '.'\n");
				}
				lexer_next();

				StructDef *def = find_struct(global_struct_name(ident_name));
				Field *field = find_field(def->name, field_tok->text);

				/* Compute byte offset: index * sizeof(struct) + field->offset.
				 * Then use addr_gidx with elem_size=1 to get byte address,
				 * and load/store with field->size for correct width. */
				Node *byte_idx = new_binary(ND_MUL, index, new_num(def->size));
				if (field->offset != 0)
					byte_idx = new_binary(ND_ADD, byte_idx, new_num(field->offset));

				if (field->is_array) {
					/* Array field: produce address of element, not a load.
					 * For entries[i].name (char[32]), we want &entries[i].name[0]. */
					int byte_scale = def->size;
					Node *array_byte_idx = index;
					if (byte_scale != 1)
						array_byte_idx = new_binary(ND_MUL, array_byte_idx, new_num(byte_scale));
					if (field->offset != 0)
						array_byte_idx = new_binary(ND_ADD, array_byte_idx, new_num(field->offset));
					Node *member = new_global_index(ident_name, array_byte_idx, 1);
					member->is_array_field = 1;
					apply_field_type(member, field);
					member->elem_size = 1; /* byte-indexed: array_byte_idx is already in bytes */
					STRNCPY(member->struct_name, def->name, sizeof(member->struct_name) - 1);
					return member;
				}

				/* Non-array field: compute byte address then dereference. */
				Node *gidx = new_global_index(ident_name, byte_idx, 1);
				gidx->is_array_field = 1; /* use addr_gidx, not gidx_load */
				Node *member = new_deref(gidx);
				member->elem_size = field->size;
				apply_field_type(member, field);
				STRNCPY(member->struct_name, def->name, sizeof(member->struct_name) - 1);
				return member;
			}

			if (is_static_local(ident_name) && is_static_array_local(ident_name)) {
				const char *gname = static_global_name_local(ident_name);
				return new_global_index(gname, index, static_local_elem_size(ident_name));
			}

			if (is_global_array(ident_name)) {
				Global *gg = find_global(ident_name);
				if (gg && gg->array_dim_count > 1) {
					Node *base = new_func_addr(ident_name);
					base->is_pointer = 1;
					base->type = global_array_decay_type(ident_name, &base->elem_size);
					Node *addr = new_binary(ND_ADD, base, index);
					addr->is_pointer = 1;
					addr->elem_size = base->elem_size;
					addr->type = base->type;
					Node *deref = new_deref(addr);
					if (base->type && base->type->kind == TY_PTR)
						deref->type = base->type->base;
					deref->elem_size = deref->type ? deref->type->size : base->elem_size;
					return deref;
				}
				return new_global_index(ident_name, index, global_elem_size(ident_name));
			}

			if (is_global_pointer(ident_name)) {
				Node *base = make_scalar_var_node(ident_name);
				Node *addr = new_binary(ND_ADD, base, index);
				addr->is_pointer = 1;
				addr->elem_size = base->elem_size;
				if (base->type && base->type->kind == TY_PTR)
					addr->type = base->type;
				return new_deref(addr);
			}

			if (is_array_local(ident_name)) {
				Type *arr_type = type_local(ident_name);
				int elem_size = elem_size_local(ident_name);

				Node *idx_node = new_index(ident_name, find_local(ident_name), index);
				idx_node->elem_size = elem_size;

				if (arr_type && arr_type->kind == TY_ARRAY &&
				        arr_type->base && arr_type->base->kind == TY_STRUCT) {
					idx_node->type = arr_type->base;
					STRNCPY(idx_node->struct_name, arr_type->base->struct_name, sizeof(idx_node->struct_name) - 1);

					if (lexer_peek()->kind == TOK_DOT) {
						lexer_next();

						const Token *field = lexer_peek();
						if (field->kind != TOK_IDENT) {
							fatal_cur("Expected field name after struct array '.'\n");
						}
						lexer_next();

						const char *current_struct = arr_type->base->struct_name;
						Field *f = find_field(current_struct, field->text);
						int field_offset = f->offset;

						while (f->is_struct && lexer_peek()->kind == TOK_DOT) {
							lexer_next();

							const Token *nested = lexer_peek();
							if (nested->kind != TOK_IDENT) {
								fatal_cur("Expected nested field name after '.'\n");
							}
							lexer_next();

							current_struct = f->struct_name;
							Field *nf = find_field(current_struct, nested->text);
							field_offset += nf->offset;
							f = nf;
						}

						Node *addr = new_addr(idx_node);
						Node *member = new_member_ptr(field->text, addr, field_offset);
						apply_field_type(member, f);
						return member;
					}

					return idx_node;
				}

				idx_node->type = type_for_size(idx_node->elem_size);

				/* For multi-dimensional arrays, the element type may itself be
				 * an array — preserve the type so a second [idx] can work.
				 * Do NOT overwrite elem_size: it must remain the ROW size (e.g. 4
				 * for char[2][4]) so that emit_addr_indexed scales correctly. */
				if (arr_type && arr_type->base && arr_type->base->kind == TY_ARRAY) {
					idx_node->type = arr_type->base;
					/* elem_size stays as row_size (elem_size_local), NOT inner elem size */
				}

				return idx_node;
			}

			if (is_pointer_local_optional(ident_name)) {
				Node *base = make_scalar_var_node(ident_name);
				Node *addr = new_binary(ND_ADD, base, index);
				addr->is_pointer = 1;
				addr->elem_size = base->elem_size;
				if (base->type && base->type->kind == TY_PTR)
					addr->type = base->type;

				if (base->struct_name[0] && lexer_peek()->kind == TOK_DOT) {
					lexer_next();

					const Token *field = lexer_peek();
					if (field->kind != TOK_IDENT) {
						fatal_cur("Expected field name after pointer index '.'\n");
					}
					lexer_next();

					const char *current_struct = base->struct_name;
					Field *f = find_field(current_struct, field->text);
					int field_offset = f->offset;

					while (f->is_struct && lexer_peek()->kind == TOK_DOT) {
						lexer_next();

						const Token *nested = lexer_peek();
						if (nested->kind != TOK_IDENT) {
							fatal_cur("Expected nested field name after '.'\n");
						}
						lexer_next();

						current_struct = f->struct_name;
						Field *nf = find_field(current_struct, nested->text);
						field_offset += nf->offset;
						f = nf;
					}

					Node *member = new_member_ptr(field->text, addr, field_offset);
					apply_field_type(member, f);
					return member;
				}

				return new_deref(addr);
			}

			fatal_cur("Indexed object is not an array or pointer: %s\n", ident_name);
		}

		if (lexer_peek()->kind == TOK_DOT) {
			if (!is_struct_local(ident_name) && !is_struct_by_ref_local(ident_name)) {
				fatal_cur("Member access on non-struct: %s\n", ident_name);
			}

			lexer_next();

			const Token *field = lexer_peek();
			if (field->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '.'\n");
			}

			lexer_next();

			if (is_struct_by_ref_local(ident_name)) {
				Node *base = make_scalar_var_node(ident_name);
				Field *f = find_field(base->struct_name, field->text);
				Node *node = new_member_ptr(field->text, base, f->offset);
				apply_field_type(node, f);
				return node;
			}

			Field *f = find_field(struct_name_local(ident_name), field->text);
			int member_offset = find_local(ident_name) + f->offset;
			char current_struct[64] = {0};
			if (f->is_struct)
				STRNCPY(current_struct, f->struct_name, sizeof(current_struct) - 1);

			while (f->is_struct && lexer_peek()->kind == TOK_DOT) {
				lexer_next();

				const Token *nested_field = lexer_peek();
				if (nested_field->kind != TOK_IDENT) {
					fatal_cur("Expected nested field name after '.'\n");
				}
				lexer_next();

				Field *nf = find_field(current_struct, nested_field->text);
				member_offset += nf->offset;
				f = nf;
				if (f->is_struct)
					STRNCPY(current_struct, f->struct_name, sizeof(current_struct) - 1);
			}

			Node *node = new_member(field->text, member_offset);
			apply_field_type(node, f);
			return node;
		}

		if (lexer_peek()->kind == TOK_ARROW) {
			int arrow_ok = 0;
			const char *arrow_struct = "";

			if (is_pointer_local_optional(ident_name) && struct_name_local_optional(ident_name)[0]) {
				arrow_ok = 1;
				arrow_struct = struct_name_local_optional(ident_name);
			} else if (is_global_pointer(ident_name) && global_struct_name(ident_name)[0]) {
				arrow_ok = 1;
				arrow_struct = global_struct_name(ident_name);
			} else if (is_global_array(ident_name) && is_global_struct(ident_name) &&
			           global_struct_name(ident_name)[0]) {
				/*
				 * C array-to-pointer decay also applies before ->.
				 * For a global array of structs, e.g.
				 *
				 *     PT cases[];
				 *     sizeof(cases->c)
				 *
				 * treat cases as &cases[0], so cases->c is
				 * equivalent to (&cases[0])->c.
				 */
				arrow_ok = 1;
				arrow_struct = global_struct_name(ident_name);
			} else if (is_array_local(ident_name)) {
				Type *lt = type_local(ident_name);
				if (lt && lt->kind == TY_ARRAY && lt->base &&
				    lt->base->kind == TY_STRUCT && lt->base->struct_name[0]) {
					arrow_ok = 1;
					arrow_struct = lt->base->struct_name;
				}
			}

			if (!arrow_ok) {
				fatal_cur("Arrow access on non-struct pointer: %s\n", ident_name);
			}

			lexer_next();

			const Token *field = lexer_peek();
			if (field->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '->'\n");
			}

			lexer_next();

			Node *base = make_scalar_var_node(ident_name);
			const char *current_struct = arrow_struct[0] ? arrow_struct : base->struct_name;
			Field *f = find_field(current_struct, field->text);
			int field_offset = f->offset;

			while (f->is_struct && lexer_peek()->kind == TOK_DOT) {
				lexer_next();

				const Token *nested_field = lexer_peek();
				if (nested_field->kind != TOK_IDENT) {
					fatal_cur("Expected nested field name after '.'\n");
				}
				lexer_next();

				current_struct = f->struct_name;
				Field *nf = find_field(current_struct, nested_field->text);
				field_offset += nf->offset;
				f = nf;
			}

			Node *node = new_member_ptr(field->text, base, field_offset);
			apply_field_type(node, f);
			return node;
		}

		{
			int enum_value = 0;
			if (find_enum_const(ident_name, &enum_value))
				return new_num(enum_value);
		}

		return make_var_node(ident_name);
	}

	if (token->kind == TOK_LPAREN) {
		if (lexer_peek_next()->kind == TOK_LBRACE)
			return parse_statement_expression();

		if (lexer_peek_next()->kind == TOK_LPAREN &&
		        lexer_peek_after_next()->kind == TOK_STRUCT &&
		        lexer_peek_third()->kind == TOK_IDENT &&
		        lexer_peek_fourth()->kind == TOK_RPAREN &&
		        lexer_peek_fifth()->kind == TOK_LBRACE) {
			lexer_next(); /* outer '(' */
			Node *compound_member = parse_struct_compound_literal_member_expr();
			if (compound_member)
				return compound_member;
		}

		if (lexer_peek_next()->kind == TOK_STRUCT &&
		        lexer_peek_after_next()->kind == TOK_IDENT &&
		        lexer_peek_third()->kind == TOK_RPAREN &&
		        lexer_peek_fourth()->kind == TOK_LBRACE) {
			Node *compound_member = parse_struct_compound_literal_member_expr();
			if (compound_member)
				return compound_member;
		}

		lexer_next();

		if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
			Type *type = parse_type_name();

			/* Accept GNU attributes and abstract function-pointer declarators
			 * inside casts, for example:
			 *   ((ATTR int (*)(void)) p)()
			 *   ((int (ATTR *)(void)) p)()
			 * The attributes are syntax-only for now; the result type is a
			 * pointer-sized function pointer.
			 */
			skip_inline_qualifiers();
			if (lexer_peek()->kind == TOK_LPAREN)
				try_parse_abstract_function_pointer_declarator(&type);
			skip_inline_qualifiers();

			expect(TOK_RPAREN);
			return new_cast(parse_unary(), type);
		}

		/*
		 * Parenthesized expressions may contain the comma operator.  Keep
		 * parse_expr() itself as an assignment-expression because callers such
		 * as parse_arg_list() use commas as separators, not operators.
		 */
		Node *node = parse_assignment();
		while (lexer_peek()->kind == TOK_COMMA) {
			lexer_next();
			Node *rhs = parse_assignment();
			node = new_binary(ND_COMMA, node, rhs);
		}
		expect(TOK_RPAREN);
		return node;
	}

	fatal_token(token, "Expected expression factor");
	return 0;
}

static Node *
parse_postfix(void)
{
	Node *node = parse_factor();

	for (;;) {
		TokenKind op = lexer_peek()->kind;

		if (op == TOK_LBRACKET) {
			lexer_next();
			Node *index = parse_expr();
			expect(TOK_RBRACKET);

			if (node->type && node->type->kind == TY_ARRAY && node->type->base) {
				Type *elem_type = node->type->base;
				Node *base = new_addr(node);
				base->is_pointer = 1;
				base->elem_size = elem_type->size;
				base->type = type_ptr(elem_type);

				Node *addr = new_binary(ND_ADD, base, index);
				addr->is_pointer = 1;
				addr->elem_size = elem_type->size;
				addr->type = type_ptr(elem_type);

				node = new_deref(addr);
				node->type = elem_type;
				node->elem_size = elem_type->size;
				if (elem_type->kind == TY_STRUCT)
					STRNCPY(node->struct_name, elem_type->struct_name, sizeof(node->struct_name) - 1);
				continue;
			}

			if ((node->type && node->type->kind == TY_PTR && node->type->base) || node->is_pointer) {
				Type *elem_type = (node->type && node->type->kind == TY_PTR && node->type->base)
				                  ? node->type->base
				                  : type_for_size(node->elem_size ? node->elem_size : 4);

				Node *addr = new_binary(ND_ADD, node, index);
				addr->is_pointer = 1;
				addr->elem_size = elem_type->size;
				addr->type = type_ptr(elem_type);

				node = new_deref(addr);
				node->type = elem_type;
				node->elem_size = elem_type->size;
				if (elem_type->kind == TY_STRUCT)
					STRNCPY(node->struct_name, elem_type->struct_name, sizeof(node->struct_name) - 1);
				continue;
			}

			fatal_cur("Indexed expression is not an array or pointer\n");
		}

		if (op == TOK_DOT) {
			const char *dot_struct_name = "";

			if (node->type && node->type->kind == TY_STRUCT)
				dot_struct_name = node->type->struct_name;
			else if (node->struct_name[0])
				dot_struct_name = node->struct_name;

			if (!dot_struct_name || !dot_struct_name[0]) {
				fatal_cur("Member access on non-struct expression\n");
			}

			lexer_next();

			const Token *field = lexer_peek();
			if (field->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '.'\n");
			}
			lexer_next();

			Field *f = find_field(dot_struct_name, field->text);

			if (node->kind == ND_VAR || node->kind == ND_MEMBER) {
				node = new_member(field->text, node->offset + f->offset);
			} else if (node->kind == ND_CALL && node->returns_struct) {
				/* call().field — spill call result to temp, access field on temp.
				 * Emit as: (temp = call(), temp.field) via ND_COMMA. */
				char temp_name[64];
				snprintf(temp_name, sizeof(temp_name), "__struct_dot_%d", struct_arg_temp_id++);
				const char *sname = node->type ? node->type->struct_name : "";
				if (!sname[0]) sname = node->return_struct_name;
				StructDef *def = find_struct(sname);
				int sz = def ? def->size : 8;
				int temp_off = add_struct_local(temp_name, sname);

				Node *lhs = new_var(temp_name, temp_off);
				lhs->type = type_struct(sname, sz);
				lhs->elem_size = sz;
				STRNCPY(lhs->struct_name, sname, sizeof(lhs->struct_name) - 1);

				Node *assign = new_assign(lhs, node);

				Node *member = new_member(field->text, temp_off + f->offset);
				apply_field_type(member, f);

				/* ND_COMMA: eval assign as side-effect, result is member */
				node = new_binary(ND_COMMA, assign, member);
				node->type = member->type;
				node->elem_size = member->elem_size;
				continue;
			} else {
				Node *base = new_addr(node);
				node = new_member_ptr(field->text, base, f->offset);
			}

			apply_field_type(node, f);
			continue;
		}

		if (op == TOK_ARROW) {
			const char *struct_name = "";
			if (node->type && node->type->kind == TY_PTR && node->type->base &&
			        node->type->base->kind == TY_STRUCT)
				struct_name = node->type->base->struct_name;
			else if (node->struct_name[0])
				struct_name = node->struct_name;
			else if (node->type && node->type->kind == TY_STRUCT)
				struct_name = node->type->struct_name;
			else {
				/* Try to determine struct from field name by peeking ahead */
				const Token *peek_field = lexer_peek_next(); /* token after '->' */
				if (peek_field->kind == TOK_IDENT) {
					/* Search all known structs for this field */
					for (int si = 0; si < struct_count; si++) {
						for (int fi2 = 0; fi2 < structs[si].field_count; fi2++) {
							if (STRCMP(structs[si].fields[fi2].name, peek_field->text) == 0) {
								struct_name = structs[si].name;
								goto found_struct;
							}
						}
					}
				}
				fatal_cur("Arrow access on non-struct pointer expression\n");
found_struct:;
			}

			lexer_next();

			const Token *field = lexer_peek();
			if (field->kind != TOK_IDENT) {
				fatal_cur("Expected field name after '->'\n");
			}
			lexer_next();

			Field *f = find_field(struct_name, field->text);
			node = new_member_ptr(field->text, node, f->offset);
			apply_field_type(node, f);
			continue;
		}

		if (op == TOK_PLUSPLUS || op == TOK_MINUSMINUS) {
			lexer_next();
			node = make_incdec(node, op, 1);
			continue;
		}

		if (op == TOK_LPAREN) {
			/* indirect call through a function pointer expression, e.g. cg->emit_fn() */
			lexer_next();
			Node *args = parse_arg_list();
			expect(TOK_RPAREN);
			/* For "(*p)(args)" where p is a function pointer variable:
			 * DEREF(VAR(p)) is a no-op — calling (*p)(args) == calling p(args).
			 * Replace DEREF(VAR(p)) with VAR(p) so we load from p's stack slot,
			 * not from the function's code address. */
			Node *callee = node;
			int callee_stripped = 0;
			if (callee->kind == ND_DEREF && callee->left &&
			    callee->left->is_pointer) {
				/*
				 * Calling through (*fp)(...) does not dereference the function
				 * code as data; for function pointers, unary * is a no-op in
				 * call context.  This covers both local function-pointer
				 * variables and global function-pointer objects.
				 */
				callee = callee->left;
				callee_stripped = 1;
			}
			Node *icall = new_indirect_call(callee, args);
			/* If we stripped a DEREF from a function-pointer-variable,
			 * the call may return another function pointer. */
			if (callee_stripped) {
				icall->is_pointer = 1;
				icall->elem_size = 8;
				icall->type = callee->type;
			} else if (callee->kind == ND_DEREF && callee->elem_size == 8) {
				icall->is_pointer = 1;
				icall->elem_size = 8;
				icall->type = callee->type;
			}
			node = icall;
			continue;
		}

		return node;
	}
}

static int 
sizeof_identifier(const char *name)
{
	for (int i = 0; i < local_count; i++) {
		if (STRCMP(locals[i].name, name) == 0) {
			if (locals[i].type)
				return locals[i].type->size;
			if (locals[i].is_pointer)
				return 8;
			return locals[i].elem_size ? locals[i].elem_size : 4;
		}
	}

	for (int i = 0; i < global_count; i++) {
		if (STRCMP(globals[i].name, name) == 0) {
			if (globals[i].is_array)
				return globals[i].array_len * globals[i].elem_size;
			if (globals[i].elem_size == 8)
				return 8;
			return globals[i].elem_size ? globals[i].elem_size : 4;
		}
	}

	return -1;
}

static int 
sizeof_node(Node *node)
{
	if (!node)
		return 4;

	if (node->type)
		return node->type->size;

	if (node->is_pointer || node->kind == ND_ADDR || node->kind == ND_STRING)
		return 8;

	if (node->kind == ND_DEREF)
		return node->elem_size ? node->elem_size : 4;

	if (node->kind == ND_INDEX)
		return node->elem_size ? node->elem_size : 4;

	return 4;
}

static int 
parse_sizeof_type_or_expr(void)
{
	if (lexer_peek()->kind != TOK_LPAREN) {
		Node *expr = parse_unary();
		return sizeof_node(expr);
	}

	expect(TOK_LPAREN);

	/*
	 * v154: use the real type parser for sizeof(type), instead of the older
	 * hand-written partial recognizer. This covers typedefs, pointers,
	 * structs, unions, enums, and pointer chains uniformly.
	 */
	if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
		Type *type = parse_type_name();

		while (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();

			const Token *len = lexer_peek();
			if (len->kind != TOK_NUM) {
				fatal_cur("Expected numeric array length in sizeof(type[n])\n");
			}

			lexer_next();
			expect(TOK_RBRACKET);

			type = type_array(type, len->value);
		}

		expect(TOK_RPAREN);
		return type->size;
	}

	if (lexer_peek()->kind == TOK_IDENT && lexer_peek_next()->kind == TOK_RPAREN) {
		int size = sizeof_identifier(lexer_peek()->text);
		if (size >= 0) {
			lexer_next();
			expect(TOK_RPAREN);
			return size;
		}
	}

	Node *expr = parse_expr();
	expect(TOK_RPAREN);

	return sizeof_node(expr);
}

static Node *
parse_unary(void)
{
	if (lexer_peek()->kind == TOK_TILDE) {
		lexer_next();
		return new_unary(ND_BITNOT, parse_unary());
	}

	const Token *token = lexer_peek();

	if (token->kind == TOK_PLUSPLUS || token->kind == TOK_MINUSMINUS) {
		lexer_next();
		return make_incdec(parse_unary(), token->kind, 0);
	}

	if (token->kind == TOK_SIZEOF) {
		lexer_next();
		return new_num(parse_sizeof_type_or_expr());
	}

	if (token->kind == TOK_MINUS) {
		lexer_next();
		return new_unary(ND_NEG, parse_unary());
	}

	if (token->kind == TOK_NOT) {
		lexer_next();
		return new_unary(ND_NOT, parse_unary());
	}

	/* Unary plus: +expr is a no-op (integer promotion only) */
	if (token->kind == TOK_PLUS) {
		lexer_next();
		return parse_unary();
	}

	if (token->kind == TOK_STAR) {
		lexer_next();
		Node *deref_inner = parse_unary();
		/* In C, (*fptr)() == fptr(): dereferencing a function pointer is a no-op.
		 * Skip for function addresses and calls returning function pointers,
		 * but NOT for regular data pointer variables (those need actual loads). */
		if (deref_inner && deref_inner->kind == ND_FUNC_ADDR)
			return deref_inner;
		/* Call returning a function pointer: result IS the callable, skip deref */
		if (deref_inner && deref_inner->kind == ND_CALL &&
		    deref_inner->is_pointer && deref_inner->elem_size == 8)
			return deref_inner;
		return new_deref(deref_inner);
	}

	if (token->kind == TOK_AMP) {
		lexer_next();
		Node *operand = parse_unary();
		/* &funcname is the same as funcname for function-pointer contexts */
		if (operand && operand->kind == ND_FUNC_ADDR)
			return operand;
		return new_addr(operand);
	}

	return parse_postfix();
}

static Node *
parse_term(void)
{
	Node *node = parse_unary();

	for (;;) {
		const Token *token = lexer_peek();

		if (token->kind == TOK_STAR) {
			lexer_next();
			node = new_binary(ND_MUL, node, parse_unary());
		} else if (token->kind == TOK_SLASH) {
			lexer_next();
			node = new_binary(ND_DIV, node, parse_unary());
		} else if (token->kind == TOK_PERCENT) {
			lexer_next();
			node = new_binary(ND_MOD, node, parse_unary());
		} else {
			return node;
		}
	}
}

static Node *
make_additive(NodeKind kind, Node *left, Node *right)
{
	int left_ptr = left->is_pointer || (left->type && left->type->kind == TY_PTR);
	int right_ptr = right->is_pointer || (right->type && right->type->kind == TY_PTR);

	if (kind == ND_ADD) {
		if (left_ptr && right_ptr) {
			fatal_cur("Cannot add two pointers\n");
		}

		if (right_ptr && !left_ptr) {
			Node *tmp = left;
			left = right;
			right = tmp;
			left_ptr = 1;
			right_ptr = 0;
		}

		Node *node = new_binary(kind, left, right);
		node->is_pointer = left_ptr;
		/* For pointer arithmetic, scale = size of the pointed-to element,
		 * not the size of the pointer itself (which is what elem_size tracks
		 * for load purposes on pointer-typed nodes). */
		if (left->type && left->type->kind == TY_PTR && left->type->base) {
			Type *base = left->type->base;
			if (base->kind == TY_CHAR)
				node->elem_size = 1;
			else if (base->kind == TY_SHORT)
				node->elem_size = 2;
			else if (base->kind == TY_PTR)
				node->elem_size = 8;
			else if (base->kind == TY_STRUCT)
				node->elem_size = base->size;
			else
				node->elem_size = base->size ? base->size : 4;
			node->type = left->type;
		} else {
			node->elem_size = left->elem_size ? left->elem_size : 4;
			if (left->type && left->type->kind == TY_PTR)
				node->type = left->type;
		}
		return node;
	}

	if (kind == ND_SUB) {
		Node *node = new_binary(kind, left, right);

		if (left_ptr && right_ptr) {
			/* ptr - ptr = (addr_diff) / sizeof(pointee) */
			node->is_pointer = 0;
			node->type = type_int();
			/* Determine element size of the pointee */
			int ptrdiff_scale = 4; /* default: int */
			if (left->type && left->type->kind == TY_PTR && left->type->base) {
				Type *base = left->type->base;
				if (base->kind == TY_CHAR) ptrdiff_scale = 1;
				else if (base->kind == TY_SHORT) ptrdiff_scale = 2;
				else if (base->kind == TY_PTR) ptrdiff_scale = 8;
				else if (base->size > 0) ptrdiff_scale = base->size;
			} else if (left->elem_size > 0) {
				ptrdiff_scale = left->elem_size;
			}
			node->elem_size = ptrdiff_scale;
			if (ptrdiff_scale > 1) {
				/* wrap: (left - right) / scale */
				Node *divisor = new_num(ptrdiff_scale);
				divisor->type = type_int();
				Node *div = new_binary(ND_DIV, node, divisor);
				div->type = type_int();
				div->elem_size = 4;
				return div;
			}
		} else {
			node->is_pointer = left_ptr && !right_ptr;
			node->elem_size = left->elem_size ? left->elem_size : 4;
			if (node->is_pointer && left->type && left->type->kind == TY_PTR)
				node->type = left->type;
		}

		return node;
	}

	return new_binary(kind, left, right);
}

static Node *
parse_additive(void)
{
	Node *node = parse_term();

	for (;;) {
		const Token *token = lexer_peek();

		if (token->kind == TOK_PLUS) {
			lexer_next();
			node = make_additive(ND_ADD, node, parse_term());
		} else if (token->kind == TOK_MINUS) {
			lexer_next();
			node = make_additive(ND_SUB, node, parse_term());
		} else {
			return node;
		}
	}
}

static ExprValue 
parse_struct_member_setup_value(void)
{
	ExprValue ret = parse_struct_return_member_setup_value();
	if (ret.value) {
		return ret;
	}

	Node *setup = NULL;
	Node *value = parse_struct_assign_member_expr_core(&setup);
	if (!value) {
		return expr_value_none();
	}

	return expr_value_make(setup, value);
}

static ExprValue 
parse_struct_assign_member_setup_value(void)
{
	ExprValue first = parse_struct_member_setup_value();
	if (!first.value) {
		return expr_value_none();
	}

	Node *setup = first.setup;
	Node *expr = first.value;

	for (;;) {
		TokenKind op = lexer_peek()->kind;
		NodeKind kind = ND_ADD;
		int use_additive = 0;

		if (op == TOK_STAR) {
			kind = ND_MUL;
		} else if (op == TOK_SLASH) {
			kind = ND_DIV;
		} else if (op == TOK_PLUS) {
			kind = ND_ADD;
			use_additive = 1;
		} else if (op == TOK_MINUS) {
			kind = ND_SUB;
			use_additive = 1;
		} else if (op == TOK_SHL) {
			kind = ND_SHL;
		} else if (op == TOK_SHR) {
			kind = ND_SHR;
		} else if (op == TOK_AMP) {
			kind = ND_BITAND;
		} else if (op == TOK_CARET) {
			kind = ND_BITXOR;
		} else if (op == TOK_PIPE) {
			kind = ND_BITOR;
		} else {
			break;
		}

		lexer_next();

		ExprValue rhs_ev = parse_struct_member_setup_value();
		Node *rhs = rhs_ev.value;
		if (!rhs)
			rhs = parse_unary();

		if (rhs_ev.setup)
			setup = append_node(setup, rhs_ev.setup);

		if (use_additive)
			expr = make_additive(kind, expr, rhs);
		else
			expr = new_binary(kind, expr, rhs);
	}
	return expr_value_make(setup, expr);
}

static Node *
parse_struct_assign_member_sum(Node **setup_out)
{
	ExprValue expr = parse_struct_assign_member_setup_value();

	if (setup_out)
		*setup_out = expr.setup;

	return expr.value;
}

static Node *
make_member_read_from_struct_temp(Node *temp, const char *struct_name)
{
	int offset = temp->offset;
	Field *field = NULL;

	if (lexer_peek()->kind != TOK_DOT) {
		fatal_cur("Expected member access after struct return expression\n");
	}

	while (lexer_peek()->kind == TOK_DOT) {
		lexer_next();

		const Token *field_name = lexer_peek();
		if (field_name->kind != TOK_IDENT) {
			fatal_cur("Expected field name after '.'\n");
		}
		lexer_next();

		field = find_field(struct_name, field_name->text);
		offset += field->offset;

		if (field->is_struct) {
			struct_name = field->struct_name;
			continue;
		}

		if (lexer_peek()->kind == TOK_DOT) {
			fatal_cur("Nested member access through non-struct field\n");
		}

		Node *member = new_member(field->name, offset);
		member->elem_size = field->size;
		member->type = type_for_size(field->size);
		STRNCPY(member->struct_name, struct_name, sizeof(member->struct_name) - 1);
		return member;
	}

	fatal_cur("Struct return member expression must select scalar field\n");
}

static ExprValue 
parse_struct_return_member_setup_value(void)
{
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_RPAREN) {
		return expr_value_none();
	}
	const Token *func = lexer_peek();
	FuncInfo *fi = find_func(func->text);
	if (!fi || !fi->returns_struct) {
		return expr_value_none();
	}

	lexer_next(); /* function name */
	expect(TOK_LPAREN);
	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_DOT) {
		return expr_value_none();
	}

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__struct_ret_member_%d", struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, fi->struct_name);
	StructDef *def = find_struct(fi->struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(fi->struct_name, def->size);

	Node *lhs = new_var(temp_name, offset);
	lhs->type = type_struct(fi->struct_name, def->size);
	lhs->elem_size = def->size;
	STRNCPY(lhs->struct_name, fi->struct_name, sizeof(lhs->struct_name) - 1);

	Node *call = new_call(func->text, NULL);
	call->returns_struct = 1;
	call->struct_return_size = fi->struct_size;
	call->type = type_struct(fi->struct_name, fi->struct_size);
	STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);

	Node *assign = new_assign(lhs, call);

	Node *temp = new_var(temp_name, offset);
	temp->type = type_struct(fi->struct_name, def->size);
	temp->elem_size = def->size;
	STRNCPY(temp->struct_name, fi->struct_name, sizeof(temp->struct_name) - 1);

	Node *member = make_member_read_from_struct_temp(temp, fi->struct_name);
	Node *setup = append_node(decl, assign);
	return expr_value_make(setup, member);
}

static Node *
parse_shift(void)
{
	Node *node = parse_additive();

	for (;;) {
		const Token *token = lexer_peek();

		if (token->kind == TOK_SHL) {
			lexer_next();
			node = new_binary(ND_SHL, node, parse_additive());
		} else if (token->kind == TOK_SHR) {
			lexer_next();
			node = new_binary(ND_SHR, node, parse_additive());
		} else {
			return node;
		}
	}
}

static Node *
parse_relational(void)
{
	Node *node = parse_shift();

	for (;;) {
		const Token *token = lexer_peek();

		if (token->kind == TOK_LT) {
			lexer_next();
			Node *lhs = node;
			Node *rhs = parse_shift();
			node = new_binary(ND_LT, lhs, rhs);
			node->is_unsigned = expr_is_unsigned_for_compare(lhs) || expr_is_unsigned_for_compare(rhs);
			node->value = node->is_unsigned;
		} else if (token->kind == TOK_LE) {
			lexer_next();
			Node *lhs = node;
			Node *rhs = parse_shift();
			node = new_binary(ND_LE, lhs, rhs);
			node->is_unsigned = expr_is_unsigned_for_compare(lhs) || expr_is_unsigned_for_compare(rhs);
			node->value = node->is_unsigned;
		} else if (token->kind == TOK_GT) {
			lexer_next();
			Node *lhs = node;
			Node *rhs = parse_shift();
			node = new_binary(ND_GT, lhs, rhs);
			node->is_unsigned = expr_is_unsigned_for_compare(lhs) || expr_is_unsigned_for_compare(rhs);
			node->value = node->is_unsigned;
		} else if (token->kind == TOK_GE) {
			lexer_next();
			Node *lhs = node;
			Node *rhs = parse_shift();
			node = new_binary(ND_GE, lhs, rhs);
			node->is_unsigned = expr_is_unsigned_for_compare(lhs) || expr_is_unsigned_for_compare(rhs);
			node->value = node->is_unsigned;
		} else {
			return node;
		}
	}
}

static Node *
make_struct_scalar_member(Node *base, Field *field, int offset_base)
{
	if (base->kind != ND_VAR) {
		fatal_cur("Struct comparison currently requires local struct operands\n");
	}

	Node *node = new_member(field->name, base->offset + offset_base + field->offset);
	node->elem_size = field->size;
	node->type = type_for_size(field->size);
	STRNCPY(node->struct_name, base->struct_name, sizeof(node->struct_name) - 1);
	return node;
}

static Node *
append_struct_field_comparisons(Node *expr, Node *left, Node *right, const char *struct_name, int offset_base)
{
	StructDef *def = find_struct(struct_name);

	for (int i = 0; i < def->field_count; i++) {
		Field *field = &def->fields[i];

		if (field->is_struct) {
			expr = append_struct_field_comparisons(expr, left, right, field->struct_name,
			                                       offset_base + field->offset);
			continue;
		}

		Node *lhs = make_struct_scalar_member(left, field, offset_base);
		Node *rhs = make_struct_scalar_member(right, field, offset_base);
		Node *cmp = new_binary(ND_EQ, lhs, rhs);

		if (!expr)
			expr = cmp;
		else
			expr = new_binary(ND_LOGICAL_AND, expr, cmp);
	}

	return expr ? expr : new_num(1);
}

static Node *
build_struct_equality_expr(Node *left, Node *right, int invert)
{
	if (!left || !right ||
	        !left->type || !right->type ||
	        left->type->kind != TY_STRUCT || right->type->kind != TY_STRUCT)
		return NULL;

	if (STRCMP(left->type->struct_name, right->type->struct_name) != 0) {
		fatal_cur("Cannot compare different struct types\n");
	}

	Node *expr = append_struct_field_comparisons(NULL, left, right, left->type->struct_name, 0);
	if (invert)
		expr = new_unary(ND_NOT, expr);

	return expr;
}

static Node *
parse_equality(void)
{
	Node *node = parse_relational();

	for (;;) {
		const Token *token = lexer_peek();

		if (token->kind == TOK_EQ) {
			lexer_next();
			Node *right = parse_relational();
			Node *struct_cmp = build_struct_equality_expr(node, right, 0);
			node = struct_cmp ? struct_cmp : new_binary(ND_EQ, node, right);
		} else if (token->kind == TOK_NE) {
			lexer_next();
			Node *right = parse_relational();
			Node *struct_cmp = build_struct_equality_expr(node, right, 1);
			node = struct_cmp ? struct_cmp : new_binary(ND_NE, node, right);
		} else {
			return node;
		}
	}
}

static Node *
parse_bitand(void)
{
	Node *node = parse_equality();

	while (lexer_peek()->kind == TOK_AMP) {
		lexer_next();
		node = new_binary(ND_BITAND, node, parse_equality());
	}
	return node;
}

static Node *
parse_bitxor(void)
{
	Node *node = parse_bitand();

	while (lexer_peek()->kind == TOK_CARET) {
		lexer_next();
		node = new_binary(ND_BITXOR, node, parse_bitand());
	}
	return node;
}

static Node *
parse_bitor(void)
{
	Node *node = parse_bitxor();

	while (lexer_peek()->kind == TOK_PIPE) {
		lexer_next();
		node = new_binary(ND_BITOR, node, parse_bitxor());
	}
	return node;
}

static Node *
parse_logical_and(void)
{
	Node *node;

	node = parse_bitor();
	while (lexer_peek()->kind == TOK_AND) {
		lexer_next();
		node = new_binary(ND_LOGICAL_AND, node, parse_bitor());
	}

	return node;
}

static Node *
parse_logical_or(void)
{
	Node *node;

	node = parse_logical_and();
	while (lexer_peek()->kind == TOK_OR) {
		lexer_next();
		node = new_binary(ND_LOGICAL_OR, node, parse_logical_and());
	}
	return node;
}

static Node *
parse_conditional(void)
{
	Node *node;

	node = parse_logical_or();
	if (lexer_peek()->kind != TOK_QUESTION) {
		return node;
	}

	lexer_next();

	Node *then_expr = parse_expr();
	expect(TOK_COLON);
	Node *else_expr = parse_conditional();

	Node *tmp= new_conditional(node, then_expr, else_expr);
	return tmp;
}

static int 
is_assignable(Node *node)
{
	return node->kind == ND_VAR ||
	       node->kind == ND_GLOBAL ||
	       node->kind == ND_GLOBAL_INDEX ||
	       node->kind == ND_MEMBER ||
	       node->kind == ND_MEMBER_PTR ||
	       node->kind == ND_INDEX ||
	       node->kind == ND_DEREF;
}

static Node *
clone_node_tree(Node *node)
{
	if (!node)
		return NULL;

	Node *copy = xcalloc(1, sizeof(Node));
	*copy = *node;

	copy->left = clone_node_tree(node->left);
	copy->right = clone_node_tree(node->right);
	copy->init = clone_node_tree(node->init);
	copy->cond = clone_node_tree(node->cond);
	copy->inc = clone_node_tree(node->inc);
	copy->then_body = clone_node_tree(node->then_body);
	copy->else_body = clone_node_tree(node->else_body);
	copy->body = clone_node_tree(node->body);
	copy->args = clone_node_tree(node->args);

	/*
	 * A read copy must own its expression children, but it must not inherit
	 * statement-list links from the original node.
	 */
	copy->next = NULL;

	return copy;
}

static Node *
clone_lvalue_for_read(Node *node)
{
	return clone_node_tree(node);
}

static Node *
make_incdec(Node *node, TokenKind op, int is_postfix)
{
	if (!is_assignable(node)) {
		fatal_cur("Operand of ++/-- must be assignable\n");
	}

	if (op == TOK_PLUSPLUS)
		return new_incdec(is_postfix ? ND_POST_INC : ND_PRE_INC, node);

	return new_incdec(is_postfix ? ND_POST_DEC : ND_PRE_DEC, node);
}

static int 
is_struct_assign_node(Node *node)
{
	return node &&
	       node->kind == ND_STRUCT_ASSIGN &&
	       node->left &&
	       node->right &&
	       node->left->type &&
	       node->left->type->kind == TY_STRUCT;
}

static Node *
make_struct_assign_chain(Node *dst, Node *rhs_assign)
{
	/*
	 * v126.1: chained struct assignment:
	 *
	 *   a = b = c;
	 *
	 * Lower to:
	 *
	 *   b = c;
	 *   a = b;
	 *
	 * The value of the RHS assignment is its destination object after the copy.
	 * Copying from rhs_assign->left preserves the normal struct-copy path and
	 * avoids treating aggregates as scalar values.
	 */
	if (!is_struct_assign_node(rhs_assign))
		return NULL;

	if (!dst || !dst->type || dst->type->kind != TY_STRUCT) {
		fatal_cur("Struct assignment chain requires struct destination\n");
	}

	if (!rhs_assign->left->type ||
	        rhs_assign->left->type->kind != TY_STRUCT ||
	        STRCMP(dst->type->struct_name, rhs_assign->left->type->struct_name) != 0) {
		fatal_cur("Struct assignment chain type mismatch\n");
	}

	Node *src_after_rhs = clone_lvalue_for_read(rhs_assign->left);
	Node *copy_to_dst = new_struct_assign(dst, src_after_rhs, dst->type->size);

	return new_block(append_node(rhs_assign, copy_to_dst));
}

static Node *
parse_assignment(void)
{
	Node *node;

	node = parse_conditional();

	TokenKind op = lexer_peek()->kind;

	if (op == TOK_ASSIGN ||
	        op == TOK_PLUSEQ ||
	        op == TOK_MINUSEQ ||
	        op == TOK_MULEQ ||
	        op == TOK_DIVEQ ||
	        op == TOK_MODEQ ||
	        op == TOK_ANDEQ ||
	        op == TOK_OREQ  ||
	        op == TOK_XOREQ ||
	        op == TOK_SHLEQ ||
	        op == TOK_SHREQ) {
		lexer_next();

		if (!is_assignable(node)) {
			fatal_cur("Left side of assignment must be assignable\n");
		}

		Node *rhs;
		if (op == TOK_ASSIGN &&
		        node->is_pointer &&
		        lexer_peek()->kind == TOK_IDENT &&
		        find_func(lexer_peek()->text) &&
		        lexer_peek_next()->kind != TOK_LPAREN) {
			const Token *fn = lexer_peek();
			lexer_next();
			rhs = new_func_addr(fn->text);
		} else {
			rhs = parse_assignment();
		}

		if (op == TOK_ASSIGN) {
			if (is_struct_assign_node(rhs) &&
			        node->type && node->type->kind == TY_STRUCT) {
				node = make_struct_assign_chain(node, rhs);
			} else if (node->kind == ND_VAR && rhs->kind == ND_VAR &&
			           node->type && rhs->type &&
			           node->type->kind == TY_STRUCT && rhs->type->kind == TY_STRUCT) {
				if (STRCMP(node->type->struct_name, rhs->type->struct_name) != 0) {
					fatal_cur("Struct assignment type mismatch\n");
				}

				node = new_struct_assign(node, rhs, node->type->size);
			} else {
				if (node->is_pointer && rhs->kind == ND_VAR && find_func(rhs->name))
					rhs = new_func_addr(rhs->name);
				node = new_assign(node, rhs);
			}
		} else {
			/*
			 * v66 allows compound assignment for all assignment-capable
			 * lvalues. The existing assignment emitter has explicit store
			 * paths for locals, globals, indexed locals, dereferences, and
			 * pointer members. The RHS uses a separate read copy of the lvalue.
			 */
			NodeKind binop = ND_ADD;
			Node *read_lhs = clone_lvalue_for_read(node);

			if (op == TOK_MINUSEQ)
				binop = ND_SUB;
			else if (op == TOK_MULEQ)
				binop = ND_MUL;
			else if (op == TOK_DIVEQ)
				binop = ND_DIV;
			else if (op == TOK_MODEQ)
				binop = ND_MOD;
			else if (op == TOK_ANDEQ)
				binop = ND_BITAND;
			else if (op == TOK_OREQ)
				binop = ND_BITOR;
			else if (op == TOK_XOREQ)
				binop = ND_BITXOR;
			else if (op == TOK_SHLEQ)
				binop = ND_SHL;
			else if (op == TOK_SHREQ)
				binop = ND_SHR;

			Node *expr;
			if (binop == ND_ADD || binop == ND_SUB)
				expr = make_additive(binop, read_lhs, rhs);
			else
				expr = new_binary(binop, read_lhs, rhs);

			node = new_assign(node, expr);
		}
	}
	return node;
}

static Node *
parse_expr(void)
{
	Node *tmp=parse_assignment();
	return tmp;
}

static Node *
parse_block_contents(void)
{

	Node head = {0};
	Node *cur = &head;
	int saved_local_count = local_count;

	while (lexer_peek()->kind != TOK_RBRACE &&
	       lexer_peek()->kind != TOK_EOF) {
		Node *stmt = parse_statement();
		if (!stmt) break;
		cur->next = stmt;
		cur = stmt;
	}

	/* Restore scope: keep statics declared in this block visible to outer
	 * scope (they map to globals), but remove non-static locals. */
	int new_count = saved_local_count;
	for (int i = saved_local_count; i < local_count; i++) {
		if (locals[i].is_static) {
			locals[new_count++] = locals[i];
		}
	}
	local_count = new_count;

	Node *tmp=new_block(head.next);
	return tmp;
}

static Node *
make_local_array_store(const char *name, int offset, int elem_size, int index, int value)
{
	Node *idx = new_num(index);
	Node *lhs = new_index(name, offset, idx);
	lhs->elem_size = elem_size;
	lhs->type = type_for_size(elem_size);
	return new_assign(lhs, new_num(value));
}

static Node *
build_local_zero_fill_block(const char *name, int offset, int bytes, Node *decl)
{
	Node head = {0};
	Node *cur = &head;

	if (decl)
		append_stmt(&cur, decl);

	for (int i = 0; i < bytes; i++)
		append_stmt(&cur, make_local_array_store(name, offset, 1, i, 0));

	return new_block(head.next);
}

static Node *
append_stmt(Node **cur, Node *stmt)
{
	(*cur)->next = stmt;
	*cur = stmt;
	return stmt;
}

static Type *
parse_enum_specifier(void)
{

	expect(TOK_ENUM);

	if (lexer_peek()->kind == TOK_IDENT)
		lexer_next();

	if (lexer_peek()->kind == TOK_LBRACE) {
		lexer_next();

		int value = 0;
		while (lexer_peek()->kind != TOK_RBRACE) {
			const Token *name = lexer_peek();
			if (name->kind != TOK_IDENT) {
				fatal_cur("Expected enum constant name\n");
			}
			char enum_const_name[64] = {0};
			STRNCPY(enum_const_name, name->text ? name->text : "", sizeof(enum_const_name) - 1);

			lexer_next();

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				/* Skip optional cast: (int)expr */
				if (lexer_peek()->kind == TOK_LPAREN &&
				    is_type_start_token(lexer_peek_next()->kind, lexer_peek_next()->text)) {
					lexer_next(); /* ( */
					parse_type_name(); /* consume type */
					expect(TOK_RPAREN);
				}
				/* Optional unary minus */
				int negate = 0;
				if (lexer_peek()->kind == TOK_MINUS) { lexer_next(); negate = 1; }
				const Token *explicit_value = lexer_peek();
				if (explicit_value->kind == TOK_NUM) {
					value = negate ? -explicit_value->value : explicit_value->value;
					lexer_next();
				} else if (explicit_value->kind == TOK_IDENT) {
					/* Other enum constant */
					int ev = 0;
					if (find_enum_const(explicit_value->text, &ev))
						value = negate ? -ev : ev;
					lexer_next();
				} else if (explicit_value->kind == TOK_LPAREN) {
					/* Parenthesized expression -- consume it, use current value */
					int pd = 1; lexer_next();
					while (pd > 0 && lexer_peek()->kind != TOK_EOF) {
						if (lexer_peek()->kind == TOK_LPAREN) pd++;
						else if (lexer_peek()->kind == TOK_RPAREN) pd--;
						lexer_next();
					}
				} else {
					fatal_cur("Enum value must be a constant integer\n");
				}
				/* Handle simple arithmetic after enum value: +1, -1, <<3 etc. */
				while (lexer_peek()->kind == TOK_PLUS || lexer_peek()->kind == TOK_MINUS ||
				       lexer_peek()->kind == TOK_STAR || lexer_peek()->kind == TOK_SLASH ||
				       lexer_peek()->kind == TOK_AND || lexer_peek()->kind == TOK_OR ||
				       lexer_peek()->kind == TOK_SHL || lexer_peek()->kind == TOK_SHR) {
					TokenKind op2 = lexer_peek()->kind; lexer_next();
					int rhs2 = 1;
					if (lexer_peek()->kind == TOK_NUM) { rhs2 = lexer_peek()->value; lexer_next(); }
					else if (lexer_peek()->kind == TOK_IDENT) {
						int ev2 = 0;
						if (find_enum_const(lexer_peek()->text, &ev2)) rhs2 = ev2;
						lexer_next();
					}
					if (op2 == TOK_PLUS) value += rhs2;
					else if (op2 == TOK_MINUS) value -= rhs2;
					else if (op2 == TOK_STAR) value *= rhs2;
					else if (op2 == TOK_SLASH && rhs2) value /= rhs2;
					else if (op2 == TOK_AND) value &= rhs2;
					else if (op2 == TOK_OR) value |= rhs2;
					else if (op2 == TOK_SHL) value <<= rhs2;
					else if (op2 == TOK_SHR) value >>= rhs2;
				}
			}

			add_enum_const(enum_const_name, value);
			value++;

			if (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				if (lexer_peek()->kind == TOK_RBRACE)
					break;
			} else {
				break;
			}
		}

		expect(TOK_RBRACE);
	}

	return type_int();
}

static Type *
parse_type_name(void)
{

	skip_inline_qualifiers();

	int saw_short_type_modifier = 0;
	int saw_unsigned_type_modifier = 0;
	int saw_int_modifier = 0;
	while (lexer_peek()->kind == TOK_SIGNED ||
	        lexer_peek()->kind == TOK_UNSIGNED ||
	        lexer_peek()->kind == TOK_SHORT ||
	        lexer_peek()->kind == TOK_LONG) {
		if (lexer_peek()->kind == TOK_SHORT)
			saw_short_type_modifier = 1;
		if (lexer_peek()->kind == TOK_UNSIGNED)
			saw_unsigned_type_modifier = 1;
		saw_int_modifier = 1;
		lexer_next();
	}

	const Token *token = lexer_peek();

	Type *type = NULL;


	if (token->kind == TOK_VOID) {
		lexer_next();
		/*
		 * Minimal void support.  For now, void is represented as int-sized
		 * storage; void* still becomes a normal pointer below.
		 */
		type = type_int();
	} else if (token->kind == TOK_INT) {
		lexer_next();
		type = type_for_size_unsigned(saw_short_type_modifier ? 2 : 4, saw_unsigned_type_modifier);
	} else if (token->kind == TOK_BOOL) {
		lexer_next();
		type = type_uchar();
	} else if (token->kind == TOK_CHAR) {
		lexer_next();
		type = saw_unsigned_type_modifier ? type_uchar() : type_char();
	} else if (token->kind == TOK_STRUCT || token->kind == TOK_UNION) {
		int type_is_union = (token->kind == TOK_UNION);
		lexer_next();

		const Token *name = lexer_peek();
		char struct_type_name[64] = {0};
		if (name->kind == TOK_LBRACE) {
			/* Anonymous struct/union as a field type */
			snprintf(struct_type_name, sizeof(struct_type_name),
			         "__anon_%s_%d", type_is_union ? "union" : "struct",
			         ++anon_struct_id);
			if (struct_count < 128) {
				StructDef *adef = &structs[struct_count++];
				memset(adef, 0, sizeof(*adef));
				STRNCPY(adef->name, struct_type_name, sizeof(adef->name) - 1);
				adef->is_union = type_is_union;
				parse_struct_body_into(adef);
			}
		} else if (name->kind == TOK_IDENT) {
			STRNCPY(struct_type_name, name->text ? name->text : "", sizeof(struct_type_name) - 1);
			lexer_next();
			/* Inline definition: "struct S { ... }" as a type */
			if (lexer_peek()->kind == TOK_LBRACE) {
				StructDef *idef = find_struct_or_null(struct_type_name);
				if (!idef) {
					if (struct_count < 128) {
						idef = &structs[struct_count++];
						memset(idef, 0, sizeof(*idef));
						STRNCPY(idef->name, struct_type_name, sizeof(idef->name) - 1);
					}
				} else {
					memset(idef, 0, sizeof(*idef));
					STRNCPY(idef->name, struct_type_name, sizeof(idef->name) - 1);
				}
				if (idef) {
					idef->is_union = type_is_union;
					parse_struct_body_into(idef);
				}
			}
		} else {
			fatal_cur("Expected struct name in type\n");
		}

		StructDef *def = find_struct_or_null(struct_type_name);
		if (!def)
			def = get_or_add_forward_struct(struct_type_name);
		type = type_struct(struct_type_name, def->size);

	} else if (token->kind == TOK_FLOAT) {
		/* float treated as 4-byte opaque value */
		lexer_next();
		type = type_int();
		type->size = 4;
	} else if (token->kind == TOK_DOUBLE) {
		/* double treated as 8-byte opaque value; skip optional "long double" */
		lexer_next();
		type = type_ptr(type_int()); /* reuse TY_PTR as 8-byte slot */
		type->size = 8;
	} else if (token->kind == TOK_ENUM) {
		type = parse_enum_specifier();
	} else if (saw_int_modifier) {
		/*
		 * If we already consumed integer declaration specifiers such as
		 * "unsigned" or "long", the following identifier is the declarator
		 * name, even if that spelling is already known as a typedef.
		 *
		 * This permits valid redeclarations like:
		 *
		 *     typedef unsigned long size_t;
		 *
		 * after a system header has already typedef'd size_t. The old ordering
		 * treated the second size_t as another type-name, consumed it here, and
		 * then parse_typedef_declaration() failed at the semicolon with
		 * "Expected typedef name".
		 */
		type = type_for_size_unsigned(saw_short_type_modifier ? 2 : 4, saw_unsigned_type_modifier);
	} else if (token->kind == TOK_IDENT && is_typedef_name(token->text)) {
		char typedef_name[64] = {0};
		STRNCPY(typedef_name, token->text ? token->text : "", sizeof(typedef_name) - 1);
		lexer_next();
		type = clone_type(find_typedef(typedef_name));
	} else {
		fatal_cur("Expected type name\n");
		exit(1);
	}

	skip_inline_qualifiers();

	while (lexer_peek()->kind == TOK_STAR) {
		lexer_next();
		skip_pointer_qualifiers();
		skip_inline_qualifiers();
		type = type_ptr(type);
	}

	skip_inline_qualifiers();
	skip_pointer_qualifiers();

	return type;
}

static int 
is_type_start_token(TokenKind kind, const char *text)
{
	return kind == TOK_INT ||
	       kind == TOK_CHAR ||
	       kind == TOK_VOID ||
	       kind == TOK_BOOL ||
	       kind == TOK_SHORT ||
	       kind == TOK_LONG ||
	       kind == TOK_SIGNED ||
	       kind == TOK_UNSIGNED ||
	       kind == TOK_FLOAT ||
	       kind == TOK_DOUBLE ||
	       kind == TOK_STRUCT ||
	       kind == TOK_UNION ||
	       kind == TOK_ENUM ||
	       kind == TOK_STATIC ||
	       kind == TOK_EXTERN ||
	       kind == TOK_CONST ||
	       kind == TOK_INLINE ||
	       (kind == TOK_IDENT && text && STRCMP(text, "__attribute__") == 0) ||
	       (kind == TOK_IDENT && is_typedef_name(text));
}

static int 
parse_typedef_declaration(void)
{

	if (lexer_peek()->kind != TOK_TYPEDEF) {
		return 0;
	}

	lexer_next();

	if (lexer_peek()->kind == TOK_STRUCT || lexer_peek()->kind == TOK_UNION) {
		lexer_next(); /* consume struct/union keyword */

		/* Skip __attribute__((packed)) etc. */
		skip_inline_qualifiers();

		char struct_name[64] = {0};
		int has_tag = 0;

		if (lexer_peek()->kind == TOK_IDENT && !is_typedef_name(lexer_peek()->text)) {
			const Token *tag = lexer_peek();
			STRNCPY(struct_name, tag->text, sizeof(struct_name) - 1);
			has_tag = 1;
			lexer_next();
		}

		if (lexer_peek()->kind == TOK_LBRACE) {
			{
				StructDef *def;
				if (has_tag) {
					def = get_or_add_forward_struct(struct_name);
				} else {
					if (struct_count >= 128) {
						fatal_cur("Too many structs\n");
					}
					def = &structs[struct_count++];
					memset(def, 0, sizeof(*def));
				}

				parse_struct_body_into(def);

				/* Accept attributes between a struct/union body and its typedef name:
				 *   typedef union U { ... } __attribute__((packed)) U;
				 */
				skip_inline_qualifiers();

				const Token *alias = lexer_peek();
				if (alias->kind != TOK_IDENT) {
					fatal_cur("Expected typedef name after struct body\n");
				}

				if (!has_tag) {
					STRNCPY(def->name, alias->text, sizeof(def->name) - 1);
					STRNCPY(struct_name, alias->text, sizeof(struct_name) - 1);
				}

				lexer_next();
				expect(TOK_SEMI);
				add_typedef_name(alias->text, type_struct(struct_name, def->size));
				return 1;
			}
		}

		/* Handle pointer/function-pointer typedef: "typedef struct S * alias;" or
		 * "typedef struct S * (*fty)();" */
		int ptr_depth = 0;
		while (lexer_peek()->kind == TOK_STAR) { lexer_next(); ptr_depth++; }

		/* Function pointer typedef: "typedef struct S * (*fty)(...);" */
		if (lexer_peek()->kind == TOK_LPAREN && lexer_peek_next()->kind == TOK_STAR) {
			lexer_next(); /* ( */
			lexer_next(); /* * */
			const Token *fp_alias = lexer_peek();
			if (fp_alias->kind != TOK_IDENT)
				fatal_cur("Expected typedef function pointer name\n");
			char fp_name[64] = {0};
			STRNCPY(fp_name, fp_alias->text, sizeof(fp_name) - 1);
			lexer_next(); /* name */
			expect(TOK_RPAREN);
			expect(TOK_LPAREN);
			/* skip parameter list */
			if (lexer_peek()->kind == TOK_VOID) lexer_next();
			else while (lexer_peek()->kind != TOK_RPAREN && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_DOT &&
				        lexer_peek_next()->kind == TOK_DOT &&
				        lexer_peek_after_next()->kind == TOK_DOT) {
					lexer_next();
					lexer_next();
					lexer_next();
					break;
				}
				if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
					Type *pt = parse_type_name(); (void)pt;
					if (lexer_peek()->kind == TOK_IDENT) lexer_next();
				}
				if (lexer_peek()->kind == TOK_COMMA) lexer_next(); else break;
			}
			expect(TOK_RPAREN);
			expect(TOK_SEMI);
			/* Register as pointer type (function pointers are 8-byte pointers) */
			StructDef *def = get_or_add_forward_struct(struct_name);
			Type *base = type_struct(struct_name, def->size);
			for (int pi = 0; pi <= ptr_depth; pi++) base = type_ptr(base);
			add_typedef_name(fp_name, base);
			return 1;
		}

		const Token *alias = lexer_peek();
		if (alias->kind != TOK_IDENT) {
			fatal_cur("Expected typedef name after struct tag\n");
		}
		char alias_name[64] = {0};
		STRNCPY(alias_name, alias->text ? alias->text : "", sizeof(alias_name) - 1);

		lexer_next();
		expect(TOK_SEMI);

		StructDef *def = get_or_add_forward_struct(struct_name);
		Type *base_type = type_struct(struct_name, def->size);
		for (int pi = 0; pi < ptr_depth; pi++) base_type = type_ptr(base_type);
		add_typedef_name(alias_name, base_type);
		return 1;
	}

	Type *type = parse_type_name();

	/* Function pointer typedef: "typedef int (*fptr)(int);" */
	if (lexer_peek()->kind == TOK_LPAREN && lexer_peek_next()->kind == TOK_STAR) {
		lexer_next(); /* ( */
		lexer_next(); /* * */
		const Token *fp_alias = lexer_peek();
		if (fp_alias->kind != TOK_IDENT) {
			fatal_cur("Expected typedef function pointer name\n");
		}
		char fp_tname[64] = {0};
		STRNCPY(fp_tname, fp_alias->text, sizeof(fp_tname) - 1);
		lexer_next(); /* name */

		/*
		 * C declarator suffixes bind to the identifier even when the
		 * identifier is inside the parenthesized pointer declarator:
		 *
		 *     typedef int (*fptr[4])(int);
		 *
		 * This is an array of function pointers, not a function pointer
		 * named fptr followed by a stray '[' token.
		 */
		int fp_dims[MAX_ARRAY_DIMS] = {0};
		int fp_dim_count = 0;
		if (lexer_peek()->kind == TOK_LBRACKET)
			fp_dim_count = parse_array_dimensions(fp_dims, 0);

		expect(TOK_RPAREN);
		/* consume parameter list */
		if (lexer_peek()->kind == TOK_LPAREN) {
			int fpd = 1; lexer_next();
			while (fpd > 0 && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_LPAREN) fpd++;
				else if (lexer_peek()->kind == TOK_RPAREN) fpd--;
				lexer_next();
			}
		}
		expect(TOK_SEMI);
		/* Register as a pointer type (8-byte function pointer), or an
		 * array of such pointers for declarations like (*fptr[4])(...).
		 */
		Type *fp_type = type_ptr(type);
		if (fp_dim_count > 0)
			fp_type = build_array_type_from_dims(fp_type, fp_dims, fp_dim_count);
		add_typedef_name(fp_tname, fp_type);
		return 1;
	}

	const Token *name = lexer_peek();
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected typedef name\n");
	}
	char tdef_name[64] = {0};
	STRNCPY(tdef_name, name->text ? name->text : "", sizeof(tdef_name) - 1);

	lexer_next();
	expect(TOK_SEMI);

	add_typedef_name(tdef_name, type);
	return 1;
}

static Node *
parse_return_call_with_compound_literal_arg(void)
{

	/*
	 * v120 focused temporary materialization:
	 *
	 *   return sum((struct Point){ 1, 41 });
	 *
	 * Lower to:
	 *
	 *   struct Point __compound_arg_N = { 1, 41 };
	 *   return sum(__compound_arg_N);
	 *
	 * The existing argument lowering then passes the temp by address for struct
	 * parameters.
	 */
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_LPAREN ||
	        lexer_peek_third()->kind != TOK_STRUCT) {
		return NULL;
	}

	const Token *func = lexer_peek();
	lexer_next(); /* function name */
	lexer_next(); /* call '(' */
	lexer_next(); /* compound literal '(' */
	lexer_next(); /* struct */

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in compound literal argument\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_LBRACE) {
		fatal_cur("Expected initializer list in compound literal argument\n");
	}
	lexer_next();

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__compound_arg_%d", compound_arg_temp_id++);

	int offset = add_struct_local(temp_name, struct_name->text);
	StructDef *def = find_struct(struct_name->text);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(struct_name->text, def->size);

	Node *head = parse_struct_initializer_values(def, struct_name->text, offset, decl);

	expect(TOK_RBRACE);
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	Node *temp = new_var(temp_name, offset);
	temp->type = type_struct(struct_name->text, def->size);
	temp->elem_size = def->size;
	STRNCPY(temp->struct_name, struct_name->text, sizeof(temp->struct_name) - 1);

	Node *arg = new_addr(temp);
	arg->by_ref_arg = 1;

	Node *call = new_call(func->text, arg);
	FuncInfo *fi = find_func(func->text);
	if (fi && fi->returns_pointer) {
		call->is_pointer = 1;
		call->elem_size = fi->return_elem_size;
		call->type = type_ptr(type_for_size(fi->return_elem_size));
	}

	head = append_node(head, new_return(call));
	Node *tmp=new_block(head);
	return tmp;
}

static Node *
make_struct_temp_from_compound_literal(const char *struct_name, const char *prefix, Node **out_temp_var)
{
	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "%s%d", prefix, struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, struct_name);
	StructDef *def = find_struct(struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(struct_name, def->size);

	Node *head = parse_struct_initializer_values(def, struct_name, offset, decl);

	Node *temp = new_var(temp_name, offset);
	temp->type = type_struct(struct_name, def->size);
	temp->elem_size = def->size;
	STRNCPY(temp->struct_name, struct_name, sizeof(temp->struct_name) - 1);

	if (out_temp_var)
		*out_temp_var = temp;

	return head;
}

static Node *
parse_call_statement_with_compound_literal_arg(void)
{
	/*
	 * v122:
	 *
	 *   sink((struct Point){ 1, 41 });
	 *
	 * Lower to a hidden local temporary and then call sink(temp).
	 */
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_LPAREN ||
	        lexer_peek_third()->kind != TOK_STRUCT)
		return NULL;

	const Token *func = lexer_peek();
	lexer_next(); /* function name */
	lexer_next(); /* call '(' */
	lexer_next(); /* compound literal '(' */
	lexer_next(); /* struct */

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in compound literal argument\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_LBRACE) {
		fatal_cur("Expected initializer list in compound literal argument\n");
	}
	lexer_next();

	Node *temp = NULL;
	Node *head = make_struct_temp_from_compound_literal(struct_name->text, "__compound_stmt_arg_", &temp);

	expect(TOK_RBRACE);
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	Node *arg = new_addr(temp);
	arg->by_ref_arg = 1;

	Node *call = new_call(func->text, arg);
	head = append_node(head, call);
	return new_block(head);
}

static Node *
parse_return_call_with_struct_return_arg(void)
{

	/*
	 * v123:
	 *
	 *   return sum(make_point());
	 *
	 * Lower to:
	 *
	 *   struct Point __tmp;
	 *   __tmp = make_point();
	 *   return sum(__tmp);
	 */
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_IDENT ||
	        lexer_peek_third()->kind != TOK_LPAREN) {
		return NULL;
	}

	const Token *outer = lexer_peek();
	const Token *inner = lexer_peek_after_next();

	FuncInfo *inner_info = find_func(inner->text);
	if (!inner_info || !inner_info->returns_struct) {
		return NULL;
	}

	lexer_next(); /* outer */
	lexer_next(); /* outer '(' */
	lexer_next(); /* inner */
	lexer_next(); /* inner '(' */
	expect(TOK_RPAREN);
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__struct_call_arg_%d", struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, inner_info->struct_name);
	StructDef *def = find_struct(inner_info->struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(inner_info->struct_name, def->size);

	Node *temp_lhs = new_var(temp_name, offset);
	temp_lhs->type = type_struct(inner_info->struct_name, def->size);
	temp_lhs->elem_size = def->size;
	STRNCPY(temp_lhs->struct_name, inner_info->struct_name, sizeof(temp_lhs->struct_name) - 1);

	Node *inner_call = new_call(inner->text, NULL);
	inner_call->returns_struct = 1;
	inner_call->struct_return_size = inner_info->struct_size;
	inner_call->type = type_struct(inner_info->struct_name, inner_info->struct_size);
	STRNCPY(inner_call->return_struct_name, inner_info->struct_name, sizeof(inner_call->return_struct_name) - 1);

	Node *assign = new_assign(temp_lhs, inner_call);

	Node *temp_arg = new_var(temp_name, offset);
	temp_arg->type = type_struct(inner_info->struct_name, def->size);
	temp_arg->elem_size = def->size;
	STRNCPY(temp_arg->struct_name, inner_info->struct_name, sizeof(temp_arg->struct_name) - 1);

	Node *arg = new_addr(temp_arg);
	arg->by_ref_arg = 1;

	Node *outer_call = new_call(outer->text, arg);

	Node *head = decl;
	head = append_node(head, assign);
	head = append_node(head, new_return(outer_call));
	Node *tmp= new_block(head);
	return tmp;
}

static Node *
append_arg_node(Node *head, Node **tail, Node *arg)
{
	if (!head) {
		head = arg;
		*tail = arg;
	} else {
		(*tail)->next = arg;
		*tail = arg;
	}

	return head;
}

static Node *
materialize_struct_return_call_arg(const Token *inner, Node **out_arg)
{
	FuncInfo *inner_info = find_func(inner->text);
	if (!inner_info || !inner_info->returns_struct)
		return NULL;

	lexer_next(); /* inner function name */
	expect(TOK_LPAREN);
	expect(TOK_RPAREN);

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__v124_call_arg_%d", struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, inner_info->struct_name);
	StructDef *def = find_struct(inner_info->struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(inner_info->struct_name, def->size);

	Node *lhs = new_var(temp_name, offset);
	lhs->type = type_struct(inner_info->struct_name, def->size);
	lhs->elem_size = def->size;
	STRNCPY(lhs->struct_name, inner_info->struct_name, sizeof(lhs->struct_name) - 1);

	Node *inner_call = new_call(inner->text, NULL);
	inner_call->returns_struct = 1;
	inner_call->struct_return_size = inner_info->struct_size;
	inner_call->type = type_struct(inner_info->struct_name, inner_info->struct_size);
	STRNCPY(inner_call->return_struct_name, inner_info->struct_name, sizeof(inner_call->return_struct_name) - 1);

	Node *assign = new_assign(lhs, inner_call);

	Node *temp = new_var(temp_name, offset);
	temp->type = type_struct(inner_info->struct_name, def->size);
	temp->elem_size = def->size;
	STRNCPY(temp->struct_name, inner_info->struct_name, sizeof(temp->struct_name) - 1);

	Node *arg = new_addr(temp);
	arg->by_ref_arg = 1;
	*out_arg = arg;

	return append_node(decl, assign);
}

static Node *
materialize_compound_literal_call_arg(Node **out_arg)
{
	if (lexer_peek()->kind != TOK_LPAREN || lexer_peek_next()->kind != TOK_STRUCT)
		return NULL;

	lexer_next(); /* ( */
	lexer_next(); /* struct */

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in compound literal argument\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (lexer_peek()->kind != TOK_LBRACE) {
		fatal_cur("Expected initializer list in compound literal argument\n");
	}
	lexer_next();

	Node *temp = NULL;
	Node *head = make_struct_temp_from_compound_literal(struct_name->text, "__v124_compound_arg_", &temp);

	expect(TOK_RBRACE);

	Node *arg = new_addr(temp);
	arg->by_ref_arg = 1;
	*out_arg = arg;
	return head;
}

static Node *
parse_v124_call_after_name(const Token *func, int as_return)
{

	expect(TOK_LPAREN);

	Node *prefix = NULL;
	Node *args = NULL;
	Node *arg_tail = NULL;

	if (lexer_peek()->kind != TOK_RPAREN) {
		for (;;) {
			Node *arg = NULL;
			Node *setup = NULL;

			if (lexer_peek()->kind == TOK_LPAREN && lexer_peek_next()->kind == TOK_STRUCT) {
				setup = materialize_compound_literal_call_arg(&arg);
			} else if (lexer_peek()->kind == TOK_IDENT &&
			           lexer_peek_next()->kind == TOK_LPAREN &&
			           lexer_peek_after_next()->kind == TOK_RPAREN) {
				const Token *inner = lexer_peek();
				setup = materialize_struct_return_call_arg(inner, &arg);
				if (!setup)
					arg = parse_expr();
			} else {
				arg = parse_expr();
			}

			if (setup)
				prefix = append_node(prefix, setup);

			if (arg && arg->type && arg->type->kind == TY_STRUCT) {
				arg = new_addr(arg);
				arg->by_ref_arg = 1;
			}

			args = append_arg_node(args, &arg_tail, arg);

			if (lexer_peek()->kind != TOK_COMMA)
				break;

			lexer_next();
		}
	}

	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	Node *call = new_call(func->text, args);
	FuncInfo *fi = find_func(func->text);
	if (fi) {
		if (fi->returns_struct) {
			call->returns_struct = 1;
			call->struct_return_size = fi->struct_size;
			call->type = type_struct(fi->struct_name, fi->struct_size);
			STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);
		} else if (fi->returns_pointer) {
			call->is_pointer = 1;
			call->elem_size = fi->return_elem_size;
			call->type = type_ptr(type_for_size(fi->return_elem_size));
		}
	}

	if (as_return && call->returns_struct) {
		/* Spill struct-returning call to temp before returning */
		char temp_name[64];
		snprintf(temp_name, sizeof(temp_name), "__struct_ret_v124_%d", struct_arg_temp_id++);
		FuncInfo *rfi = find_func(func->text);
		const char *sname = (rfi && rfi->struct_name[0]) ? rfi->struct_name : call->return_struct_name;
		StructDef *def = find_struct(sname);
		int sz = def ? def->size : 8;
		int temp_off = add_struct_local(temp_name, sname);

		Node *lhs = new_var(temp_name, temp_off);
		lhs->type = type_struct(sname, sz);
		lhs->elem_size = sz;
		STRNCPY(lhs->struct_name, sname, sizeof(lhs->struct_name) - 1);

		Node *assign = new_assign(lhs, call);

		Node *temp_ref = new_var(temp_name, temp_off);
		temp_ref->type = type_struct(sname, sz);
		temp_ref->elem_size = sz;
		STRNCPY(temp_ref->struct_name, sname, sizeof(temp_ref->struct_name) - 1);

		Node *ret_expr = new_binary(ND_COMMA, assign, temp_ref);
		ret_expr->type = temp_ref->type;
		call = new_return(ret_expr);
	} else if (as_return) {
		call = new_return(call);
	}

	if (prefix) {
		Node *tmp= new_block(append_node(prefix, call));
		return tmp;
	}

	Node *tmp= as_return ? call : call;
	return tmp;
}

static Node *
parse_v124_return_call_with_temps(void)
{

	if (!v124_call_starts_with_struct_temp_arg()) {
		return NULL;
	}

	const Token *func = lexer_peek();
	lexer_next();
	Node *tmp=parse_v124_call_after_name(func, 1);
	return tmp;
}

static Node *
parse_v124_call_statement_with_temps(void)
{

	if (!v124_call_starts_with_struct_temp_arg()) {
		return NULL;
	}
	const Token *func = lexer_peek();
	lexer_next();
	Node *tmp= parse_v124_call_after_name(func, 0);
	return tmp;
}

static Node *
make_struct_member_read_from_local(const char *var_name)
{
	const char *struct_name = struct_name_local(var_name);
	int offset = find_local(var_name);
	Field *field = NULL;

	if (lexer_peek()->kind != TOK_DOT) {
		fatal_cur("Expected member access after struct assignment expression\n");
	}

	while (lexer_peek()->kind == TOK_DOT) {
		lexer_next();

		const Token *field_name = lexer_peek();
		if (field_name->kind != TOK_IDENT) {
			fatal_cur("Expected field name after '.'\n");
		}
		lexer_next();

		field = find_field(struct_name, field_name->text);
		offset += field->offset;

		if (field->is_struct) {
			struct_name = field->struct_name;
			continue;
		}

		if (lexer_peek()->kind == TOK_DOT) {
			fatal_cur("Nested member access through non-struct field\n");
		}

		Node *member = new_member(field->name, offset);
		member->elem_size = field->size;
		member->type = type_for_size(field->size);
		STRNCPY(member->struct_name, struct_name, sizeof(member->struct_name) - 1);
		return member;
	}

	fatal_cur("Struct assignment member expression must select scalar field\n");
}

static Node *
parse_return_struct_assign_member_expr(void)
{

	if (lexer_peek()->kind != TOK_LPAREN ||
	        lexer_peek_next()->kind != TOK_IDENT ||
	        lexer_peek_after_next()->kind != TOK_ASSIGN ||
	        lexer_peek_third()->kind != TOK_IDENT) {
		return NULL;
	}

	lexer_next(); /* ( */

	const Token *dst_tok = lexer_peek();
	lexer_next();

	expect(TOK_ASSIGN);

	const Token *src_tok = lexer_peek();
	if (src_tok->kind != TOK_IDENT) {
		fatal_cur("Expected RHS struct identifier in assignment expression\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (!is_struct_local(dst_tok->text) || !is_struct_local(src_tok->text)) {
		return NULL;
	}

	const char *dst_struct = struct_name_local(dst_tok->text);
	const char *src_struct = struct_name_local(src_tok->text);
	if (STRCMP(dst_struct, src_struct) != 0) {
		fatal_cur("Struct assignment expression type mismatch\n");
	}

	StructDef *def = find_struct(dst_struct);

	Node *dst = make_scalar_var_node(dst_tok->text);
	Node *src = make_scalar_var_node(src_tok->text);
	Node *assign = new_struct_assign(dst, src, def->size);

	Node *member = make_struct_member_read_from_local(dst_tok->text);
	expect(TOK_SEMI);

	Node *tmp= new_block(append_node(assign, new_return(member)));
	return tmp;
}

static Node *
parse_struct_assign_member_expr_core(Node **setup_out)
{

	if (lexer_peek()->kind != TOK_LPAREN ||
	        lexer_peek_next()->kind != TOK_IDENT ||
	        lexer_peek_after_next()->kind != TOK_ASSIGN ||
	        lexer_peek_third()->kind != TOK_IDENT) {
		return NULL;
	}
	lexer_next(); /* ( */

	const Token *dst_tok = lexer_peek();
	lexer_next();

	expect(TOK_ASSIGN);

	const Token *src_tok = lexer_peek();
	if (src_tok->kind != TOK_IDENT) {
		fatal_cur("Expected RHS struct identifier in assignment expression\n");
	}
	lexer_next();

	expect(TOK_RPAREN);

	if (!is_struct_local(dst_tok->text) || !is_struct_local(src_tok->text)) {
		return NULL;
	}
	const char *dst_struct = struct_name_local(dst_tok->text);
	const char *src_struct = struct_name_local(src_tok->text);
	if (STRCMP(dst_struct, src_struct) != 0) {
		fatal_cur("Struct assignment expression type mismatch\n");
	}

	StructDef *def = find_struct(dst_struct);
	Node *dst = make_scalar_var_node(dst_tok->text);
	Node *src = make_scalar_var_node(src_tok->text);
	Node *assign = new_struct_assign(dst, src, def->size);

	Node *member = make_struct_member_read_from_local(dst_tok->text);

	if (setup_out)
		*setup_out = assign;

	return member;
}

static Node *
parse_call_statement_with_struct_assign_member_arg(void)
{

	/*
	 * v129b:
	 *
	 *   sink2((a = b).x, (c = d).y);
	 *
	 * Lower setup expressions before the call, preserving source order for
	 * struct assignments.
	 */
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN) {
		return NULL;
	}
	if (!(lexer_peek_after_next()->kind == TOK_LPAREN &&
	        lexer_peek_third()->kind == TOK_IDENT &&
	        lexer_peek_fourth()->kind == TOK_ASSIGN) &&
	        !(lexer_peek_after_next()->kind == TOK_IDENT &&
	          lexer_peek_third()->kind == TOK_LPAREN &&
	          lexer_peek_fourth()->kind == TOK_RPAREN &&
	          lexer_peek_fifth()->kind == TOK_DOT)) {
		return NULL;
	}

	const Token *func = lexer_peek();
	lexer_next();
	expect(TOK_LPAREN);

	Node *prefix = NULL;
	Node *args = NULL;
	Node *arg_tail = NULL;
	int saw_struct_assign_member = 0;

	if (lexer_peek()->kind != TOK_RPAREN) {
		for (;;) {
			Node *setup = NULL;
			Node *arg = parse_struct_assign_member_sum(&setup);

			if (arg) {
				saw_struct_assign_member = 1;
				if (setup)
					prefix = append_node(prefix, setup);
			} else {
				arg = parse_expr();
			}

			args = append_arg_node(args, &arg_tail, arg);

			if (lexer_peek()->kind != TOK_COMMA)
				break;

			lexer_next();
		}
	}

	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	if (!saw_struct_assign_member) {
		return NULL;
	}

	Node *call = new_call(func->text, args);
	Node *tmp=new_block(append_node(prefix, call));
	return tmp;
}

static Node *
parse_if_with_struct_assign_member_condition(void)
{

	if (lexer_peek()->kind != TOK_IF ||
	        lexer_peek_next()->kind != TOK_LPAREN) {
		return NULL;
	}
	if (!(lexer_peek_after_next()->kind == TOK_LPAREN &&
	        lexer_peek_third()->kind == TOK_IDENT &&
	        lexer_peek_fourth()->kind == TOK_ASSIGN) &&
	        !(lexer_peek_after_next()->kind == TOK_IDENT &&
	          lexer_peek_third()->kind == TOK_LPAREN &&
	          lexer_peek_fourth()->kind == TOK_RPAREN &&
	          lexer_peek_fifth()->kind == TOK_DOT)) {
		return NULL;
	}

	lexer_next();
	expect(TOK_LPAREN);

	Node *setup = NULL;
	Node *left = parse_struct_assign_member_sum(&setup);
	if (!left) {
		return NULL;
	}

	TokenKind op = lexer_peek()->kind;
	Node *cond = left;

	if (op == TOK_EQ || op == TOK_NE ||
	        op == TOK_LT || op == TOK_LE || op == TOK_GT || op == TOK_GE) {
		lexer_next();
		Node *rhs_setup = NULL;
		Node *right = parse_struct_assign_member_sum(&rhs_setup);
		if (!right)
			right = parse_expr();
		if (rhs_setup)
			setup = append_node(setup, rhs_setup);

		NodeKind kind = ND_EQ;
		if (op == TOK_NE) kind = ND_NE;
		else if (op == TOK_LT) kind = ND_LT;
		else if (op == TOK_LE) kind = ND_LE;
		else if (op == TOK_GT) kind = ND_GT;
		else if (op == TOK_GE) kind = ND_GE;

		cond = new_binary(kind, left, right);
	}

	expect(TOK_RPAREN);

	Node *then_body = parse_statement();
	Node *else_body = NULL;

	if (lexer_peek()->kind == TOK_ELSE) {
		lexer_next();
		else_body = parse_statement();
	}

	Node *tmp= new_block(append_node(setup, new_if(cond, then_body, else_body)));
	return tmp;
}


static Node *
parse_duff_switch_body(Node *cond)
{
	/*
	 * Parse Duff's-device style switches:
	 *
	 *   switch (x) {
	 *   case 0: do { stmt0;
	 *   case 7:      stmt7;
	 *          ...
	 *   case 1:      stmt1;
	 *           } while (expr);
	 *   }
	 *
	 * The case labels live inside the do-body and are valid C labels.
	 * Represent this as a switch whose case bodies fall through, with the
	 * do/while condition stored in switch->inc for the emitter.
	 */
	if (lexer_peek()->kind != TOK_CASE ||
	    lexer_peek_next()->kind != TOK_NUM ||
	    lexer_peek_after_next()->kind != TOK_COLON ||
	    lexer_peek_third()->kind != TOK_DO ||
	    lexer_peek_fourth()->kind != TOK_LBRACE)
		return NULL;

	Node *cases = NULL;

	/* First case: case N: do { */
	lexer_next(); /* case */
	int case_value = lexer_peek()->value;
	lexer_next(); /* number */
	expect(TOK_COLON);
	expect(TOK_DO);
	expect(TOK_LBRACE);

	for (;;) {
		Node *body = NULL;
		while (lexer_peek()->kind != TOK_CASE &&
		       lexer_peek()->kind != TOK_DEFAULT &&
		       lexer_peek()->kind != TOK_RBRACE &&
		       lexer_peek()->kind != TOK_EOF) {
			body = append_node(body, parse_statement());
		}

		cases = append_node(cases, new_case(case_value, body));

		if (lexer_peek()->kind == TOK_RBRACE)
			break;

		if (lexer_peek()->kind == TOK_DEFAULT) {
			lexer_next();
			expect(TOK_COLON);
			Node *dbody = NULL;
			while (lexer_peek()->kind != TOK_CASE &&
			       lexer_peek()->kind != TOK_RBRACE &&
			       lexer_peek()->kind != TOK_EOF)
				dbody = append_node(dbody, parse_statement());
			cases = append_node(cases, new_default(dbody));
			if (lexer_peek()->kind == TOK_RBRACE)
				break;
		}

		expect(TOK_CASE);
		const Token *v = lexer_peek();
		if (v->kind == TOK_NUM) {
			case_value = v->value;
			lexer_next();
		} else if (v->kind == TOK_IDENT && find_enum_const(v->text, &case_value)) {
			lexer_next();
		} else {
			fatal_cur("case label must be a constant integer\n");
		}
		expect(TOK_COLON);
	}

	expect(TOK_RBRACE);
	expect(TOK_WHILE);
	expect(TOK_LPAREN);
	Node *while_cond = parse_expr();
	expect(TOK_RPAREN);
	expect(TOK_SEMI);
	expect(TOK_RBRACE);

	Node *sw = new_switch(cond, cases);
	sw->inc = while_cond;
	return sw;
}

static Node *
parse_switch_statement(void)
{

	expect(TOK_SWITCH);
	expect(TOK_LPAREN);
	Node *cond = parse_expr();
	expect(TOK_RPAREN);

	/* C allows switch without braces: switch(x) case 0: stmt */
	if (lexer_peek()->kind != TOK_LBRACE) {
		/* Parse the body as a single statement which may be a case label */
		Node *cases = NULL;
		if (lexer_peek()->kind == TOK_CASE) {
			lexer_next();
			const Token *value = lexer_peek();
			int case_value = 0;
			if (value->kind == TOK_NUM) {
				case_value = value->value;
				lexer_next();
			} else if (value->kind == TOK_IDENT && find_enum_const(value->text, &case_value)) {
				lexer_next();
			}
			expect(TOK_COLON);
			Node *body = NULL;
			if (lexer_peek()->kind != TOK_SEMI &&
			    lexer_peek()->kind != TOK_CASE &&
			    lexer_peek()->kind != TOK_DEFAULT &&
			    lexer_peek()->kind != TOK_RBRACE) {
				body = parse_statement();
			} else if (lexer_peek()->kind == TOK_SEMI) {
				lexer_next();
			}
			cases = new_case(case_value, body);
		} else if (lexer_peek()->kind == TOK_DEFAULT) {
			lexer_next();
			expect(TOK_COLON);
			Node *body = parse_statement();
			cases = new_default(body);
		} else {
			/* No case label: just parse as a statement */
			cases = parse_statement();
		}
		return new_switch(cond, cases);
	}

	lexer_next(); /* consume { */

	Node *duff = parse_duff_switch_body(cond);
	if (duff)
		return duff;

	Node *cases = NULL;

	/* Consume any leading non-case statements (e.g. declarations, goto targets).
	 * Track brace depth to handle nested blocks containing case labels. */
	int switch_depth = 1; /* we already consumed outer { */
	Node *pre_stmts = NULL;
	while (switch_depth > 0 &&
	       !(switch_depth == 1 && (lexer_peek()->kind == TOK_CASE ||
	                                lexer_peek()->kind == TOK_DEFAULT ||
	                                lexer_peek()->kind == TOK_RBRACE))) {
		if (lexer_peek()->kind == TOK_LBRACE) {
			switch_depth++;
			lexer_next();
			continue;
		}
		if (lexer_peek()->kind == TOK_RBRACE) {
			switch_depth--;
			if (switch_depth > 0)
				lexer_next();
			continue;
		}
		/* Skip case/default labels at inner depths */
		if (lexer_peek()->kind == TOK_CASE || lexer_peek()->kind == TOK_DEFAULT) {
			lexer_next();
			if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT)
				lexer_next();
			if (lexer_peek()->kind == TOK_COLON)
				lexer_next();
			continue;
		}
		/* "do { ... case N: ... } while(cond);" — consume "do" and enter brace scope */
		if (lexer_peek()->kind == TOK_DO) {
			lexer_next(); /* consume do */
			continue;     /* next iter will see { and increment depth */
		}
		/* "while(cond)" at depth > 1 — close of do-while; consume it */
		if (lexer_peek()->kind == TOK_WHILE && switch_depth > 1) {
			lexer_next(); /* consume while */
			if (lexer_peek()->kind == TOK_LPAREN) {
				int wd = 1; lexer_next();
				while (wd > 0 && lexer_peek()->kind != TOK_EOF) {
					if (lexer_peek()->kind == TOK_LPAREN) wd++;
					else if (lexer_peek()->kind == TOK_RPAREN) wd--;
					lexer_next();
				}
			}
			if (lexer_peek()->kind == TOK_SEMI) lexer_next();
			continue;
		}
		pre_stmts = append_node(pre_stmts, parse_statement());
	}
	(void)pre_stmts; /* pre-case statements fall through; we discard AST but parse them */

	while (lexer_peek()->kind != TOK_RBRACE) {
		Node *case_node = NULL;

		if (lexer_peek()->kind == TOK_CASE) {
			lexer_next();

			const Token *value = lexer_peek();
			int case_value = 0;
			if (value->kind == TOK_NUM) {
				case_value = value->value;
				lexer_next();
			} else if (value->kind == TOK_IDENT && find_enum_const(value->text, &case_value)) {
				lexer_next();
			} else {
				fatal_cur("case label must be a constant integer\n");
			}
			expect(TOK_COLON);

			Node *body = NULL;
			/* Collect case body; track do-while depth to handle inner case labels */
			int case_brace_depth = 0;
			while (!(case_brace_depth == 0 &&
			         (lexer_peek()->kind == TOK_CASE ||
			          lexer_peek()->kind == TOK_DEFAULT ||
			          lexer_peek()->kind == TOK_RBRACE))) {
				if ((lexer_peek()->kind == TOK_CASE ||
				     lexer_peek()->kind == TOK_DEFAULT) && case_brace_depth > 0) {
					/* inner case label inside do-while — skip without recursing */
					lexer_next();
					if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT)
						lexer_next();
					if (lexer_peek()->kind == TOK_COLON) lexer_next();
				} else if (lexer_peek()->kind == TOK_DO) {
					/* "do {" — consume do, next iter sees { and increments depth */
					lexer_next();
				} else if (lexer_peek()->kind == TOK_LBRACE) {
					/* entering a nested scope */
					case_brace_depth++;
					lexer_next(); /* consume { without going through parse_statement */
				} else if (lexer_peek()->kind == TOK_RBRACE && case_brace_depth > 0) {
					/* closing a nested scope */
					case_brace_depth--;
					lexer_next(); /* consume } */
					/* if this closes a do-while, consume while(cond); */
					if (lexer_peek()->kind == TOK_WHILE) {
						lexer_next();
						if (lexer_peek()->kind == TOK_LPAREN) {
							int wd = 1; lexer_next();
							while (wd > 0 && lexer_peek()->kind != TOK_EOF) {
								if (lexer_peek()->kind == TOK_LPAREN) wd++;
								else if (lexer_peek()->kind == TOK_RPAREN) wd--;
								lexer_next();
							}
						}
						if (lexer_peek()->kind == TOK_SEMI) lexer_next();
					}
				} else {
					body = append_node(body, parse_statement());
				}
			}

			case_node = new_case(case_value, body);
		} else if (lexer_peek()->kind == TOK_DEFAULT) {
			lexer_next();
			expect(TOK_COLON);

			Node *body = NULL;
			while (lexer_peek()->kind != TOK_CASE &&
			        lexer_peek()->kind != TOK_DEFAULT &&
			        lexer_peek()->kind != TOK_RBRACE) {
				body = append_node(body, parse_statement());
			}

			case_node = new_default(body);
		} else {
			fatal_cur("Expected case/default label in switch\n");
		}

		cases = append_node(cases, case_node);
	}

	expect(TOK_RBRACE);
	Node *tmp= new_switch(cond, cases);
	return tmp;
}

static Node *
parse_function_pointer_declaration_statement(void)
{

	const Token *ret = lexer_peek();
	if (ret->kind != TOK_INT && ret->kind != TOK_CHAR) {
		return NULL;
	}

	if (lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_STAR) {
		return NULL;
	}

	int elem_size = (ret->kind == TOK_CHAR) ? 1 : 4;

	lexer_next();
	expect(TOK_LPAREN);
	expect(TOK_STAR);

	const Token *name = lexer_peek();
	if (name->kind == TOK_LPAREN) {
		/* Nested function pointer: "int (* (*p)(...))(...)" — treat as 8-byte pointer */
		int nest = 1; lexer_next(); /* consume ( */
		while (nest > 0 && lexer_peek()->kind != TOK_EOF) {
			if (lexer_peek()->kind == TOK_LPAREN) nest++;
			else if (lexer_peek()->kind == TOK_RPAREN) nest--;
			/* capture the first IDENT we see — that's the variable name */
			if (lexer_peek()->kind == TOK_IDENT && name->kind != TOK_IDENT)
				name = lexer_peek();
			lexer_next();
		}
		/* consume parameter list of inner pointer: (*p)(params1) */
		while (lexer_peek()->kind == TOK_LPAREN) {
			int pd = 1; lexer_next();
			while (pd > 0 && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_LPAREN) pd++;
				else if (lexer_peek()->kind == TOK_RPAREN) pd--;
				lexer_next();
			}
		}
		/* consume the outer ) that closes (* */
		expect(TOK_RPAREN);
		/* consume return-type parameter list: (params2) */
		while (lexer_peek()->kind == TOK_LPAREN) {
			int pd = 1; lexer_next();
			while (pd > 0 && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_LPAREN) pd++;
				else if (lexer_peek()->kind == TOK_RPAREN) pd--;
				lexer_next();
			}
		}
		if (name->kind != TOK_IDENT) return NULL;
		/* p is a pointer-to-function-pointer: elem_size=8 for 8-byte pointer deref */
		Type *fpp_type = type_ptr(type_ptr(type_int()));
		int fp_off = add_typed_local(name->text, fpp_type);
		Node *fp_decl = new_ptr_decl(name->text, fp_off);
		fp_decl->type = fpp_type;
		fp_decl->elem_size = 8;
		/* handle optional initializer */
		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			Node *rhs = parse_expr();
			expect(TOK_SEMI);
			Node *lhs2 = new_var(name->text, fp_off);
			lhs2->is_pointer = 1; lhs2->elem_size = 8;
			return new_block(append_node(fp_decl, new_assign(lhs2, rhs)));
		}
		expect(TOK_SEMI);
		return fp_decl;
	}
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected function pointer name\n");
	}
	lexer_next();

	expect(TOK_RPAREN);
	expect(TOK_LPAREN);

	if (lexer_peek()->kind == TOK_VOID) {
		lexer_next();
	} else {
		while (lexer_peek()->kind != TOK_RPAREN) {
			if (lexer_peek()->kind == TOK_DOT &&
			        lexer_peek_next()->kind == TOK_DOT &&
			        lexer_peek_after_next()->kind == TOK_DOT) {
				lexer_next();
				lexer_next();
				lexer_next();
				break;
			}

			if (!is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
				fatal_cur("Expected function pointer parameter type\n");
			}

			Type *param_type = parse_type_name();
			(void)param_type;

			if (lexer_peek()->kind == TOK_IDENT)
				lexer_next();

			if (lexer_peek()->kind == TOK_COMMA)
				lexer_next();
			else
				break;
		}
	}

	expect(TOK_RPAREN);

	int offset = add_pointer_local(name->text, elem_size);
	Node *decl = new_ptr_decl(name->text, offset);
	decl->is_pointer = 1;
	decl->elem_size = elem_size;
	decl->type = type_ptr(type_for_size(elem_size));

	if (lexer_peek()->kind == TOK_ASSIGN) {
		lexer_next();
		const Token *fn = lexer_peek();
		Node *rhs;
		if (fn->kind == TOK_IDENT && find_func(fn->text)) {
			lexer_next();
			rhs = new_func_addr(fn->text);
		} else {
			rhs = parse_expr();
		}
		expect(TOK_SEMI);

		Node *lhs = new_var(name->text, offset);
		lhs->is_pointer = 1;
		lhs->elem_size = elem_size;
		lhs->type = decl->type;

		Node *tmp= new_block(append_node(decl, new_assign(lhs, rhs)));
		return tmp;
	}

	expect(TOK_SEMI);
	return decl;
}

static Node *
parse_statement(void)
{
	const Token *token = lexer_peek();

	/* v175 empty statement */
	if (token->kind == TOK_SEMI) {
		lexer_next();
		return new_block(NULL);
	}

	if (token->kind == TOK_IDENT && lexer_peek_next()->kind == TOK_COLON) {
		lexer_next(); /* label */
		lexer_next(); /* ':' */
		return new_label_stmt(token->text);
	}

	if (token->kind == TOK_GOTO) {
		lexer_next();

		const Token *label = lexer_peek();
		if (label->kind != TOK_IDENT) {
			fatal_cur("Expected label after goto\n");
			exit(1);
		}

		lexer_next();
		expect(TOK_SEMI);
		return new_goto_stmt(label->text);
	}

	if (token->kind == TOK_ASM)
		return parse_asm_statement();

	if (parse_typedef_declaration())
		return new_block(NULL);

	if (token->kind == TOK_ENUM) {
		parse_enum_specifier();
		/* "enum E e;" — variable declaration of enum type (treated as int) */
		if (lexer_peek()->kind == TOK_IDENT) {
			const Token *var = lexer_peek();
			lexer_next();
			int offset = add_local(var->text);
			Node *node = new_decl(var->text, offset);
			node->elem_size = 4;
			node->type = type_int();
			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				Node *expr = parse_expr();
				expect(TOK_SEMI);
				Node *lhs = new_var(var->text, offset);
				lhs->type = type_int();
				return new_block(append_node(node, new_assign(lhs, expr)));
			}
			expect(TOK_SEMI);
			return new_block(node);
		}
		expect(TOK_SEMI);
		return new_block(NULL);
	}

	Node *func_ptr_decl = parse_function_pointer_declaration_statement();
	if (func_ptr_decl)
		return func_ptr_decl;

	Node *compound_assign = parse_struct_compound_assignment_statement();
	if (compound_assign)
		return compound_assign;

	Node *struct_ret_assign = parse_struct_return_assignment_statement();
	if (struct_ret_assign)
		return struct_ret_assign;

	Node *struct_ret_discard = parse_struct_return_discard_statement();
	if (struct_ret_discard)
		return struct_ret_discard;

	if (token->kind == TOK_IDENT && is_typedef_name(token->text)) {
		Type *base_type = parse_type_name();

		const Token *name = lexer_peek();
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected identifier after typedef name\n");
			exit(1);
		}

		lexer_next();

		if (lexer_peek()->kind == TOK_LBRACKET) {
			int dims[MAX_ARRAY_DIMS] = {0};
			int dim_count = parse_array_dimensions(dims, 1);
			int array_len = dims[0];
			int init_count = 0;
			int string_init = 0;
			int zero_fill_only = 0;
			char string_value[4096] = {0};

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				if (lexer_peek()->kind == TOK_STRING) {
					const Token *value = lexer_peek();
					string_init = 1;
					STRNCPY(string_value, value->text, sizeof(string_value) - 1);
					init_count = (int)strlen(value->text) + 1;
					lexer_next();
				} else if (consume_all_zero_initializer()) {
					zero_fill_only = 1;
					init_count = array_len;
				} else {
					fatal_cur("Unsupported typedef-based local array initializer\n");
					exit(1);
				}
			}

			if (array_len == 0)
				array_len = init_count;

			if (array_len <= 0) {
				fatal_cur("Array length must be known for typedef-based local array\n");
				exit(1);
			}

			if (dims[0] == 0)
				dims[0] = array_len;

			Type *array_type = build_array_type_from_dims(base_type, dims, dim_count);
			int offset = add_typed_local(name->text, array_type);
			Node *node = new_array_decl(name->text, offset, array_len);
			node->elem_size = type_elem_size(base_type);
			node->type = array_type;

			expect(TOK_SEMI);

			if (zero_fill_only)
				return build_local_zero_fill_block(name->text, offset, array_type->size, node);

			if (string_init) {
				Node head = {0};
				Node *cur = &head;
				int elem_size = type_elem_size(base_type);

				append_stmt(&cur, node);
				for (int i = 0; i < init_count; i++) {
					append_stmt(&cur,
					            make_local_array_store(name->text, offset, elem_size, i,
					                                   (unsigned char)string_value[i]));
				}
				for (int i = init_count; i < array_len; i++) {
					append_stmt(&cur,
					            make_local_array_store(name->text, offset, elem_size, i, 0));
				}
				return new_block(head.next);
			}

			return node;
		}

		int offset = add_typed_local(name->text, base_type);
		Node *node;

		if (base_type->kind == TY_PTR) {
			node = new_ptr_decl(name->text, offset);
			node->is_pointer = 1;
			node->elem_size = type_elem_size(base_type);
			if (base_type->base && base_type->base->kind == TY_STRUCT) {
				STRNCPY(node->struct_name, base_type->base->struct_name, sizeof(node->struct_name) - 1);
			}
		} else if (base_type->kind == TY_STRUCT) {
			node = new_struct_decl(name->text, offset);
		} else {
			node = new_decl(name->text, offset);
			node->elem_size = type_elem_size(base_type);
		}

		node->type = clone_type(base_type);

		if (base_type->kind == TY_STRUCT)
			return parse_struct_initializer_block(name->text, base_type->struct_name, offset, node);

		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();

			Node *expr = parse_expr();
			expect(TOK_SEMI);

			Node *lhs = new_var(name->text, offset);
			lhs->type = clone_type(base_type);
			lhs->elem_size = type_elem_size(base_type);
			if (base_type->kind == TY_PTR) {
				lhs->is_pointer = 1;
				if (base_type->base && base_type->base->kind == TY_STRUCT) {
					STRNCPY(lhs->struct_name, base_type->base->struct_name,
					        sizeof(lhs->struct_name) - 1);
				}
			}

			return new_block(append_node(node, new_assign(lhs, expr)));
		}

		expect(TOK_SEMI);
		return node;
	}

	if (token->kind == TOK_CONST || token->kind == TOK_VOID) {
		Type *decl_type = parse_type_name();

		const Token *name = lexer_peek();
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected identifier after declaration type\n");
			exit(1);
		}

		lexer_next();

		int offset;
		Node *node;

		offset = add_typed_local(name->text, decl_type);
		if (decl_type->kind == TY_PTR) {
			node = new_ptr_decl(name->text, offset);
			node->is_pointer = 1;
			if (decl_type->base && decl_type->base->kind == TY_STRUCT)
				STRNCPY(node->struct_name, decl_type->base->struct_name, sizeof(node->struct_name) - 1);
		} else {
			node = new_decl(name->text, offset);
		}

		node->type = clone_type(decl_type);
		node->elem_size = type_elem_size(decl_type);

		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			Node *expr = parse_expr();
			expect(TOK_SEMI);

			Node *lhs = new_var(name->text, offset);
			lhs->type = clone_type(decl_type);
			lhs->elem_size = type_elem_size(decl_type);
			if (decl_type->kind == TY_PTR)
				lhs->is_pointer = 1;

			return new_block(append_node(node, new_assign(lhs, expr)));
		}

		expect(TOK_SEMI);
		return node;
	}

	if (token->kind == TOK_STRUCT || token->kind == TOK_UNION) {
		int is_union = (token->kind == TOK_UNION);
		lexer_next();

		/* Anonymous struct/union: "struct { ... } var" */
		char anon_name[64];
		const Token *struct_name = lexer_peek();
		const char *resolved_struct_name = NULL;
		if (struct_name->kind == TOK_LBRACE) {
			snprintf(anon_name, sizeof(anon_name), "__anon_%s_%d",
			         is_union ? "union" : "struct", ++anon_struct_id);
			if (struct_count < 128) {
				StructDef *adef = &structs[struct_count++];
				memset(adef, 0, sizeof(*adef));
				STRNCPY(adef->name, anon_name, sizeof(adef->name) - 1);
				adef->is_union = is_union;
				parse_struct_body_into(adef);
				/* use the name stored in the stable StructDef */
				resolved_struct_name = adef->name;
			} else {
				resolved_struct_name = anon_name;
			}
		} else if (struct_name->kind != TOK_IDENT) {
			fatal_cur("Expected struct name\n");
			exit(1);
		} else {
			resolved_struct_name = struct_name->text;
			lexer_next();
			/* "struct S { ... } var" — inline struct definition */
			if (lexer_peek()->kind == TOK_LBRACE) {
				StructDef *idef = find_struct_or_null(resolved_struct_name);
				if (idef) {
					/* Scoped redefinition: "struct T { ... } s2" where T already exists.
					 * Create a shadow struct with a synthetic name so the new variable
					 * uses the inner definition without clobbering the outer one. */
					char shadow_name[64];
					snprintf(shadow_name, sizeof(shadow_name), "__shadow_%s_%d",
					         resolved_struct_name, ++anon_struct_id);
					if (struct_count < 128) {
						idef = &structs[struct_count++];
						memset(idef, 0, sizeof(*idef));
						STRNCPY(idef->name, shadow_name, sizeof(idef->name) - 1);
						idef->is_union = is_union;
						parse_struct_body_into(idef);
						resolved_struct_name = idef->name;
					}
				} else {
					if (struct_count >= 128)
						fatal_cur("Too many structs\n");
					idef = &structs[struct_count++];
					memset(idef, 0, sizeof(*idef));
					STRNCPY(idef->name, resolved_struct_name, sizeof(idef->name) - 1);
					idef->is_union = is_union;
					parse_struct_body_into(idef);
				}
			}
		}

		/* "struct T { ... };" or "struct T;" as a standalone statement — no variable */
		if (lexer_peek()->kind == TOK_SEMI) {
			lexer_next();
			return new_block(NULL);
		}
		/* "struct T { ... };" with a body but no var — already defined inline above.
		 * If next is still LBRACE it means we did NOT parse a body (named, forward ref).
		 * Parse and discard if the struct already exists (scoped redefinition). */
		if (lexer_peek()->kind == TOK_LBRACE && find_struct_or_null(resolved_struct_name)) {
			/* Shadow: skip the body without clobbering the existing definition */
			int depth = 1;
			lexer_next();
			while (depth > 0 && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_LBRACE) depth++;
				else if (lexer_peek()->kind == TOK_RBRACE) depth--;
				lexer_next();
			}
			expect(TOK_SEMI);
			return new_block(NULL);
		}

		int is_ptr_decl = 0;
		if (lexer_peek()->kind == TOK_STAR) {
			lexer_next();
			is_ptr_decl = 1;
		}

		const Token *var_name = lexer_peek();
		if (var_name->kind != TOK_IDENT) {
			fatal_cur("Expected variable name after aggregate type\n");
			exit(1);
		}

		lexer_next();

		StructDef *def = find_struct(resolved_struct_name);

		if (!is_ptr_decl && lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();

			const Token *len = lexer_peek();
			if (len->kind != TOK_NUM) {
				fatal_cur("Expected numeric struct array length\n");
			}

			lexer_next();
			expect(TOK_RBRACKET);

			Type *base_type = type_struct(resolved_struct_name, def->size);
			int offset = add_typed_array_local(var_name->text, base_type, len->value);
			Node *node = new_array_decl(var_name->text, offset, len->value);
			node->elem_size = def->size;
			node->type = type_array(base_type, len->value);

			if (lexer_peek()->kind == TOK_ASSIGN)
				return parse_struct_array_initializer_block(var_name->text, resolved_struct_name,
				        offset, len->value, node);

			expect(TOK_SEMI);
			return node;
		}

		int offset;
		if (is_ptr_decl)
			offset = add_struct_pointer_local(var_name->text, resolved_struct_name);
		else
			offset = add_struct_local(var_name->text, resolved_struct_name);

		Node *node = new_struct_decl(var_name->text, offset);
		node->type = is_ptr_decl ? type_ptr(type_struct(resolved_struct_name, def->size)) : type_struct(resolved_struct_name, def->size);

		if (!is_ptr_decl)
			return parse_struct_initializer_block(var_name->text, resolved_struct_name, offset, node);

		/* struct pointer local: handle optional initializer */
		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			Node *rhs = parse_assignment();
			Node *decl = new_struct_decl(var_name->text, offset);
			Node *lhs = new_var(var_name->text, offset);
			lhs->is_pointer = 1;
			lhs->type = type_ptr(type_struct(resolved_struct_name, def ? def->size : 0));
			Node *assign = new_assign(lhs, rhs);
			expect(TOK_SEMI);
			return new_block(append_node(decl, assign));
		}

		expect(TOK_SEMI);
		return node;
	}


	if (token->kind == TOK_STATIC) {
		lexer_next();

		/* skip const qualifier */
		if (lexer_peek()->kind == TOK_CONST)
			lexer_next();

		const Token *type_tok = lexer_peek();
		int is_ptr_type = 0;
		int elem_size = 4;

		if (type_tok->kind == TOK_INT) {
			elem_size = 4;
			lexer_next();
		} else if (type_tok->kind == TOK_CHAR) {
			elem_size = 1;
			lexer_next();
		} else if (type_tok->kind == TOK_UNSIGNED || type_tok->kind == TOK_SIGNED ||
		           type_tok->kind == TOK_SHORT || type_tok->kind == TOK_LONG) {
			/* eat modifiers */
			while (lexer_peek()->kind == TOK_UNSIGNED || lexer_peek()->kind == TOK_SIGNED ||
			        lexer_peek()->kind == TOK_SHORT || lexer_peek()->kind == TOK_LONG)
				lexer_next();
			if (lexer_peek()->kind == TOK_INT || lexer_peek()->kind == TOK_CHAR)
				lexer_next();
			elem_size = 4;
		} else if (type_tok->kind == TOK_STRUCT || type_tok->kind == TOK_UNION) {
			/* static struct/union local: emit as a named global */
			lexer_next(); /* consume struct/union keyword */
			const Token *stag = lexer_peek();
			char sname[64] = {0};
			if (stag->kind == TOK_IDENT) {
				STRNCPY(sname, stag->text, sizeof(sname)-1);
				lexer_next();
			}
			const Token *svar = lexer_peek();
			if (svar->kind != TOK_IDENT) {
				fatal_cur("Expected identifier after static struct\n");
				exit(1);
			}
			lexer_next(); /* consume variable name */
			char sgname[64];
			snprintf(sgname, sizeof(sgname), "__static_%.24s_%.24s", current_function_name, svar->text);
			if (global_count >= 512) { fatal_cur("Too many globals\n"); exit(1); }
			Global *sg = &globals[global_count];
			memset(sg, 0, sizeof(*sg));
			STRNCPY(sg->name, sgname, sizeof(sg->name)-1);
			sg->is_struct = 1;
			STRNCPY(sg->struct_name, sname, sizeof(sg->struct_name)-1);
			sg->array_len = 1;
			StructDef *sdef = find_struct_or_null(sname);
			if (sdef) {
				sg->elem_size = sdef->size;
				sg->init_count = sdef->size;
			}
			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				if (lexer_peek()->kind == TOK_LBRACE && sdef) {
					lexer_next();
					parse_global_struct_initializer_body(sg, sdef, 0);
					expect(TOK_RBRACE);
				} else {
					/* skip unknown initializer */
					if (lexer_peek()->kind == TOK_LBRACE) {
						int bd=1; lexer_next();
						while (bd>0 && lexer_peek()->kind!=TOK_EOF) {
							if (lexer_peek()->kind==TOK_LBRACE) bd++;
							else if (lexer_peek()->kind==TOK_RBRACE) bd--;
							lexer_next();
						}
					}
				}
			}
			expect(TOK_SEMI);
			global_count++;
			Type *st = sdef ? type_struct(sname, sdef->size) : type_for_size(4);
			add_static_local(svar->text, sgname, st, sdef ? sdef->size : 4, 0, 1);
			return new_block(NULL);
		} else if (is_typedef_name(type_tok->text)) {
			/* static <typedef> var -- treat like int for now */
			Type *td = find_typedef(type_tok->text);
			elem_size = td ? (td->size ? td->size : 4) : 4;
			lexer_next();
		} else {
			fatal_cur("Only int/char static locals supported for now\n");
			exit(1);
		}

		/* pointer qualifier */
		if (lexer_peek()->kind == TOK_STAR) {
			lexer_next();
			is_ptr_type = 1;
			elem_size = 8; /* pointer size */
		}

		const Token *name = lexer_peek();
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected identifier after static type\n");
			exit(1);
		}
		lexer_next();

		char gname[64];
		snprintf(gname, sizeof(gname), "__static_%.24s_%.24s", current_function_name, name->text);

		if (global_count >= 512) {
			fatal_cur("Too many globals\n");
			exit(1);
		}

		Global *g = &globals[global_count];
		memset(g, 0, sizeof(*g));
		STRNCPY(g->name, gname, sizeof(g->name) - 1);
		g->elem_size = elem_size;
		g->array_len = 1;

		int is_array = 0;
		int array_len = 1;

		if (lexer_peek()->kind == TOK_LBRACKET) {
			lexer_next();
			is_array = 1;
			array_len = 0;

			if (lexer_peek()->kind == TOK_NUM) {
				const Token *len = lexer_peek();
				if (len->value <= 0) {
					fatal_cur("Static array length must be positive\n");
					exit(1);
				}
				array_len = len->value;
				lexer_next();
			} else if (elem_size != 1 && !is_ptr_type) {
				fatal_cur("Expected numeric static array length\n");
				exit(1);
			}

			expect(TOK_RBRACKET);

			g->is_array = 1;
			g->array_len = array_len;
			g->elem_size = elem_size;

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				if (lexer_peek()->kind == TOK_LBRACE) {
					lexer_next();
					while (lexer_peek()->kind != TOK_RBRACE) {
						const Token *value = lexer_peek();
						if (value->kind == TOK_STRING && is_ptr_type) {
							/* static const char *arr[] = {"str", ...} —
							 * store each string as a separate global string,
							 * init value records the string label index. */
							if (g->init_count >= 256) {
								fatal_cur("Too many static array initializers\n");
								exit(1);
							}
							g->init_values[g->init_count++] = next_string_label;
							if (global_count + g->init_count < 512) {
								Global *sg = &globals[global_count + g->init_count];
								memset(sg, 0, sizeof(*sg));
								sg->is_string = 1;
								sg->string_label = next_string_label++;
								STRNCPY(sg->string_value, value->text, sizeof(sg->string_value) - 1);
							}
						} else if (value->kind == TOK_NUM) {
							if (g->init_count >= 256) {
								fatal_cur("Too many static array initializers\n");
								exit(1);
							}
							g->init_values[g->init_count++] = value->value;
						} else {
							fatal_cur("Static array initializer must contain constant integers\n");
							exit(1);
						}
						lexer_next();
						if (lexer_peek()->kind == TOK_COMMA)
							lexer_next();
						else
							break;
					}
					expect(TOK_RBRACE);
				} else if (elem_size == 1 && lexer_peek()->kind == TOK_STRING) {
					const Token *value = lexer_peek();
					g->is_string_array = 1;
					STRNCPY(g->string_value, value->text, sizeof(g->string_value) - 1);
					g->init_count = (int)strlen(value->text) + 1;
					lexer_next();
				} else {
					fatal_cur("Unsupported static array initializer\n");
					exit(1);
				}
			}

			if (array_len == 0)
				array_len = g->is_string_array ? (int)strlen(g->string_value) + 1 : g->init_count;
			if (array_len <= 0) {
				fatal_cur("Static array length must be known\n");
				exit(1);
			}
			g->array_len = array_len;
		} else {
			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				const Token *val = lexer_peek();
				if (val->kind != TOK_NUM) {
					fatal_cur("Static initializer must be constant\n");
					exit(1);
				}
				g->init_value = elem_size == 1 ? (val->value & 255) : val->value;
				lexer_next();
			}
		}

		expect(TOK_SEMI);
		global_count++;

		add_static_local(name->text, gname, is_array ? type_array(type_for_size(elem_size), array_len) : type_for_size(elem_size), elem_size, is_array, array_len);
		return new_block(NULL);
	}


	if (token->kind == TOK_SIGNED || token->kind == TOK_UNSIGNED ||
	        token->kind == TOK_SHORT || token->kind == TOK_LONG) {
		int base_size = 4;
		int saw_short = 0;
		int saw_unsigned = 0;
		while (lexer_peek()->kind == TOK_SIGNED ||
		        lexer_peek()->kind == TOK_UNSIGNED ||
		        lexer_peek()->kind == TOK_SHORT ||
		        lexer_peek()->kind == TOK_LONG) {
			if (lexer_peek()->kind == TOK_SHORT)
				saw_short = 1;
			if (lexer_peek()->kind == TOK_UNSIGNED)
				saw_unsigned = 1;
			lexer_next();
		}
		if (lexer_peek()->kind == TOK_CHAR) {
			base_size = 1;
			lexer_next();
		} else if (lexer_peek()->kind == TOK_INT) {
			lexer_next();
			if (saw_short)
				base_size = 2;
		} else if (saw_short) {
			base_size = 2;
		}

		int ptr_depth = 0;
		while (lexer_peek()->kind == TOK_STAR) {
			lexer_next();
			ptr_depth++;
		}
		int is_ptr_decl = ptr_depth > 0;

		const Token *name = lexer_peek();
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected identifier after integer type modifier\n");
			exit(1);
		}

		lexer_next();

		if (is_ptr_decl) {
			Type *ptr_type = type_for_size_unsigned(base_size, saw_unsigned);
			for (int i = 0; i < ptr_depth; i++)
				ptr_type = type_ptr(ptr_type);
			int offset = add_typed_local(name->text, ptr_type);
			Node *node = new_ptr_decl(name->text, offset);
			node->type = ptr_type;

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				Node *expr = parse_expr();
				expect(TOK_SEMI);

				Node *lhs = new_var(name->text, offset);
				lhs->is_pointer = 1;
				lhs->elem_size = base_size;
				lhs->type = type_ptr(type_for_size_unsigned(base_size, saw_unsigned));

				return new_block(append_node(node, new_assign(lhs, expr)));
			}

			/* Comma-separated pointer decls: "short *from, *to;" */
			Node *ptr_head = node;
			Node *ptr_tail = node;
			while (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				if (lexer_peek()->kind == TOK_SEMI) break;
				int np = 0;
				while (lexer_peek()->kind == TOK_STAR) { lexer_next(); np++; }
				const Token *nn = lexer_peek();
				if (nn->kind != TOK_IDENT) break;
				lexer_next();
				Type *npt = type_for_size_unsigned(base_size, saw_unsigned);
				int ndepth = np > 0 ? np : 1; /* at least 1 since is_ptr_decl */
				for (int pi = 0; pi < ndepth; pi++) npt = type_ptr(npt);
				int noff = add_typed_local(nn->text, npt);
				Node *nnode = new_ptr_decl(nn->text, noff);
				nnode->type = npt;
				ptr_tail->next = nnode; ptr_tail = nnode;
			}
			expect(TOK_SEMI);
			return ptr_head;
		}

		if (lexer_peek()->kind == TOK_LBRACKET) {
			int dims[MAX_ARRAY_DIMS] = {0};
			Type *base_type = type_for_size_unsigned(base_size, saw_unsigned);
			int dim_count = parse_array_dimensions(dims, 0);
			Type *array_type = build_array_type_from_dims(base_type, dims, dim_count);
			int offset = add_typed_local(name->text, array_type);
			Node *node = new_array_decl(name->text, offset, dims[0]);
			node->elem_size = type_elem_size(array_type);
			node->type = array_type;
			/* Handle comma-separated declarators: char a[16], b[16]; */
			Node *head = node;
			Node *tail = node;
			while (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				/* Handle "(*p)[4]" — pointer to array declarator */
				if (lexer_peek()->kind == TOK_LPAREN &&
				    lexer_peek_next()->kind == TOK_STAR) {
					lexer_next(); /* ( */
					lexer_next(); /* * */
					const Token *pa_name = lexer_peek();
					if (pa_name->kind != TOK_IDENT) break;
					lexer_next(); /* name */
					expect(TOK_RPAREN); /* ) */
					/* parse the array dimensions */
					Type *pa_base = type_for_size_unsigned(base_size, saw_unsigned);
					if (lexer_peek()->kind == TOK_LBRACKET) {
						int pa_dims[MAX_ARRAY_DIMS] = {0};
						int pa_dc = parse_array_dimensions(pa_dims, 0);
						Type *pa_arr = build_array_type_from_dims(pa_base, pa_dims, pa_dc);
						Type *pa_ptr = type_ptr(pa_arr);
						int pa_off = add_typed_local(pa_name->text, pa_ptr);
						Node *pa_node = new_ptr_decl(pa_name->text, pa_off);
						pa_node->type = pa_ptr;
						pa_node->elem_size = pa_arr->size;
						tail->next = pa_node; tail = pa_node;
					} else {
						Type *pa_ptr = type_ptr(pa_base);
						int pa_off = add_typed_local(pa_name->text, pa_ptr);
						Node *pa_node = new_ptr_decl(pa_name->text, pa_off);
						pa_node->type = pa_ptr;
						tail->next = pa_node; tail = pa_node;
					}
					continue;
				}
				int next_ptr_depth = 0;
				while (lexer_peek()->kind == TOK_STAR) { lexer_next(); next_ptr_depth++; }
				const Token *next_name = lexer_peek();
				if (next_name->kind != TOK_IDENT) break;
				lexer_next();
				if (lexer_peek()->kind == TOK_LBRACKET) {
					int next_dims[MAX_ARRAY_DIMS] = {0};
					Type *next_base = type_for_size_unsigned(base_size, saw_unsigned);
					int next_dim_count = parse_array_dimensions(next_dims, 0);
					Type *next_arr = build_array_type_from_dims(next_base, next_dims, next_dim_count);
					int next_off = add_typed_local(next_name->text, next_arr);
					Node *next_node = new_array_decl(next_name->text, next_off, next_dims[0]);
					next_node->elem_size = type_elem_size(next_arr);
					next_node->type = next_arr;
					tail->next = next_node; tail = next_node;
				} else if (next_ptr_depth > 0) {
					Type *ptr_type = type_for_size_unsigned(base_size, saw_unsigned);
					for (int pi = 0; pi < next_ptr_depth; pi++) ptr_type = type_ptr(ptr_type);
					int next_off = add_typed_local(next_name->text, ptr_type);
					Node *next_node = new_ptr_decl(next_name->text, next_off);
					next_node->type = ptr_type;
					tail->next = next_node; tail = next_node;
				} else {
					int next_off = add_local_sized(next_name->text, base_size, 0);
					Node *next_node = new_decl(next_name->text, next_off);
					next_node->elem_size = base_size;
					next_node->type = type_for_size_unsigned(base_size, saw_unsigned);
					tail->next = next_node; tail = next_node;
				}
			}
			expect(TOK_SEMI);
			return head;
		}

		int offset = add_local_sized(name->text, base_size, 0);
		locals[local_count - 1].elem_size = base_size;
		locals[local_count - 1].type = type_for_size_unsigned(base_size, saw_unsigned);
		Node *node = new_decl(name->text, offset);
		node->elem_size = base_size;
		node->is_unsigned = saw_unsigned;
		node->type = type_for_size_unsigned(base_size, saw_unsigned);

		Node *dhead = node;
		Node *dtail = node;

		for (;;) {
			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				Node *expr = parse_expr();
				Node *lhs = new_var(name->text, offset);
				lhs->elem_size = base_size;
				lhs->is_unsigned = saw_unsigned;
				lhs->type = type_for_size_unsigned(base_size, saw_unsigned);
				dtail = append_node(dtail, new_assign(lhs, expr));
			}
			if (lexer_peek()->kind != TOK_COMMA)
				break;
			lexer_next();
			name = lexer_peek();
			if (name->kind != TOK_IDENT) {
				fatal_cur("Expected identifier in declaration list\n");
				exit(1);
			}
			lexer_next();
			offset = add_local_sized(name->text, base_size, 0);
			locals[local_count - 1].elem_size = base_size;
			locals[local_count - 1].type = type_for_size_unsigned(base_size, saw_unsigned);
			Node *ndecl = new_decl(name->text, offset);
			ndecl->elem_size = base_size;
			ndecl->is_unsigned = saw_unsigned;
			ndecl->type = type_for_size_unsigned(base_size, saw_unsigned);
			dtail = append_node(dtail, ndecl);
		}
		expect(TOK_SEMI);
		return new_block(dhead);
	}

	if (token->kind == TOK_INT || token->kind == TOK_CHAR ||
	    token->kind == TOK_BOOL ||
	    token->kind == TOK_FLOAT || token->kind == TOK_DOUBLE) {
		/* "int f1(char *);" inside a function — local prototype declaration */
		if (try_parse_prototype())
			return new_block(NULL);
		int base_size = (token->kind == TOK_CHAR) ? 1 :
		                (token->kind == TOK_BOOL) ? 1 :
		                (token->kind == TOK_DOUBLE) ? 8 : 4;
		lexer_next();

		int ptr_depth = 0;
		while (lexer_peek()->kind == TOK_STAR) {
			lexer_next();
			ptr_depth++;
		}
		int is_ptr_decl = ptr_depth > 0;

		const Token *name = lexer_peek();
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected identifier after int\n");
			exit(1);
		}
		char local_name[64] = {0};
		STRNCPY(local_name, name->text ? name->text : "", sizeof(local_name) - 1);

		lexer_next();

		if (is_ptr_decl) {
			Type *ptr_type = type_for_size(base_size);
			for (int i = 0; i < ptr_depth; i++)
				ptr_type = type_ptr(ptr_type);
			int offset = add_typed_local(local_name, ptr_type);
			Node *node = new_ptr_decl(local_name, offset);
			node->type = ptr_type;

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				Node *expr = parse_expr();
				expect(TOK_SEMI);

				Node *lhs = new_var(local_name, offset);
				lhs->is_pointer = 1;
				lhs->elem_size = base_size;
				lhs->type = type_ptr(type_for_size(base_size));

				return new_block(append_node(node, new_assign(lhs, expr)));
			}

			expect(TOK_SEMI);
			return node;
		}

		if (lexer_peek()->kind == TOK_LBRACKET) {
			int dims[MAX_ARRAY_DIMS] = {0};
			int dim_count = parse_array_dimensions(dims, 1); /* allow int x[] = {...} */
			int array_len = dims[0];
			int total_len = 1;
			for (int d = 0; d < dim_count; d++) {
				if (dims[d] == 0) {
					if (d != 0) {
						fatal_cur("Only the first array dimension may be omitted\n");
					}
				} else {
					total_len *= dims[d];
				}
			}

			int init_values[256];
			int init_count = 0;
			int string_init = 0;
			int zero_fill_only = 0;
			char string_value[256] = {0};

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				if (dim_count > 1 && lexer_peek()->kind == TOK_LBRACE) {
					if (!consume_all_zero_initializer()) {
						fatal_cur("Only zero-initializers are supported for multidimensional local arrays\n");
					}
					zero_fill_only = 1;
					init_count = 1;
				} else if (lexer_peek()->kind == TOK_LBRACE) {
					lexer_next();

					while (lexer_peek()->kind != TOK_RBRACE) {
						const Token *value = lexer_peek();
						if (value->kind != TOK_NUM) {
							fatal_cur("Local array initializer must contain constant integers\n");
						}

						if (init_count >= 256) {
							fatal_cur("Too many local array initializers\n");
						}

						init_values[init_count++] = value->value;
						lexer_next();

						if (lexer_peek()->kind == TOK_COMMA)
							lexer_next();
						else
							break;
					}

					expect(TOK_RBRACE);
				} else if (base_size == 1 && lexer_peek()->kind == TOK_STRING) {
					const Token *value = lexer_peek();
					string_init = 1;
					STRNCPY(string_value, value->text, sizeof(string_value) - 1);
					init_count = (int)strlen(value->text) + 1;
					lexer_next();
				} else {
					fatal_cur("Unsupported local array initializer\n");
				}
			}

			if (array_len == 0)
				array_len = init_count;

			if (array_len <= 0) {
				fatal_cur("Array length must be positive: %s\n", local_name);
			}

			if (dims[0] == 0)
				dims[0] = array_len;

			if (dim_count > 1)
				total_len = array_len * (total_len / (dims[0] ? dims[0] : 1));
			else
				total_len = array_len;

			if (!zero_fill_only && init_count > total_len) {
				fatal_cur("Too many initializers for local array\n");
			}

			Type *array_type = build_array_type_from_dims(type_for_size(base_size), dims, dim_count);
			int offset = add_typed_local(local_name, array_type);
			Node *decl = new_array_decl(local_name, offset, array_len);
			decl->elem_size = type_elem_size(array_type);
			decl->type = array_type;

			/* Comma-separated declarators: char a[16], b[16]; */
			Node *comma_extra = NULL;
			Node *comma_tail = NULL;
			if (init_count == 0) {
				while (lexer_peek()->kind == TOK_COMMA) {
					lexer_next();
					/* Handle "(*p)[N]" — pointer-to-array declarator */
					if (lexer_peek()->kind == TOK_LPAREN &&
					    lexer_peek_next()->kind == TOK_STAR) {
						lexer_next(); /* ( */
						lexer_next(); /* * */
						const Token *pa2_name = lexer_peek();
						if (pa2_name->kind != TOK_IDENT) break;
						lexer_next();
						expect(TOK_RPAREN);
						Type *pa2_base = type_for_size(base_size);
						if (lexer_peek()->kind == TOK_LBRACKET) {
							int pa2_dims[MAX_ARRAY_DIMS] = {0};
							int pa2_dc = parse_array_dimensions(pa2_dims, 0);
							Type *pa2_arr = build_array_type_from_dims(pa2_base, pa2_dims, pa2_dc);
							Type *pa2_ptr = type_ptr(pa2_arr);
							int pa2_off = add_typed_local(pa2_name->text, pa2_ptr);
							Node *pa2_node = new_ptr_decl(pa2_name->text, pa2_off);
							pa2_node->type = pa2_ptr;
							pa2_node->elem_size = pa2_arr->size;
							if (!comma_extra) comma_extra = pa2_node; else comma_tail->next = pa2_node;
							comma_tail = pa2_node;
						} else {
							Type *pa2_ptr = type_ptr(pa2_base);
							int pa2_off = add_typed_local(pa2_name->text, pa2_ptr);
							Node *pa2_node = new_ptr_decl(pa2_name->text, pa2_off);
							pa2_node->type = pa2_ptr;
							if (!comma_extra) comma_extra = pa2_node; else comma_tail->next = pa2_node;
							comma_tail = pa2_node;
						}
						continue;
					}
					/* consume pointer stars before the name */
					int nstar = 0;
					while (lexer_peek()->kind == TOK_STAR) { lexer_next(); nstar++; }
					const Token *next_name = lexer_peek();
					if (next_name->kind != TOK_IDENT) break;
					lexer_next();
					if (nstar > 0) {
						Type *npt = type_for_size(base_size);
						for (int pi = 0; pi < nstar; pi++) npt = type_ptr(npt);
						int noff = add_typed_local(next_name->text, npt);
						Node *nd = new_ptr_decl(next_name->text, noff);
						nd->type = npt;
						if (!comma_extra) comma_extra = nd; else comma_tail->next = nd;
						comma_tail = nd;
						continue;
					}
					if (lexer_peek()->kind == TOK_LBRACKET) {
						int ndims[MAX_ARRAY_DIMS] = {0};
						int ndc = parse_array_dimensions(ndims, base_size == 1);
						Type *narr = build_array_type_from_dims(type_for_size(base_size), ndims, ndc);
						int noff = add_typed_local(next_name->text, narr);
						Node *nd = new_array_decl(next_name->text, noff, ndims[0]);
						nd->elem_size = type_elem_size(narr); nd->type = narr;
						if (!comma_extra) comma_extra = nd; else comma_tail->next = nd;
						comma_tail = nd;
					} else {
						int noff = (base_size==1) ? add_char_local(next_name->text) : add_local(next_name->text);
						Node *nd = new_decl(next_name->text, noff);
						nd->elem_size = base_size; nd->type = type_for_size(base_size);
						if (!comma_extra) comma_extra = nd; else comma_tail->next = nd;
						comma_tail = nd;
					}
				}
			}

			expect(TOK_SEMI);

			if (init_count == 0) {
				if (comma_extra) { decl->next = comma_extra; return decl; }
				return decl;
			}

			Node head = {0};
			Node *cur = &head;
			append_stmt(&cur, decl);

			/* write provided initializers */
			if (zero_fill_only) {
				for (int i = 0; i < total_len; i++) {
					append_stmt(&cur,
					            make_local_array_store(local_name, offset, base_size, i, 0));
				}
			} else if (string_init) {
				for (int i = 0; i < init_count; i++) {
					append_stmt(&cur,
					            make_local_array_store(local_name, offset, base_size, i, string_value[i]));
				}
			} else {
				for (int i = 0; i < init_count; i++) {
					append_stmt(&cur,
					            make_local_array_store(local_name, offset, base_size, i, init_values[i]));
				}
			}

			/* zero-fill remaining elements */
			for (int i = init_count; !zero_fill_only && i < total_len; i++) {
				append_stmt(&cur,
				            make_local_array_store(local_name, offset, base_size, i, 0));
			}

			return new_block(head.next);
		}

		int offset = (base_size == 1) ? add_char_local(local_name) : add_local(local_name);
		Node *node = new_decl(local_name, offset);
		node->elem_size = base_size;
		node->type = type_for_size(base_size);

		Node *head = node;
		Node *cur_tail = node;

		for (;;) {
			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				Node *setup = NULL;
				Node *expr = parse_struct_assign_member_sum(&setup);
				if (!expr)
					expr = parse_expr();

				Node *lhs = new_var(local_name, offset);
				lhs->elem_size = base_size;
				lhs->type = type_for_size(base_size);
				Node *assign = new_assign(lhs, expr);

				if (setup)
					cur_tail = append_node(cur_tail, setup);
				cur_tail = append_node(cur_tail, assign);
			}

			if (lexer_peek()->kind != TOK_COMMA)
				break;
			lexer_next(); /* consume comma */

			/* another declarator of the same base type */
			int list_ptr_depth = 0;
			while (lexer_peek()->kind == TOK_STAR) {
				lexer_next();
				list_ptr_depth++;
			}

			name = lexer_peek();
			if (name->kind != TOK_IDENT) {
				fatal_cur("Expected identifier in declaration list\n");
				exit(1);
			}
			STRNCPY(local_name, name->text ? name->text : "", sizeof(local_name) - 1);
			lexer_next();

			if (list_ptr_depth > 0) {
				Type *lptr_type = type_for_size(base_size);
				for (int i = 0; i < list_ptr_depth; i++)
					lptr_type = type_ptr(lptr_type);
				offset = add_typed_local(local_name, lptr_type);
				Node *pdecl = new_ptr_decl(local_name, offset);
				pdecl->type = lptr_type;
				cur_tail = append_node(cur_tail, pdecl);
			} else {
				offset = (base_size == 1) ? add_char_local(local_name) : add_local(local_name);
				Node *ndecl = new_decl(local_name, offset);
				ndecl->elem_size = base_size;
				ndecl->type = type_for_size(base_size);
				cur_tail = append_node(cur_tail, ndecl);
			}
		}

		expect(TOK_SEMI);
		return new_block(head);
	}

	if (token->kind == TOK_RETURN) {
		lexer_next();

		Node *struct_call_return = parse_return_struct_call_value();
		if (struct_call_return)
			return struct_call_return;

		Node *setup = NULL;
		Node *expr = parse_struct_assign_member_sum(&setup);
		if (expr) {
			expect(TOK_SEMI);
			return expr_value_statement(setup, new_return(expr));
		}

		Node *struct_assign_member_return = parse_return_struct_assign_member_expr();
		if (struct_assign_member_return)
			return struct_assign_member_return;

		Node *v124_return_call = parse_v124_return_call_with_temps();
		if (v124_return_call)
			return v124_return_call;

		Node *struct_return_arg = parse_return_call_with_struct_return_arg();
		if (struct_return_arg)
			return struct_return_arg;

		Node *compound_arg_return = parse_return_call_with_compound_literal_arg();
		if (compound_arg_return)
			return compound_arg_return;

		if (lexer_peek()->kind == TOK_SEMI) {
			lexer_next();
			return new_return(NULL);
		}

		expr = parse_expr();
		expect(TOK_SEMI);

		/* If returning a struct-call directly, spill to temp first */
		if (expr && expr->kind == ND_CALL && expr->returns_struct) {
			char temp_name[64];
			snprintf(temp_name, sizeof(temp_name), "__struct_ret_%d", struct_arg_temp_id++);
			const char *sname = expr->return_struct_name[0] ? expr->return_struct_name
			                    : (expr->type ? expr->type->struct_name : "");
			StructDef *def = find_struct(sname);
			int sz = def ? def->size : 8;
			int temp_off = add_struct_local(temp_name, sname);

			Node *lhs = new_var(temp_name, temp_off);
			lhs->type = type_struct(sname, sz);
			lhs->elem_size = sz;
			STRNCPY(lhs->struct_name, sname, sizeof(lhs->struct_name) - 1);

			Node *assign = new_assign(lhs, expr);

			Node *temp_ref = new_var(temp_name, temp_off);
			temp_ref->type = type_struct(sname, sz);
			temp_ref->elem_size = sz;
			STRNCPY(temp_ref->struct_name, sname, sizeof(temp_ref->struct_name) - 1);

			expr = new_binary(ND_COMMA, assign, temp_ref);
			expr->type = temp_ref->type;
		}

		return new_return(expr);
	}

	if (token->kind == TOK_BREAK) {
		lexer_next();
		expect(TOK_SEMI);
		return new_break();
	}

	if (token->kind == TOK_CONTINUE) {
		lexer_next();
		expect(TOK_SEMI);
		return new_continue();
	}

	if (token->kind == TOK_SWITCH)
		return parse_switch_statement();

	if (token->kind == TOK_IF) {
		Node *if_assign_member = parse_if_with_struct_assign_member_condition();
		if (if_assign_member)
			return if_assign_member;

		lexer_next();

		expect(TOK_LPAREN);
		Node *cond = parse_expr();
		expect(TOK_RPAREN);

		Node *then_body = parse_statement();
		Node *else_body = NULL;

		if (lexer_peek()->kind == TOK_ELSE) {
			lexer_next();
			else_body = parse_statement();
		}

		return new_if(cond, then_body, else_body);
	}

	if (token->kind == TOK_DO) {
		lexer_next();

		Node *body = parse_statement();

		expect(TOK_WHILE);
		expect(TOK_LPAREN);
		Node *cond = parse_expr();
		expect(TOK_RPAREN);
		expect(TOK_SEMI);

		return new_do_while(body, cond);
	}

	if (token->kind == TOK_WHILE) {
		lexer_next();

		expect(TOK_LPAREN);
		Node *cond = parse_expr();
		expect(TOK_RPAREN);

		Node *body = parse_statement();
		return new_while(cond, body);
	}

	if (token->kind == TOK_FOR) {
		lexer_next();

		expect(TOK_LPAREN);

		Node *init = NULL;
		if (lexer_peek()->kind == TOK_SEMI) {
			lexer_next();
		} else if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text) ||
		           lexer_peek()->kind == TOK_CONST ||
		           lexer_peek()->kind == TOK_STATIC) {
			/*
			 * v175: allow declaration initializers:
			 *
			 *   for (int i = 0; i < n; i++)
			 *
			 * parse_statement() consumes the declaration's trailing ';'.
			 */
			init = parse_statement();
		} else {
			init = parse_expr();
			expect(TOK_SEMI);
		}

		Node *cond = NULL;
		if (lexer_peek()->kind != TOK_SEMI)
			cond = parse_expr();
		expect(TOK_SEMI);

		Node *inc = NULL;
		if (lexer_peek()->kind != TOK_RPAREN) {
			inc = parse_expr();
			/* Comma-separated expressions in for increment: "f++, p++" */
			while (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				Node *extra = parse_expr();
				inc = append_node(inc, extra);
			}
		}
		expect(TOK_RPAREN);

		Node *body = parse_statement();
		return new_for(init, cond, inc, body);
	}

	if (token->kind == TOK_LBRACE) {
		lexer_next();

		Node *block = parse_block_contents();
		expect(TOK_RBRACE);

		return block;
	}

	if (token->kind == TOK_IDENT || token->kind == TOK_NUM || token->kind == TOK_STRING || token->kind == TOK_LPAREN || token->kind == TOK_MINUS || token->kind == TOK_NOT || token->kind == TOK_TILDE || token->kind == TOK_STAR || token->kind == TOK_AMP || token->kind == TOK_SIZEOF || token->kind == TOK_PLUSPLUS || token->kind == TOK_MINUSMINUS) {
		Node *assign_member_call_stmt = parse_call_statement_with_struct_assign_member_arg();
		if (assign_member_call_stmt)
			return assign_member_call_stmt;

		Node *v124_call_stmt = parse_v124_call_statement_with_temps();
		if (v124_call_stmt)
			return v124_call_stmt;

		Node *compound_call_stmt = parse_call_statement_with_compound_literal_arg();
		if (compound_call_stmt)
			return compound_call_stmt;

		Node *expr = parse_expr();
		expect(TOK_SEMI);
		return expr;
	}

	/* case/default labels that appear inside nested blocks within a switch body.
	 * Consume the label token and colon; the body statements will be handled
	 * by the enclosing parse_block_contents loop on subsequent iterations. */
	if (token->kind == TOK_CASE) {
		lexer_next(); /* consume "case" */
		/* consume the case value */
		if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT)
			lexer_next();
		expect(TOK_COLON);
		return new_num(0); /* body handled by caller's loop */
	}

	if (token->kind == TOK_DEFAULT) {
		lexer_next(); /* consume "default" */
		expect(TOK_COLON);
		return new_num(0); /* body handled by caller's loop */
	}

	fatal_cur("Unexpected token while parsing statement");
	exit(1);
}

static void 
parse_struct_definition(void)
{

	expect(TOK_STRUCT);

	const Token *name = lexer_peek();
	char struct_def_name[64];
	StructDef *def;

	if (name->kind == TOK_LBRACE) {
		/* anonymous struct definition */
		snprintf(struct_def_name, sizeof(struct_def_name), "__anon_struct_%d", ++anon_struct_id);
		if (struct_count >= 128)
			fatal_cur("Too many structs\n");
		def = &structs[struct_count++];
		memset(def, 0, sizeof(*def));
		STRNCPY(def->name, struct_def_name, sizeof(def->name) - 1);
		parse_struct_body_into(def);
	} else {
		if (name->kind != TOK_IDENT) {
			fatal_cur("Expected struct name\n");
		}
		STRNCPY(struct_def_name, name->text, sizeof(struct_def_name) - 1);
		def = find_struct_or_null(name->text);
		if (!def) {
			if (struct_count >= 128)
				fatal_cur("Too many structs\n");
			def = &structs[struct_count++];
		}
		memset(def, 0, sizeof(*def));
		STRNCPY(def->name, name->text, sizeof(def->name) - 1);
		lexer_next();
		parse_struct_body_into(def);
	}

	/* "struct [Name] { ... } varname [= {...}];" — global variable declaration */
	if (lexer_peek()->kind == TOK_IDENT || lexer_peek()->kind == TOK_STAR) {
		if (global_count >= 512)
			fatal_cur("Too many globals\n");
		Global *g = &globals[global_count];
		memset(g, 0, sizeof(*g));
		int ptr = 0;
		if (lexer_peek()->kind == TOK_STAR) {
			ptr = 1;
			lexer_next();
		}
		const Token *var = lexer_peek();
		if (var->kind != TOK_IDENT)
			fatal_cur("Expected global variable name\n");
		STRNCPY(g->name, var->text, sizeof(g->name) - 1);
		if (ptr) {
			g->elem_size = 8;       /* pointer to struct */
		} else {
			g->is_struct = 1;
			g->elem_size = def->size;
		}
		g->array_len = 1;
		STRNCPY(g->struct_name, struct_def_name, sizeof(g->struct_name) - 1);
		lexer_next();
		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			if (!try_parse_global_struct_compound_initializer(g, def, struct_def_name, 0)) {
				expect(TOK_LBRACE);
				g->init_count = def->size;
				parse_global_struct_initializer_body(g, def, 0);
				expect(TOK_RBRACE);
			}
		}
		expect(TOK_SEMI);
		commit_global_definition(g);
		return;
	}

	expect(TOK_SEMI);
}

static Node *
append_struct_copy_from_ptr_fields(Node *head, const char *dst_name, int dst_base, Node *src_base, const char *struct_name, int offset_base)
{
	StructDef *def = find_struct(struct_name);

	for (int i = 0; i < def->field_count; i++) {
		Field *field = &def->fields[i];

		if (field->is_struct) {
			head = append_struct_copy_from_ptr_fields(head, dst_name, dst_base, src_base,
			       field->struct_name, offset_base + field->offset);
			continue;
		}

		Node *lhs = new_member(field->name, dst_base + offset_base + field->offset);
		lhs->elem_size = field->size;
		lhs->type = type_for_size(field->size);
		STRNCPY(lhs->struct_name, struct_name, sizeof(lhs->struct_name) - 1);

		Node *base = new_var(src_base->name, src_base->offset);
		base->is_pointer = src_base->is_pointer;
		base->elem_size = src_base->elem_size;
		base->type = src_base->type;
		STRNCPY(base->struct_name, src_base->struct_name, sizeof(base->struct_name) - 1);

		Node *rhs = new_member_ptr(field->name, base, offset_base + field->offset);
		rhs->elem_size = field->size;
		rhs->type = type_for_size(field->size);

		head = append_node(head, new_assign(lhs, rhs));
	}

	(void)dst_name;
	return head;
}

static Node *
build_struct_param_copy(const char *dst_name, const char *hidden_name, const char *struct_name)
{
	Node *hidden = make_scalar_var_node(hidden_name);
	return append_struct_copy_from_ptr_fields(NULL, dst_name, find_local(dst_name), hidden, struct_name, 0);
}

static Node *
parse_function(void)
{

	skip_inline_qualifiers();

	local_count = 0;
	memset(locals, 0, sizeof(locals)); /* clear stale is_static bits from previous function */
	stack_size = 0;
	param_copy_count = 0;
	struct_param_copy_id = 1;
	pending_struct_param_count = 0;
	current_returns_struct = 0;
	current_return_size = 0;
	current_return_struct_name[0] = '\0';
	current_returns_pointer = 0;
	current_return_elem_size = 4;

	Type *ret_type = parse_type_name();

	/* skip __attribute__((noreturn)) etc. between return type and function name */
	skip_inline_qualifiers();

	if (ret_type->kind == TY_STRUCT) {
		current_returns_struct = 1;
		current_return_size = ret_type->size;
		STRNCPY(current_return_struct_name, ret_type->struct_name, sizeof(current_return_struct_name) - 1);
	} else if (ret_type->kind == TY_PTR) {
		current_returns_pointer = 1;
		current_return_elem_size = ret_type->base ? ret_type->base->size : 4;
	} else {
		current_return_elem_size = ret_type->size ? ret_type->size : 4;
	}

	const Token *name = lexer_peek();
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected function name\n");
	}

	/*
	 * Do not keep using name->text after parsing the function body.
	 * name points into the lexer's token ring, and body parsing performs
	 * enough lexer_peek()/lexer_next() calls to overwrite that token slot.
	 */
	char function_name[64];
	STRNCPY(function_name, name->text, sizeof(function_name) - 1);

	lexer_next();

	STRNCPY(current_function_name, function_name, sizeof(current_function_name) - 1);

	add_func_info(function_name, current_returns_struct, current_return_struct_name, current_return_size, current_returns_pointer, current_return_elem_size);

	expect(TOK_LPAREN);

	int param_count = 0;

	if (current_returns_struct) {
		add_struct_pointer_local("__ret", current_return_struct_name);
		param_count++;
	}

	if (lexer_peek()->kind == TOK_VOID && lexer_peek_next()->kind == TOK_RPAREN) {
		lexer_next();
	} else if (lexer_peek()->kind != TOK_RPAREN) {
		for (;;) {
			Type *param_type = parse_type_name();

			/* C adjusts array parameters, including typedef-named arrays, to pointers. */
			if (param_type->kind == TY_ARRAY)
				param_type = type_ptr(clone_type(param_type->base));

			int param_is_ptr = param_type->kind == TY_PTR;
			int param_is_struct_ptr = 0;
			char param_struct_name[64] = {0};

			if (param_type->kind == TY_STRUCT) {
				param_is_struct_ptr = 1;
				STRNCPY(param_struct_name, param_type->struct_name, sizeof(param_struct_name) - 1);
			} else if (param_type->kind == TY_PTR && param_type->base && param_type->base->kind == TY_STRUCT) {
				param_is_struct_ptr = 1;
				STRNCPY(param_struct_name, param_type->base->struct_name, sizeof(param_struct_name) - 1);
			}

			const Token *param = lexer_peek();
			char param_name_buf[64] = {0};
			if (param->kind != TOK_IDENT) {
				/*
				 * Accept unnamed parameters in prototypes and the special
				 * single void parameter form after the common type parser.
				 */
				if (lexer_peek()->kind == TOK_COMMA || lexer_peek()->kind == TOK_RPAREN) {
					param_name_buf[0] = '\0';
				} else {
					fatal_cur("Expected parameter name\n");
				}
			} else {
				STRNCPY(param_name_buf, param->text ? param->text : "", sizeof(param_name_buf) - 1);
				lexer_next();
			}

			if (param->text[0] && lexer_peek()->kind == TOK_LBRACKET) {
				int dims[MAX_ARRAY_DIMS] = {0};
				int dim_count = parse_array_dimensions(dims, 1);
				if (dim_count > 1)
					param_type = type_ptr(build_array_type_from_dims(param_type, dims + 1, dim_count - 1));
				else
					param_type = type_ptr(clone_type(param_type));
				param_is_ptr = 1;
			}

			/*
			 * Array parameters are adjusted to pointers by C.  This also matters
			 * when the array type arrives through a typedef, for example:
			 *
			 *     typedef int (*fptr4[4])(int);
			 *     int f4(fptr4 fp, int i) { return (*fp[i])(i); }
			 *
			 * Here fp is a pointer to the first function-pointer element, not a
			 * by-value array object.
			 */
			if (param_type->kind == TY_ARRAY) {
				param_type = type_ptr(clone_type(param_type->base));
				param_is_ptr = 1;
			}

			int param_base_size = type_elem_size(param_type);

			if (param->text[0] == '\0') {
				/* unnamed parameter: accepted for prototype-like syntax */
			} else if (param_is_struct_ptr) {
				if (param_is_ptr) {
					int offset = add_pointer_local(param->text, param_base_size);
					for (int i = 0; i < local_count; i++) {
						if (locals[i].offset == offset && STRCMP(locals[i].name, param->text) == 0) {
							locals[i].type = clone_type(param_type);
							locals[i].is_pointer = 1;
							locals[i].elem_size = param_base_size;
							STRNCPY(locals[i].struct_name, param_struct_name,
							        sizeof(locals[i].struct_name) - 1);
							break;
						}
					}
				} else {
					char hidden_name[64];
					snprintf(hidden_name, sizeof(hidden_name), "__paramptr_%d", struct_param_copy_id++);

					add_struct_pointer_local(hidden_name, param_struct_name);

					/*
					 * v124.1: do not allocate the user-visible struct parameter
					 * immediately.  Hidden ABI pointer slots must remain packed
					 * at -8, -16, ... so the prologue stores each incoming
					 * argument into the correct local slot.  User-visible struct
					 * copies are allocated after the full parameter list has
					 * been parsed.
					 */
					if (pending_struct_param_count >= 32) {
						fatal_cur("Too many struct parameters requiring copy-in\n");
					}

					STRNCPY(pending_struct_params[pending_struct_param_count].param_name, param->text,
					        sizeof(pending_struct_params[pending_struct_param_count].param_name) - 1);
					STRNCPY(pending_struct_params[pending_struct_param_count].hidden_name, hidden_name,
					        sizeof(pending_struct_params[pending_struct_param_count].hidden_name) - 1);
					STRNCPY(pending_struct_params[pending_struct_param_count].struct_name, param_struct_name,
					        sizeof(pending_struct_params[pending_struct_param_count].struct_name) - 1);
					pending_struct_param_count++;
				}
			} else if (param_is_ptr) {
				int offset = add_pointer_local(param->text, param_base_size);
				for (int i = 0; i < local_count; i++) {
					if (locals[i].offset == offset && STRCMP(locals[i].name, param->text) == 0) {
						locals[i].type = clone_type(param_type);
						locals[i].is_pointer = 1;
						locals[i].elem_size = param_base_size;
						if (param_type->base && param_type->base->kind == TY_STRUCT) {
							STRNCPY(locals[i].struct_name, param_type->base->struct_name,
							        sizeof(locals[i].struct_name) - 1);
						} else {
							locals[i].struct_name[0] = '\0';
						}
						break;
					}
				}
			} else
				add_local_sized(param->text, 2, 0);

			param_count++;

			if (lexer_peek()->kind != TOK_COMMA)
				break;

			lexer_next();

			if (lexer_peek()->kind == TOK_DOT &&
			        lexer_peek_next()->kind == TOK_DOT &&
			        lexer_peek_after_next()->kind == TOK_DOT) {
				lexer_next();
				lexer_next();
				lexer_next();

				for (int i = func_count - 1; i >= 0; i--) {
					if (STRCMP(funcs[i].name, function_name) == 0) {
						funcs[i].is_variadic = 1;
						funcs[i].fixed_param_count = param_count;
						break;
					}
				}
				break;
			}
		}
	}

	expect(TOK_RPAREN);
	skip_inline_qualifiers();

	for (int i = 0; i < pending_struct_param_count; i++) {
		add_struct_local(pending_struct_params[i].param_name,
		                 pending_struct_params[i].struct_name);

		if (param_copy_count >= 32) {
			fatal_cur("Too many struct parameters requiring copy-in\n");
		}

		STRNCPY(param_copies[param_copy_count].dst_name,
		        pending_struct_params[i].param_name,
		        sizeof(param_copies[param_copy_count].dst_name) - 1);
		STRNCPY(param_copies[param_copy_count].hidden_name,
		        pending_struct_params[i].hidden_name,
		        sizeof(param_copies[param_copy_count].hidden_name) - 1);
		STRNCPY(param_copies[param_copy_count].struct_name,
		        pending_struct_params[i].struct_name,
		        sizeof(param_copies[param_copy_count].struct_name) - 1);
		param_copy_count++;
	}

	expect(TOK_LBRACE);

	STRNCPY(current_func_name, function_name, sizeof(current_func_name) - 1);
	current_func_name[sizeof(current_func_name) - 1] = '\0';

	Node *body = parse_block_contents();

	/* Debug: print the body chain */
	{
		Node *dbg = body ? body->body : NULL;
		int cnt = 0;
		while (dbg) {
			Debug(1, "BODY_CHAIN[%d]: addr=%p kind=%d name=%s next=%p\n", cnt, (void*)dbg, dbg->kind, dbg->name, (void*)dbg->next);
			dbg = dbg->next;
			cnt++;
		}
	}

	expect(TOK_RBRACE);

	/* Debug AFTER expect */
	{
		Node *dbg = body ? body->body : NULL;
		int cnt = 0;
		while (dbg) {
			Debug(1, "AFTER_RBRACE[%d]: addr=%p kind=%d name=%s next=%p\n", cnt, (void*)dbg, dbg->kind, dbg->name, (void*)dbg->next);
			dbg = dbg->next;
			cnt++;
		}
	}

	if (param_copy_count > 0) {
		Node *copy_head = NULL;

		for (int i = 0; i < param_copy_count; i++) {
			Node *copy = build_struct_param_copy(param_copies[i].dst_name,
			                                     param_copies[i].hidden_name,
			                                     param_copies[i].struct_name);
			copy_head = append_node(copy_head, copy);
		}

		if (copy_head) {
			Node *tail = copy_head;
			while (tail->next)
				tail = tail->next;
			tail->next = body->body;
			body->body = copy_head;
		}
	}


	Node *func = new_func(function_name, body, stack_size, param_count);
	func->is_static = current_file_static;
	current_file_static = 0;
	func->returns_struct = current_returns_struct;
	func->struct_return_size = current_return_size;
	func->is_pointer = current_returns_pointer;
	func->elem_size = current_return_elem_size;
	if (current_returns_pointer)
		func->type = type_ptr(type_for_size(current_return_elem_size));
	STRNCPY(func->return_struct_name, current_return_struct_name, sizeof(func->return_struct_name) - 1);

	current_func_name[0] = '\0';

	return func;
}

static int 
looks_like_function_definition_start(void)
{
	const Token *a = lexer_peek();
	const Token *b = lexer_peek_next();
	const Token *c = lexer_peek_after_next();
	const Token *d = lexer_peek_third();
	const Token *e = lexer_peek_fourth();

	if (a->kind == TOK_STATIC || a->kind == TOK_INLINE || a->kind == TOK_CONST) {
		if (b->kind == TOK_IDENT && c->kind == TOK_IDENT && d->kind == TOK_LPAREN)
			return 1;
		if (b->kind == TOK_IDENT && c->kind == TOK_STAR && d->kind == TOK_IDENT && e->kind == TOK_LPAREN)
			return 1;
		if (b->kind == TOK_INLINE && c->kind == TOK_IDENT)
			return 1;
		if (b->kind == TOK_IDENT && STRCMP(b->text, "__attribute__") == 0)
			return 1;
	}

	if (a->kind == TOK_STRUCT || a->kind == TOK_UNION || a->kind == TOK_ENUM) {
		if (b->kind == TOK_IDENT && c->kind == TOK_IDENT && d->kind == TOK_LPAREN)
			return 1;
		if (b->kind == TOK_IDENT && c->kind == TOK_STAR && d->kind == TOK_IDENT && e->kind == TOK_LPAREN)
			return 1;
		return 0;
	}

	if (!is_type_start_token(a->kind, a->text))
		return 0;

	if (b->kind == TOK_IDENT && c->kind == TOK_LPAREN)
		return 1;

	if (b->kind == TOK_STAR && c->kind == TOK_IDENT && d->kind == TOK_LPAREN)
		return 1;

	if (b->kind == TOK_STAR && c->kind == TOK_CONST && d->kind == TOK_IDENT && e->kind == TOK_LPAREN)
		return 1;

	/* "enum TYPE func(" or "struct TYPE func(" */
	if ((a->kind == TOK_ENUM || a->kind == TOK_STRUCT) &&
	    b->kind == TOK_IDENT && c->kind == TOK_IDENT && d->kind == TOK_LPAREN)
		return 1;

	return 0;
}

static int try_parse_null_pointer_constant(void)
{
    const Token *t = lexer_peek();

    if (t->kind == TOK_NUM && t->value == 0) {
        lexer_next();
        return 1;
    }

    if (t->kind == TOK_IDENT && t->text && STRCMP(t->text, "NULL") == 0) {
        lexer_next();
        return 1;
    }

    if (t->kind == TOK_LPAREN &&
        lexer_peek_next()->kind == TOK_VOID &&
        lexer_peek_after_next()->kind == TOK_STAR &&
        lexer_peek_third()->kind == TOK_RPAREN &&
        lexer_peek_fourth()->kind == TOK_NUM &&
        lexer_peek_fourth()->value == 0) {
        lexer_next();
        lexer_next();
        lexer_next();
        lexer_next();
        lexer_next();
        return 1;
    }

    if (t->kind == TOK_LPAREN &&
        lexer_peek_next()->kind == TOK_LPAREN &&
        lexer_peek_after_next()->kind == TOK_VOID &&
        lexer_peek_third()->kind == TOK_STAR &&
        lexer_peek_fourth()->kind == TOK_RPAREN &&
        lexer_peek_fifth()->kind == TOK_NUM &&
        lexer_peek_fifth()->value == 0) {
        lexer_next();
        lexer_next();
        lexer_next();
        lexer_next();
        lexer_next();
        lexer_next();
        expect(TOK_RPAREN);
        return 1;
    }

    return 0;
}

static int
try_parse_global_addr_struct_compound_literal(Global **pg)
{
	Global *ptr_g = *pg;

	/*
	 * A file-scope compound literal has static storage duration.  Lower it to an
	 * anonymous static struct global, then initialize the pointer with that
	 * symbol's address.
	 */
	if (lexer_peek()->kind != TOK_AMP ||
	    lexer_peek_next()->kind != TOK_LPAREN ||
	    lexer_peek_after_next()->kind != TOK_STRUCT ||
	    lexer_peek_third()->kind != TOK_IDENT ||
	    lexer_peek_fourth()->kind != TOK_RPAREN ||
	    lexer_peek_fifth()->kind != TOK_LBRACE)
		return 0;

	Global saved_ptr = *ptr_g;

	lexer_next(); /* & */
	expect(TOK_LPAREN);
	expect(TOK_STRUCT);
	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in global compound literal\n");
		exit(1);
	}

	char struct_name_buf[64] = {0};
	STRNCPY(struct_name_buf, struct_name->text, sizeof(struct_name_buf) - 1);
	lexer_next();
	expect(TOK_RPAREN);
	expect(TOK_LBRACE);

	StructDef *def = find_struct(struct_name_buf);

	char lit_name[64];
	snprintf(lit_name, sizeof(lit_name), "__compound_global_%d", global_compound_literal_id++);

	Global *lit = &globals[global_count];
	memset(lit, 0, sizeof(*lit));
	STRNCPY(lit->name, lit_name, sizeof(lit->name) - 1);
	lit->array_len = 1;
	lit->elem_size = def->size;
	lit->is_struct = 1;
	lit->init_count = def->size;
	STRNCPY(lit->struct_name, struct_name_buf, sizeof(lit->struct_name) - 1);

	parse_global_struct_initializer_body(lit, def, 0);
	expect(TOK_RBRACE);
	commit_global_definition(lit);
	lit->is_static = 1;

	if (global_count >= 512) {
		fatal_cur("Too many globals\n");
		exit(1);
	}

	ptr_g = &globals[global_count];
	memset(ptr_g, 0, sizeof(*ptr_g));
	*ptr_g = saved_ptr;
	ptr_g->is_addr = 1;
	STRNCPY(ptr_g->addr_name, lit_name, sizeof(ptr_g->addr_name) - 1);
	*pg = ptr_g;
	return 1;
}


static int
try_parse_global_struct_compound_initializer(Global *g, StructDef *def, const char *expected_struct_name, int base_offset)
{
	int outer_paren = 0;

	if (lexer_peek()->kind != TOK_LPAREN)
		return 0;

	if (lexer_peek_next()->kind == TOK_LPAREN &&
	    lexer_peek_after_next()->kind == TOK_STRUCT) {
		outer_paren = 1;
		lexer_next();
	} else if (lexer_peek_next()->kind != TOK_STRUCT) {
		return 0;
	}

	expect(TOK_LPAREN);
	expect(TOK_STRUCT);

	const Token *struct_name = lexer_peek();
	if (struct_name->kind != TOK_IDENT) {
		fatal_cur("Expected struct name in global compound literal\n");
		exit(1);
	}

	if (STRCMP(struct_name->text, expected_struct_name) != 0) {
		fatal_cur("Global compound literal struct type mismatch\n");
		exit(1);
	}

	lexer_next();
	expect(TOK_RPAREN);
	expect(TOK_LBRACE);

	/*
	 * The same helper is used for both top-level globals and nested
	 * struct fields.  For nested fields, preserve the outer object's
	 * required initializer size instead of shrinking it to the nested
	 * struct's size.
	 */
	if (g->init_count < base_offset + def->size)
		g->init_count = base_offset + def->size;
	parse_global_struct_initializer_body(g, def, base_offset);

	expect(TOK_RBRACE);
	if (outer_paren)
		expect(TOK_RPAREN);

	return 1;
}

static void 
parse_generic_global_declaration(void)
{

	Type *type = parse_type_name();

	/* Forward declaration or bare struct/union type: "struct T;" */
	if (lexer_peek()->kind == TOK_SEMI) {
		lexer_next();
		(void)type;
		return;
	}

	/* Consume pointer stars: "enum E *e;" "const int *p;" */
	while (lexer_peek()->kind == TOK_STAR) {
		lexer_next();
		type = type_ptr(type);
	}

	const Token *name = lexer_peek();

	/* Global function pointer or function-returning-pointer:
	 *   "int (*fptr)() = 0;"              -- global fptr variable
	 *   "int (* f1(int a))(int c) { }"   -- function returning fptr */
	if (name->kind == TOK_LPAREN && lexer_peek_next()->kind == TOK_STAR) {
		lexer_next(); /* ( */
		lexer_next(); /* * */
		const Token *fp_name = lexer_peek();
		if (fp_name->kind != TOK_IDENT)
			fatal_cur("Expected function pointer name\n");
		char fp_decl_name[64] = {0};
		STRNCPY(fp_decl_name, fp_name->text, sizeof(fp_decl_name) - 1);
		lexer_next(); /* name */
		expect(TOK_RPAREN);
		expect(TOK_LPAREN);
		/* consume parameter list */
		if (lexer_peek()->kind == TOK_VOID) lexer_next();
		else while (lexer_peek()->kind != TOK_RPAREN && lexer_peek()->kind != TOK_EOF) {
			if (lexer_peek()->kind == TOK_DOT &&
			        lexer_peek_next()->kind == TOK_DOT &&
			        lexer_peek_after_next()->kind == TOK_DOT) {
				lexer_next();
				lexer_next();
				lexer_next();
				break;
			}
			if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
				Type *pt = parse_type_name(); (void)pt;
				if (lexer_peek()->kind == TOK_IDENT) lexer_next();
			}
			if (lexer_peek()->kind == TOK_COMMA) lexer_next(); else break;
		}
		expect(TOK_RPAREN);
		/* Register as global pointer (8 bytes on 64-bit) */
		if (global_count >= 512) fatal_cur("Too many globals\n");
		Global *g = &globals[global_count];
		memset(g, 0, sizeof(*g));
		STRNCPY(g->name, fp_decl_name, sizeof(g->name) - 1);
		g->elem_size = 8;
		g->array_len = 1;
		g->ptr_elem_size = 4; /* return type size */
		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			/* "&func" == "func" for function pointers */
			if (lexer_peek()->kind == TOK_AMP) lexer_next();
			const Token *val = lexer_peek();
			if (val->kind == TOK_NUM) { g->init_value = val->value; lexer_next(); }
			else if (val->kind == TOK_IDENT) {
				g->is_addr = 1;
				STRNCPY(g->addr_name, val->text, sizeof(g->addr_name) - 1);
				lexer_next();
			}
		}
		expect(TOK_SEMI);
		commit_global_definition(g);
		return;
	}

	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected global declarator name\n");
	}
	char global_decl_name[64] = {0};
	STRNCPY(global_decl_name, name->text ? name->text : "", sizeof(global_decl_name) - 1);

	lexer_next();

	if (global_count >= 512) {
		fatal_cur("Too many globals\n");
	}

	Global *g = &globals[global_count];
	memset(g, 0, sizeof(*g));
	STRNCPY(g->name, global_decl_name, sizeof(g->name) - 1);
	g->array_len = 1;

	if (type->kind == TY_PTR) {
		g->elem_size = 8;
		g->ptr_elem_size = type->base && type->base->size ? type->base->size : 1;
		if (type->base && type->base->kind == TY_STRUCT)
			STRNCPY(g->struct_name, type->base->struct_name, sizeof(g->struct_name) - 1);
	} else {
		g->elem_size = type->size ? type->size : 4;
	}

	if (type->kind == TY_STRUCT) {
		g->is_struct = 1;
		STRNCPY(g->struct_name, type->struct_name, sizeof(g->struct_name) - 1);
	}

	if (lexer_peek()->kind == TOK_LBRACKET) {
		lexer_next();

		/* Evaluate constant expression for global array size */
		if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT) {
			g->array_len = eval_const_array_size();
			if (g->array_len <= 0) g->array_len = 1;
		} else {
			g->array_len = 0;
		}

		g->is_array = 1;
		expect(TOK_RBRACKET);

		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();

			if (lexer_peek()->kind == TOK_LBRACE) {
				lexer_next();

				/* Struct array: "S a[1] = {{1, {2, 3}}};" — delegate to struct initializer */
				if (type->kind == TY_STRUCT && type->struct_name[0]) {
					StructDef *elem_def = find_struct_or_null(type->struct_name);
					if (elem_def) {
						g->is_struct = 1;
						g->is_array = 1;
						STRNCPY(g->struct_name, type->struct_name, sizeof(g->struct_name) - 1);
						g->elem_size = elem_def->size;
						g->init_count = elem_def->size; /* signal "has initializer" */
						int elem_index = 0;
						while (lexer_peek()->kind != TOK_RBRACE) {
							int base_offset = elem_index * elem_def->size;

							/*
							 * C aggregate initializers allow brace elision.
							 *
							 * For an array of structs, an element may either be written
							 * with its own braces or may start directly with the first
							 * field initializer.  For example:
							 *
							 *     struct SS sinit16[] = { { 1 }, 2 };
							 *
							 * The second element starts at token 2, not at a left brace.
							 */
							if (try_parse_global_struct_compound_initializer(g, elem_def,
							                                               type->struct_name,
							                                               base_offset)) {
								/* Element was written as (struct T){...} or ((struct T){...}). */
							} else if (lexer_peek()->kind == TOK_LBRACE) {
								lexer_next();
								parse_global_struct_initializer_body(g, elem_def, base_offset);
								expect(TOK_RBRACE);
							} else {
								/*
								 * Typedef-named array-of-struct declarations, e.g.
								 *
								 *     typedef struct { long c[4]; long b,e,k; } PT;
								 *     PT cases[] = { v0, v1, v2, v3, v4, v5, v6, ... };
								 *
								 * use C brace elision.  Parse exactly one PT element and
								 * leave the element separator for this outer array loop.
								 */
								parse_global_struct_initializer_body_ex(g, elem_def, base_offset, 1);
							}
							elem_index++;
							if (lexer_peek()->kind == TOK_COMMA) {
								lexer_next();
								if (lexer_peek()->kind == TOK_RBRACE) break;
							} else if (lexer_peek()->kind == TOK_RBRACE) {
								break;
							} else {
								/* The nested brace-elided parser may already have consumed
								 * the comma. If another initializer starts immediately, keep
								 * parsing the next array element. */
								continue;
							}
						}
						if (g->array_len == 0) g->array_len = elem_index;
						g->init_count = elem_index * elem_def->size;
						expect(TOK_RBRACE);
						expect(TOK_SEMI);
						commit_global_definition(g);
						return;
					}
				}

				while (lexer_peek()->kind != TOK_RBRACE) {
					const Token *value = lexer_peek();
					int init_value = 0;

					if (try_parse_null_pointer_constant()) {
						init_value = 0;
					} else if (value->kind == TOK_NUM) {
						init_value = value->value;
						lexer_next();
					} else if (value->kind == TOK_IDENT && find_enum_const(value->text, &init_value)) {
						/* enum-valued generic global arrays */
						lexer_next();
					} else {
						fatal_cur("Generic global array initializer must contain constant integers\n");
						exit(1);
					}

					if (g->init_count >= 256) {
						fatal_cur("Too many global array initializers\n");
						exit(1);
					}

					g->init_values[g->init_count++] = init_value;

					if (lexer_peek()->kind == TOK_COMMA)
						lexer_next();
					else
						break;
				}

				expect(TOK_RBRACE);
			} else if (lexer_peek()->kind == TOK_STRING && type->kind == TY_ARRAY) {
				const Token *value = lexer_peek();
				g->is_string_array = 1;
				STRNCPY(g->string_value, value->text, sizeof(g->string_value) - 1);
				if (g->array_len == 0)
					g->array_len = (int)strlen(value->text) + 1;
				lexer_next();
			} else {
				fatal_cur("Unsupported generic global array initializer\n");
				exit(1);
			}
		}

		expect(TOK_SEMI);
		commit_global_definition(g);
		return;
	}

	if (lexer_peek()->kind == TOK_ASSIGN) {
		lexer_next();

		const Token *value = lexer_peek();
		if (type->kind == TY_STRUCT && value->kind == TOK_LBRACE) {
			StructDef *def = find_struct(type->struct_name);
			lexer_next();
			g->init_count = def->size;
			parse_global_struct_initializer_body(g, def, 0);
			expect(TOK_RBRACE);
		} else if (value->kind == TOK_NUM) {
			g->init_value = value->value;
			lexer_next();
		} else if (value->kind == TOK_IDENT) {
			int enum_value = 0;
			if (try_parse_null_pointer_constant()) {
    				g->init_value = 0;
    				g->is_addr = 0;
    			/* whatever fields your scalar zero initializer normally sets */
			} else if (!find_enum_const(value->text, &enum_value)) {
				fatal_cur("Unsupported generic global initializer\n");
				exit(1);
			}
			g->init_value = enum_value;
			lexer_next();
		} else if (value->kind == TOK_STRING && type->kind == TY_PTR) {
			g->is_string = 1;
			g->string_label = next_string_label++;
			STRNCPY(g->string_value, value->text, sizeof(g->string_value) - 1);
			lexer_next();
		} else if (type->kind == TY_PTR && try_parse_global_addr_struct_compound_literal(&g)) {
			/* lowered by helper */
		} else if (value->kind == TOK_AMP && lexer_peek_next()->kind == TOK_IDENT) {
			lexer_next();
			const Token *target = lexer_peek();
			lexer_next();
			g->is_addr = 1;
			STRNCPY(g->addr_name, target->text, sizeof(g->addr_name) - 1);
		} else if (value->kind == TOK_IDENT && type->kind == TY_PTR && is_global(value->text)) {
			g->is_addr = 1;
			STRNCPY(g->addr_name, value->text, sizeof(g->addr_name) - 1);
			lexer_next();
		} else if (try_parse_null_pointer_constant()) {
    				g->init_value = 0;
    				g->is_addr = 0;
		} else if (value->kind == TOK_LPAREN && is_type_start_token(lexer_peek_next()->kind, lexer_peek_next()->text)) {
			/* Cast expression: "(type)value" in global initializer — evaluate as the value */
			lexer_next(); /* consume ( */
			Type *cast_type = parse_type_name(); (void)cast_type;
			expect(TOK_RPAREN);
			/* Unary minus before the value */
			int negate = 0;
			if (lexer_peek()->kind == TOK_MINUS) { lexer_next(); negate = 1; }
			const Token *cv = lexer_peek();
			if (cv->kind == TOK_NUM) {
				g->init_value = negate ? -cv->value : cv->value;
				lexer_next();
			} else if (cv->kind == TOK_IDENT && is_global(cv->text)) {
				g->is_addr = 1;
				STRNCPY(g->addr_name, cv->text, sizeof(g->addr_name) - 1);
				lexer_next();
			} else {
				fatal_cur("Unsupported cast expression in global initializer\n");
				exit(1);
			}
		} else if (value->kind == TOK_MINUS && lexer_peek_next()->kind == TOK_NUM) {
			/* Negative integer: "-1" */
			lexer_next(); /* - */
			g->init_value = -lexer_peek()->value;
			lexer_next();
		} else {
    			/* whatever fields your scalar zero initializer normally sets */
			fatal_cur("Unsupported generic global initializer\n");
			exit(1);
		}
	}

	commit_global_definition(g);

	/* Comma-separated global declarations: "int x, x = 3, x;" */
	while (lexer_peek()->kind == TOK_COMMA) {
		lexer_next(); /* consume , */
		if (lexer_peek()->kind == TOK_SEMI) break;
		const Token *extra_name = lexer_peek();
		if (extra_name->kind != TOK_IDENT) break;
		if (global_count >= 512) fatal_cur("Too many globals\n");
		Global *eg = &globals[global_count];
		memset(eg, 0, sizeof(*eg));
		STRNCPY(eg->name, extra_name->text, sizeof(eg->name) - 1);
		eg->elem_size = type->size ? type->size : 4;
		eg->array_len = 1;
		if (type->kind == TY_STRUCT) {
			eg->is_struct = 1;
			STRNCPY(eg->struct_name, type->struct_name, sizeof(eg->struct_name) - 1);
		}
		lexer_next(); /* consume name */
		if (lexer_peek()->kind == TOK_ASSIGN) {
			lexer_next();
			const Token *val = lexer_peek();
			if (val->kind == TOK_NUM) { eg->init_value = val->value; lexer_next(); }
			else if (val->kind == TOK_IDENT) {
				int ev = 0;
				if (find_enum_const(val->text, &ev)) { eg->init_value = ev; lexer_next(); }
				else { eg->is_addr = 1; STRNCPY(eg->addr_name, val->text, sizeof(eg->addr_name)-1); lexer_next(); }
			}
		}
		commit_global_definition(eg);
	}
	expect(TOK_SEMI);
}

static void 
parse_extern_global_declaration(void)
{
	expect(TOK_EXTERN);

	Type *type = parse_type_name();

	const Token *name = lexer_peek();
	if (name->kind != TOK_IDENT) {
		fatal_cur("Expected extern global declarator name\n");
		exit(1);
	}

	lexer_next();

	int is_array = 0;
	int array_len = 1;

	if (lexer_peek()->kind == TOK_LBRACKET) {
		lexer_next();
		is_array = 1;

		if (lexer_peek()->kind == TOK_NUM) {
			array_len = lexer_peek()->value;
			lexer_next();
		} else {
			array_len = 0;
		}

		expect(TOK_RBRACKET);
	}

	/*
	 * Initializers on extern declarations are definitions in C.  This compiler
	 * currently treats extern as declaration-only, so reject them rather than
	 * accidentally emitting storage in every translation unit.
	 */
	if (lexer_peek()->kind == TOK_ASSIGN) {
		fatal_cur("extern global initializer is not supported\n");
		exit(1);
	}

	expect(TOK_SEMI);

	/*
	 * Keep extern objects in the global symbol table so expressions such as
	 * &x86_codegen and references to global_count resolve, but mark them
	 * declaration-only so emit_program() does not allocate storage.
	 */
	if (find_global(name->text))
		return;

	if (global_count >= 512) {
		fatal_cur("Too many globals\n");
		exit(1);
	}

	Global *g = &globals[global_count];
	memset(g, 0, sizeof(*g));
	STRNCPY(g->name, name->text, sizeof(g->name) - 1);
	g->is_extern = 1;
	/* Mark symbols that live in dylibs and require GOT access on arm64.
	 * Only the macOS stdio stream globals (__stdinp/__stdoutp/__stderrp)
	 * need this — all other extern symbols are in the same link unit. */
	if (STRCMP(name->text, "__stdinp") == 0 ||
	        STRCMP(name->text, "__stdoutp") == 0 ||
	        STRCMP(name->text, "__stderrp") == 0)
		g->is_dylib = 1;
	g->is_array = is_array;
	g->array_len = array_len;

	if (type->kind == TY_PTR) {
		g->elem_size = 8;
		g->ptr_elem_size = type->base && type->base->size ? type->base->size : 1;
		if (type->base && type->base->kind == TY_STRUCT)
			STRNCPY(g->struct_name, type->base->struct_name, sizeof(g->struct_name) - 1);
	} else {
		g->elem_size = type->size ? type->size : 4;
	}

	if (type->kind == TY_STRUCT) {
		g->is_struct = 1;
		STRNCPY(g->struct_name, type->struct_name, sizeof(g->struct_name) - 1);
	}

	global_count++;
}

Node *
parse_program(const char *filename, const char *source)
{
	lexer_set_filename(filename ? filename : "<input>");
	lexer_init(source);
	next_string_label = 1;
	struct_count = 0;
	func_count = 0;
	global_count = 0;
	enum_const_count = 0;

	Node head = {0};
	Node *cur = &head;

	while (lexer_peek()->kind != TOK_EOF) {
		current_file_static = 0;

		/* Accept empty declarations at file scope: ";" */
		if (lexer_peek()->kind == TOK_SEMI) {
			lexer_next();
			continue;
		}

		/*
		 * Preserve file-scope static linkage instead of letting
		 * skip_inline_qualifiers() discard it.
		 */
		for (;;) {
			if (lexer_peek()->kind == TOK_STATIC) {
				current_file_static = 1;
				lexer_next();
				continue;
			}

			if (lexer_peek()->kind == TOK_INLINE ||
			        lexer_peek()->kind == TOK_CONST) {
				lexer_next();
				continue;
			}

			break;
		}

		/*
		 * Handle extern before skip_inline_qualifiers(), because that helper
		 * consumes TOK_EXTERN.  If this is an extern function prototype, let
		 * the normal prototype parser record its return metadata; otherwise
		 * parse the extern object declaration as declaration-only.
		 */
		if (lexer_peek()->kind == TOK_EXTERN) {
			if (try_parse_prototype())
				continue;

			parse_extern_global_declaration();
			continue;
		}

		skip_inline_qualifiers();

		if (lexer_peek()->kind == TOK_EOF)
			break;

		if (lexer_peek()->kind == TOK_SIGNED || lexer_peek()->kind == TOK_UNSIGNED ||
		        lexer_peek()->kind == TOK_SHORT || lexer_peek()->kind == TOK_LONG) {
			int elem_size = 4;
			int saw_short = 0;
			int saw_unsigned = 0;
			while (lexer_peek()->kind == TOK_SIGNED ||
			        lexer_peek()->kind == TOK_UNSIGNED ||
			        lexer_peek()->kind == TOK_SHORT ||
			        lexer_peek()->kind == TOK_LONG) {
				if (lexer_peek()->kind == TOK_SHORT)
					saw_short = 1;
				if (lexer_peek()->kind == TOK_UNSIGNED)
					saw_unsigned = 1;
				lexer_next();
			}
			if (lexer_peek()->kind == TOK_CHAR) {
				elem_size = 1;
				lexer_next();
			} else if (lexer_peek()->kind == TOK_INT) {
				lexer_next();
				if (saw_short)
					elem_size = 2;
			} else if (saw_short) {
				elem_size = 2;
			}

			const Token *name = lexer_peek();
			if (name->kind != TOK_IDENT) {
				fatal_cur("Expected global identifier after integer type modifier\n");
				exit(1);
			}
			lexer_next();

			if (lexer_peek()->kind == TOK_LPAREN) {
				/* Function with unsigned/short return type: register as function.
				 * Parse params and body. */
				char fn_name2[64] = {0};
				STRNCPY(fn_name2, name->text, sizeof(fn_name2)-1);
				local_count = 0; stack_size = 0;
				param_copy_count = 0; pending_struct_param_count = 0;
				STRNCPY(current_function_name, fn_name2, sizeof(current_function_name)-1);
				add_func_info(fn_name2, 0, "", 0, 0, elem_size);
				expect(TOK_LPAREN);
				int fp2d = 1;
				while (fp2d > 0 && lexer_peek()->kind != TOK_EOF) {
					if (lexer_peek()->kind == TOK_LPAREN) fp2d++;
					else if (lexer_peek()->kind == TOK_RPAREN) fp2d--;
					if (fp2d > 0) {
						/*
						 * Register params for the unsigned/short-return fast path using
						 * the same ABI-sized local slots as parse_function().  The old
						 * code discarded pointer information and allocated one 4-byte
						 * slot, so e.g.
						 *
						 *     static unsigned int f(unsigned int *p) { return *p; }
						 *
						 * stored x0 at [fp-8] in the prologue but later reloaded p
						 * from [fp-4] as an int, dereferencing garbage.
						 */
						if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
							Type *pt2 = parse_type_name();
							if (pt2 && pt2->kind == TY_ARRAY)
								pt2 = type_ptr(clone_type(pt2->base));

							if (lexer_peek()->kind == TOK_IDENT) {
								const char *pn2 = lexer_peek()->text;
								if (pt2 && pt2->kind == TY_PTR) {
									int elem = pt2->base ? pt2->base->size : 4;
									int poff2 = add_pointer_local(pn2, elem);
									for (int li = 0; li < local_count; li++) {
										if (locals[li].offset == poff2 && STRCMP(locals[li].name, pn2) == 0) {
											locals[li].type = clone_type(pt2);
											locals[li].is_pointer = 1;
											locals[li].elem_size = elem;
											break;
										}
									}
								} else {
									int poff2 = add_local_sized(pn2, 2, 0);
									for (int li = 0; li < local_count; li++) {
										if (locals[li].offset == poff2 && STRCMP(locals[li].name, pn2) == 0) {
											locals[li].type = pt2 ? clone_type(pt2) : type_int();
											locals[li].elem_size = pt2 && pt2->size ? pt2->size : 4;
											break;
										}
									}
								}
								lexer_next();
							}
							if (lexer_peek()->kind == TOK_COMMA) lexer_next();
						} else { lexer_next(); }
					} else { lexer_next(); }
				}
				expect(TOK_LBRACE);
				Node *fn2_body = parse_block_contents();
				expect(TOK_RBRACE);
				cur->next = new_func(fn_name2, fn2_body, stack_size, local_count);
				cur = cur->next;
				continue;
			}

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			Global *g = &globals[global_count];
			memset(g, 0, sizeof(*g));
			STRNCPY(g->name, name->text, sizeof(g->name) - 1);
			g->elem_size = elem_size;
			g->is_unsigned = saw_unsigned;
			g->array_len = 1;

			if (lexer_peek()->kind == TOK_LBRACKET) {
				lexer_next();

				const Token *len = lexer_peek();
				if (len->kind != TOK_NUM || len->value <= 0) {
					fatal_cur("Expected positive numeric global array length\n");
					exit(1);
				}

				g->is_array = 1;
				g->array_len = len->value;
				lexer_next();
				expect(TOK_RBRACKET);

				if (lexer_peek()->kind == TOK_ASSIGN) {
					lexer_next();
					expect(TOK_LBRACE);

					while (lexer_peek()->kind != TOK_RBRACE) {
						const Token *value = lexer_peek();
						if (value->kind != TOK_NUM) {
							fatal_cur("Global array initializer must contain constant integers\n");
							exit(1);
						}
						if (g->init_count >= 256) {
							fatal_cur("Too many global array initializers\n");
							exit(1);
						}
						g->init_values[g->init_count++] = value->value;
						lexer_next();

						if (lexer_peek()->kind == TOK_COMMA)
							lexer_next();
						else
							break;
					}

					expect(TOK_RBRACE);
				}

				expect(TOK_SEMI);
				commit_global_definition(&globals[global_count]);
				continue;
			}

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				const Token *value = lexer_peek();
				if (value->kind != TOK_NUM) {
					fatal_cur("Global initializer must be constant integer for modified integer type\n");
					exit(1);
				}
				g->init_value = elem_size == 1 ? (value->value & 255) : value->value;
				lexer_next();
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}

		if (lexer_peek()->kind == TOK_CHAR &&
		        lexer_peek_next()->kind == TOK_IDENT &&
		        lexer_peek_after_next()->kind == TOK_LBRACKET) {
			lexer_next(); /* char */

			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			globals[global_count].name[0] = 0;
			globals[global_count].init_value = 0;
			globals[global_count].is_array = 1;
			globals[global_count].array_len = 0;
			globals[global_count].elem_size = 1;
			globals[global_count].is_string = 0;
			globals[global_count].string_label = 0;
			globals[global_count].string_value[0] = '\0';
			globals[global_count].init_count = 0;
			globals[global_count].is_string_array = 0;
			globals[global_count].is_addr = 0;
			globals[global_count].addr_name[0] = '\0';
			globals[global_count].is_struct = 0;
			globals[global_count].struct_name[0] = '\0';
			globals[global_count].ptr_elem_size = 0;
			STRNCPY(globals[global_count].name, name->text, 63);

			expect(TOK_LBRACKET);
			if (lexer_peek()->kind == TOK_NUM) {
				const Token *len = lexer_peek();
				globals[global_count].array_len = len->value;
				lexer_next();
			}
			expect(TOK_RBRACKET);

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				const Token *value = lexer_peek();
				if (value->kind == TOK_STRING) {
					/* char buf[N] = "string"; */
					globals[global_count].is_string_array = 1;
					STRNCPY(globals[global_count].string_value, value->text, sizeof(globals[global_count].string_value) - 1);
					if (globals[global_count].array_len == 0)
						globals[global_count].array_len = (int)strlen(value->text) + 1;
					lexer_next();
				} else if (value->kind == TOK_LBRACE) {
					/* char buf[N] = {0}; or char buf[N] = {'a', 'b', 0}; */
					lexer_next(); /* consume '{' */
					int slen = 0;
					char sbuf[4096];
					sbuf[0] = '\0';
					while (lexer_peek()->kind != TOK_RBRACE) {
						const Token *elem = lexer_peek();
						int byte_val = 0;
						if (elem->kind == TOK_NUM) {
							byte_val = elem->value;
						} else if (elem->kind == TOK_CHAR) {
							byte_val = elem->value;
						} else {
							fatal_cur("Global char array brace initializer must contain integer or char constants\n");
							exit(1);
						}
						if (slen < 4095)
							sbuf[slen++] = (char)byte_val;
						lexer_next();
						if (lexer_peek()->kind == TOK_COMMA)
							lexer_next();
						else
							break;
					}
					expect(TOK_RBRACE);
					sbuf[slen] = '\0';
					globals[global_count].is_string_array = 1;
					STRNCPY(globals[global_count].string_value, sbuf, sizeof(globals[global_count].string_value) - 1);
					if (globals[global_count].array_len == 0)
						globals[global_count].array_len = slen + 1;
				} else {
					fatal_cur("Global char array initializer must be a string literal or brace-enclosed list\n");
					exit(1);
				}
			}

			if (globals[global_count].array_len <= 0) {
				fatal_cur("Global char array length must be known\n");
				exit(1);
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}

		if (lexer_peek()->kind == TOK_CHAR &&
		        lexer_peek_next()->kind == TOK_STAR &&
		        lexer_peek_after_next()->kind == TOK_IDENT &&
		        lexer_peek_third()->kind != TOK_LPAREN &&
		        lexer_peek_third()->kind != TOK_LBRACKET) {
			lexer_next(); /* char */
			lexer_next(); /* * */

			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			globals[global_count].name[0] = 0;
			globals[global_count].init_value = 0;
			globals[global_count].array_len = 0;
			globals[global_count].array_len = 1;
			globals[global_count].elem_size = 8;
			globals[global_count].is_string = 0;
			globals[global_count].string_label = 0;
			globals[global_count].string_value[0] = '\0';
			globals[global_count].init_count = 0;
			globals[global_count].is_string_array = 0;
			globals[global_count].is_addr = 0;
			globals[global_count].addr_name[0] = '\0';
			globals[global_count].is_struct = 0;
			globals[global_count].struct_name[0] = '\0';
			globals[global_count].ptr_elem_size = 0;
			STRNCPY(globals[global_count].name, name->text, 63);

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				const Token *value = lexer_peek();
				if (value->kind == TOK_STRING) {
					globals[global_count].is_string = 1;
					globals[global_count].string_label = next_string_label++;
					STRNCPY(globals[global_count].string_value, value->text, sizeof(globals[global_count].string_value) - 1);
					lexer_next();
				} else if (value->kind == TOK_AMP && lexer_peek_next()->kind == TOK_IDENT) {
					lexer_next(); /* & */
					const Token *target = lexer_peek();
					lexer_next();

					if (!is_global(target->text)) {
						fatal_cur("Global pointer initializer target must be an earlier global\n");
						exit(1);
					}

					globals[global_count].is_addr = 1;
					globals[global_count].ptr_elem_size = 1;
					STRNCPY(globals[global_count].addr_name, target->text, sizeof(globals[global_count].addr_name) - 1);
				} else if (value->kind == TOK_IDENT && is_global(value->text)) {
					globals[global_count].is_addr = 1;
					globals[global_count].ptr_elem_size = 1;
					STRNCPY(globals[global_count].addr_name, value->text, sizeof(globals[global_count].addr_name) - 1);
					lexer_next();
				} else {
					fatal_cur("Global char pointer initializer must be string literal or &global for now\n");
					exit(1);
				}
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}


		if (lexer_peek()->kind == TOK_CHAR &&
		        lexer_peek_next()->kind == TOK_IDENT &&
		        lexer_peek_after_next()->kind != TOK_LBRACKET &&
		        lexer_peek_after_next()->kind != TOK_LPAREN) {
			lexer_next(); /* char */

			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			globals[global_count].name[0] = 0;
			globals[global_count].init_value = 0;
			globals[global_count].array_len = 0;
			globals[global_count].array_len = 1;
			globals[global_count].elem_size = 1;
			globals[global_count].is_string = 0;
			globals[global_count].string_label = 0;
			globals[global_count].string_value[0] = '\0';
			globals[global_count].init_count = 0;
			globals[global_count].is_string_array = 0;
			globals[global_count].is_addr = 0;
			globals[global_count].addr_name[0] = '\0';
			globals[global_count].is_struct = 0;
			globals[global_count].struct_name[0] = '\0';
			globals[global_count].ptr_elem_size = 0;
			STRNCPY(globals[global_count].name, name->text, 63);

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				const Token *value = lexer_peek();
				if (value->kind != TOK_NUM) {
					fatal_cur("Global char initializer must be a constant integer for now\n");
					exit(1);
				}

				globals[global_count].init_value = value->value & 255;
				lexer_next();
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}


		if (lexer_peek()->kind == TOK_INT &&
		        lexer_peek_next()->kind == TOK_STAR &&
		        lexer_peek_after_next()->kind == TOK_IDENT &&
		        lexer_peek_third()->kind != TOK_LPAREN &&
		        lexer_peek_third()->kind != TOK_LBRACKET) {
			lexer_next(); /* int */
			lexer_next(); /* * */

			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			globals[global_count].name[0] = 0;
			globals[global_count].init_value = 0;
			globals[global_count].array_len = 0;
			globals[global_count].array_len = 1;
			globals[global_count].elem_size = 8;
			globals[global_count].ptr_elem_size = 4;
			globals[global_count].is_string = 0;
			globals[global_count].string_label = 0;
			globals[global_count].string_value[0] = '\0';
			globals[global_count].init_count = 0;
			globals[global_count].is_string_array = 0;
			globals[global_count].is_addr = 0;
			globals[global_count].addr_name[0] = '\0';
			globals[global_count].is_struct = 0;
			globals[global_count].struct_name[0] = '\0';
			STRNCPY(globals[global_count].name, name->text, 63);

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				if (lexer_peek()->kind != TOK_AMP || lexer_peek_next()->kind != TOK_IDENT) {
					fatal_cur("Global pointer initializer must be &global for now\n");
					exit(1);
				}

				lexer_next(); /* & */
				const Token *target = lexer_peek();
				lexer_next();

				if (!is_global(target->text)) {
					fatal_cur("Global pointer initializer target must be an earlier global\n");
					exit(1);
				}

				globals[global_count].is_addr = 1;
				STRNCPY(globals[global_count].addr_name, target->text, sizeof(globals[global_count].addr_name) - 1);
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}

		if (lexer_peek()->kind == TOK_INT &&
		        lexer_peek_next()->kind == TOK_IDENT &&
		        lexer_peek_after_next()->kind != TOK_LPAREN) {
			lexer_next(); /* int */

			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			globals[global_count].name[0] = 0;
			globals[global_count].init_value = 0;
			globals[global_count].array_len = 0;
			globals[global_count].array_len = 1;
			globals[global_count].elem_size = 4;
			globals[global_count].is_string = 0;
			globals[global_count].string_label = 0;
			globals[global_count].string_value[0] = '\0';
			globals[global_count].init_count = 0;
			globals[global_count].is_string_array = 0;
			globals[global_count].is_addr = 0;
			globals[global_count].addr_name[0] = '\0';
			globals[global_count].is_struct = 0;
			globals[global_count].struct_name[0] = '\0';
			globals[global_count].ptr_elem_size = 0;
			STRNCPY(globals[global_count].name, name->text, 63);

			if (lexer_peek()->kind == TOK_LBRACKET) {
				int dims[MAX_ARRAY_DIMS] = {0};
				int dim_count = parse_array_dimensions(dims, 1);
				globals[global_count].is_array = 1;
				globals[global_count].elem_size = 4;

				int known_total = 1;
				for (int d = 0; d < dim_count; d++) {
					if (dims[d] == 0) {
						if (d != 0) {
							fatal_cur("Only the first global array dimension may be omitted\n");
							exit(1);
						}
					} else {
						known_total *= dims[d];
					}
				}

				if (lexer_peek()->kind == TOK_ASSIGN) {
					lexer_next();
					globals[global_count].init_count = parse_global_int_array_initializer(&globals[global_count], dims, dim_count);
				}

				if (dims[0] == 0) {
					if (globals[global_count].init_count <= 0) {
						fatal_cur("Global array length must be known\n");
						exit(1);
					}
					/* The recursive initializer sets an omitted outer dimension from
					 * the number of top-level initializer groups.  For a flat int a[]
					 * initializer this is simply init_count. */
					if (dims[0] == 0)
						dims[0] = globals[global_count].init_count;
				}

				int total_len = 1;
				for (int d = 0; d < dim_count; d++)
					total_len *= dims[d];
				globals[global_count].array_len = total_len;
				globals[global_count].array_dim_count = dim_count;
				for (int d = 0; d < dim_count && d < MAX_ARRAY_DIMS; d++)
					globals[global_count].array_dims[d] = dims[d];

				if (globals[global_count].array_len <= 0) {
					fatal_cur("Global array length must be known\n");
					exit(1);
				}

				commit_global_definition(&globals[global_count]);
				/* Comma: "int A[N], B[N], C[N];" */
				int base_elem_size = 4; /* int */
				while (lexer_peek()->kind == TOK_COMMA) {
					lexer_next();
					if (lexer_peek()->kind == TOK_SEMI) break;
					const Token *en = lexer_peek();
					if (en->kind != TOK_IDENT) break;
					lexer_next();
					if (global_count >= 512) fatal_cur("Too many globals\n");
					Global *eg = &globals[global_count];
					memset(eg, 0, sizeof(*eg));
					STRNCPY(eg->name, en->text, 63);
					if (lexer_peek()->kind == TOK_LBRACKET) {
						lexer_next();
						eg->is_array = 1;
						eg->elem_size = base_elem_size;
						if (lexer_peek()->kind == TOK_NUM) {
							eg->array_len = lexer_peek()->value; lexer_next();
						} else if (lexer_peek()->kind == TOK_IDENT) {
							int ev3 = 0;
							if (find_enum_const(lexer_peek()->text, &ev3)) {
								eg->array_len = ev3; lexer_next();
							}
						}
						expect(TOK_RBRACKET);
					} else {
						eg->elem_size = base_elem_size; eg->array_len = 1;
					}
					commit_global_definition(eg);
				}
				expect(TOK_SEMI);
				continue;
			}

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();

				const Token *value = lexer_peek();
				if (value->kind == TOK_NUM) {
					globals[global_count].init_value = value->value;
					lexer_next();
				} else if (value->kind == TOK_MINUS && lexer_peek_next()->kind == TOK_NUM) {
					lexer_next();
					globals[global_count].init_value = -lexer_peek()->value;
					lexer_next();
				} else if (value->kind == TOK_LPAREN && is_type_start_token(lexer_peek_next()->kind, lexer_peek_next()->text)) {
					/* Cast: "(type)value" */
					lexer_next();
					Type *ct = parse_type_name(); (void)ct;
					expect(TOK_RPAREN);
					int neg = 0;
					if (lexer_peek()->kind == TOK_MINUS) { lexer_next(); neg = 1; }
					const Token *cv = lexer_peek();
					if (cv->kind == TOK_NUM) { globals[global_count].init_value = neg ? -cv->value : cv->value; lexer_next(); }
				} else {
					fatal_cur("Global initializer must be a constant integer for now\n");
					exit(1);
				}
			}

			commit_global_definition(&globals[global_count]);

			/* Comma-separated: "int x, x = 3, x;" or "int A[N], B[N];" */
			while (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				if (lexer_peek()->kind == TOK_SEMI) break;
				/* allow pointer: int *p, q */
				int extra_ptr = 0;
				while (lexer_peek()->kind == TOK_STAR) { lexer_next(); extra_ptr++; }
				if (lexer_peek()->kind != TOK_IDENT) break;
				const Token *en = lexer_peek(); lexer_next();
				if (global_count >= 512) fatal_cur("Too many globals\n");
				Global *eg = &globals[global_count];
				memset(eg, 0, sizeof(*eg));
				STRNCPY(eg->name, en->text, 63);
				if (extra_ptr) {
					eg->elem_size = 8; eg->array_len = 1;
				} else if (lexer_peek()->kind == TOK_LBRACKET) {
					/* array declarator */
					lexer_next();
					eg->is_array = 1;
					eg->elem_size = 4;
					if (lexer_peek()->kind == TOK_NUM) {
						eg->array_len = lexer_peek()->value;
						lexer_next();
					} else if (lexer_peek()->kind == TOK_IDENT) {
						int ev2 = 0;
						if (find_enum_const(lexer_peek()->text, &ev2)) {
							eg->array_len = ev2; lexer_next();
						}
					}
					expect(TOK_RBRACKET);
				} else {
					eg->elem_size = 4; eg->array_len = 1;
				}
				if (lexer_peek()->kind == TOK_ASSIGN) {
					lexer_next();
					const Token *ev = lexer_peek();
					if (ev->kind == TOK_NUM) { eg->init_value = ev->value; lexer_next(); }
				}
				commit_global_definition(eg);
			}
			expect(TOK_SEMI);
			continue;
		}


		if (lexer_peek()->kind == TOK_STRUCT &&
		        lexer_peek_next()->kind == TOK_IDENT &&
		        lexer_peek_after_next()->kind == TOK_IDENT &&
		        lexer_peek_third()->kind != TOK_LPAREN) {
			lexer_next(); /* struct */
			const Token *struct_name = lexer_peek();
			lexer_next();

			StructDef *def = find_struct(struct_name->text);
			const Token *name = lexer_peek();
			lexer_next();

			if (global_count >= 512) {
				fatal_cur("Too many globals\n");
				exit(1);
			}

			Global *g = &globals[global_count];
			memset(g, 0, sizeof(*g));
			STRNCPY(g->name, name->text, sizeof(g->name) - 1);
			g->is_struct = 1;
			g->elem_size = def->size;
			g->array_len = 1;
			STRNCPY(g->struct_name, struct_name->text, sizeof(g->struct_name) - 1);

			if (lexer_peek()->kind == TOK_LBRACKET) {
				lexer_next();
				g->is_array = 1;
				g->array_len = 0;

				if (lexer_peek()->kind == TOK_NUM) {
					const Token *len = lexer_peek();
					if (len->value <= 0) {
						fatal_cur("Global struct array length must be positive\n");
						exit(1);
					}
					g->array_len = len->value;
					lexer_next();
				}
				expect(TOK_RBRACKET);

				if (lexer_peek()->kind == TOK_ASSIGN) {
					lexer_next();
					expect(TOK_LBRACE);

					int elem_index = 0;
					while (lexer_peek()->kind != TOK_RBRACE) {
						/* Designated initializer: "[N] = {elem}" */
						if (lexer_peek()->kind == TOK_LBRACKET) {
							lexer_next(); /* [ */
							if (lexer_peek()->kind == TOK_NUM)
								elem_index = lexer_peek()->value;
							lexer_next(); /* index */
							expect(TOK_RBRACKET);
							expect(TOK_ASSIGN);
							/* expand array if needed */
							if (g->array_len == 0 || elem_index + 1 > g->array_len)
								g->array_len = elem_index + 1;
						}
						if (g->array_len > 0 && elem_index >= g->array_len) {
							fatal_cur("Too many global struct array initializers\n");
							exit(1);
						}

						int base_offset = elem_index * def->size;

						/* C permits brace elision for array-of-struct initializers. */
						if (try_parse_global_struct_compound_initializer(g, def,
						                                               struct_name->text,
						                                               base_offset)) {
							/* Element was written as (struct T){...} or ((struct T){...}). */
						} else if (lexer_peek()->kind == TOK_LBRACE) {
							lexer_next();
							parse_global_struct_initializer_body(g, def, base_offset);
							expect(TOK_RBRACE);
						} else {
							/*
							 * Brace elision for array-of-struct initializers:
							 *
							 *     struct S a[] = { 1, 2, 3, 4, 5, 6 };
							 *
							 * The comma after the final field of one element belongs to
							 * the containing array initializer.  Parse just one struct
							 * element and leave that comma for the outer loop.
							 */
							parse_global_struct_initializer_body_ex(g, def, base_offset, 1);
						}
						elem_index++;

						if (lexer_peek()->kind == TOK_COMMA) {
							lexer_next();
							if (lexer_peek()->kind == TOK_RBRACE)
								break;
						} else if (lexer_peek()->kind == TOK_RBRACE) {
							break;
						} else {
							/*
							 * Brace-elided array-of-struct initializers can contain
							 * nested array fields.  Older nested parsing code may consume
							 * the separator after the last scalar of one struct element.
							 * If the next token still looks like the start of another
							 * initializer, keep parsing the next array element instead
							 * of prematurely expecting the outer closing brace.
							 */
							continue;
						}
					}

					expect(TOK_RBRACE);
					if (g->array_len == 0)
						g->array_len = elem_index;
					g->init_count = g->array_len * def->size;
				}

				if (g->array_len <= 0) {
					fatal_cur("Global struct array length must be known\n");
					exit(1);
				}

				expect(TOK_SEMI);
				commit_global_definition(&globals[global_count]);
				continue;
			}

			if (lexer_peek()->kind == TOK_ASSIGN) {
				lexer_next();
				if (!try_parse_global_struct_compound_initializer(g, def, struct_name->text, 0)) {
					expect(TOK_LBRACE);
					g->init_count = def->size;
					parse_global_struct_initializer_body(g, def, 0);

					expect(TOK_RBRACE);
				}
			}

			expect(TOK_SEMI);
			commit_global_definition(&globals[global_count]);
			continue;
		}

		if (parse_typedef_declaration())
			continue;

		/* Enum definition "enum E { ... };" or bare forward "enum E;" --
		 * but NOT "enum E fn(...)" which is a function with enum return type. */
		if (lexer_peek()->kind == TOK_ENUM &&
		    (lexer_peek_after_next()->kind == TOK_LBRACE ||
		     lexer_peek_after_next()->kind == TOK_SEMI ||
		     lexer_peek_next()->kind == TOK_LBRACE)) {
			parse_enum_specifier();
			expect(TOK_SEMI);
			continue;
		}

		if (lexer_peek()->kind == TOK_STRUCT && lexer_is_struct_definition()) {
			parse_struct_definition();
			continue;
		}

		if (lexer_peek()->kind == TOK_UNION &&
		        lexer_peek_next()->kind == TOK_IDENT &&
		        lexer_peek_after_next()->kind == TOK_LBRACE) {
			parse_union_definition();
			continue;
		}

		/* "int (* f1(params1))(params2) { body }" — function returning function pointer */
		if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text) &&
		    lexer_peek_next()->kind == TOK_LPAREN &&
		    lexer_peek_after_next()->kind == TOK_STAR &&
		    lexer_peek_third()->kind == TOK_IDENT &&
		    lexer_peek_fourth()->kind == TOK_LPAREN) {
			/* consume return type */
			Type *frf_ret = parse_type_name(); (void)frf_ret;
			expect(TOK_LPAREN); /* ( */
			expect(TOK_STAR);   /* * */
			/* function name */
			const Token *frf_name_tok = lexer_peek();
			char frf_name[64] = {0};
			if (frf_name_tok->kind == TOK_IDENT)
				STRNCPY(frf_name, frf_name_tok->text, sizeof(frf_name)-1);
			lexer_next();
			/* Initialize function state before registering params */
			local_count = 0;
			stack_size = 0;
			/* consume function's own parameter list and register params */
			expect(TOK_LPAREN);
			int frf_param_n = 0;
			while (lexer_peek()->kind != TOK_RPAREN && lexer_peek()->kind != TOK_EOF) {
				/* skip type qualifiers and type name */
				if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text)) {
					Type *pt = parse_type_name(); (void)pt;
					while (lexer_peek()->kind == TOK_STAR) lexer_next();
				}
				/* param name */
				if (lexer_peek()->kind == TOK_IDENT) {
					const char *pname = lexer_peek()->text;
					if (frf_param_n < 8) {
						int poff = add_local_sized(pname, 1, 0);
						locals[local_count-1].offset = -(frf_param_n+1)*8;
						(void)poff;
					}
					frf_param_n++;
					lexer_next();
				}
				if (lexer_peek()->kind == TOK_COMMA) lexer_next(); else break;
			}
			expect(TOK_RPAREN);
			/* consume ) of (*f1...) */
			expect(TOK_RPAREN);
			/* consume return type's parameter list */
			expect(TOK_LPAREN);
			int frf_pd2 = 1;
			while (frf_pd2 > 0 && lexer_peek()->kind != TOK_EOF) {
				if (lexer_peek()->kind == TOK_LPAREN) frf_pd2++;
				else if (lexer_peek()->kind == TOK_RPAREN) frf_pd2--;
				lexer_next();
			}
			/* Register as a function returning a pointer */
			add_func_info(frf_name, 0, "", 0, 1, 8);
			/* Parse the function body */
			STRNCPY(current_function_name, frf_name, sizeof(current_function_name)-1);
			param_copy_count = 0;
			pending_struct_param_count = 0;
			expect(TOK_LBRACE);
			Node *frf_body = parse_block_contents();
			expect(TOK_RBRACE);
			cur->next = new_func(frf_name, frf_body, stack_size, 2);
			cur = cur->next;
			continue;
		}

		if (try_parse_prototype()) {
			/* "int f(int a), g(int a), a;" — comma chains more prototypes/vars */
			while (lexer_peek()->kind == TOK_COMMA) {
				lexer_next();
				/* Check for "name(" — another prototype with same implicit return type */
				if (lexer_peek()->kind == TOK_IDENT &&
				    lexer_peek_next()->kind == TOK_LPAREN) {
					/* Prototype without return type — reuse same func registration */
					const Token *pn = lexer_peek(); lexer_next();
					char pname[64] = {0};
					STRNCPY(pname, pn->text, sizeof(pname)-1);
					/* skip parameter list */
					expect(TOK_LPAREN);
					int pd = 1;
					while (pd > 0 && lexer_peek()->kind != TOK_EOF) {
						if (lexer_peek()->kind == TOK_LPAREN) pd++;
						else if (lexer_peek()->kind == TOK_RPAREN) pd--;
						lexer_next();
					}
					add_func_info(pname, 0, "", 0, 0, 0);
				} else if (lexer_peek()->kind == TOK_STAR ||
				           lexer_peek()->kind == TOK_IDENT) {
					/* Plain variable or pointer: "..., a;" or "..., *p;" */
					int extra_ptr = 0;
					while (lexer_peek()->kind == TOK_STAR) { lexer_next(); extra_ptr++; }
					const Token *vn = lexer_peek();
					if (vn->kind == TOK_IDENT && global_count < 512) {
						Global *gv = &globals[global_count];
						memset(gv, 0, sizeof(*gv));
						STRNCPY(gv->name, vn->text, sizeof(gv->name)-1);
						gv->elem_size = extra_ptr ? 8 : 4;
						gv->array_len = 1;
						lexer_next();
						commit_global_definition(gv);
					}
				} else {
					break;
				}
			}
			if (lexer_peek()->kind == TOK_SEMI) lexer_next();
			continue;
		}

		if (is_type_start_token(lexer_peek()->kind, lexer_peek()->text) && !looks_like_function_definition_start()) {
			parse_generic_global_declaration();
			continue;
		}

		cur->next = parse_function();
		cur = cur->next;
	}

	return head.next;
}

/* Returns number of fixed named params for variadic functions, -1 if not variadic */
int 
func_fixed_params(const char *name)
{
	FuncInfo *fi = find_func(name);
	if (fi && fi->is_variadic)
		return fi->fixed_param_count;
	return -1;
}

int 
struct_field_count(const char *struct_name)
{
	StructDef *def = find_struct_or_null(struct_name);
	return def ? def->field_count : 0;
}

int 
struct_field_offset(const char *struct_name, int fi)
{
	StructDef *def = find_struct_or_null(struct_name);
	if (!def || fi < 0 || fi >= def->field_count) return 0;
	return def->fields[fi].offset;
}

int 
struct_field_size(const char *struct_name, int fi)
{
	StructDef *def = find_struct_or_null(struct_name);
	if (!def || fi < 0 || fi >= def->field_count) return 4;
	return def->fields[fi].size ? def->fields[fi].size : 4;
}
