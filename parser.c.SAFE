static int 
find_enum_const(const char *name, int *out_value)
{
	for (int i = enum_const_count - 1; i >= 0; i--) {
		if (STRCMP(enum_consts[i].name, name) == 0) {
			if (out_value)
				*out_value = enum_consts[i].value;
			return 1;
		}
	}

	return 0;
}

static void 
add_enum_const(const char *name, int value)
{
	if (enum_const_count >= 256) {
		fatal_cur("Too many enum constants\n");
		exit(1);
	}

	STRNCPY(enum_consts[enum_const_count].name, name, sizeof(enum_consts[enum_const_count].name) - 1);
	enum_consts[enum_const_count].value = value;
	enum_const_count++;
}

static Type *
clone_type(Type *src)
{
	if (!src)
		return NULL;

	if (src->kind == TY_INT)
		return type_int();
	if (src->kind == TY_CHAR)
		return type_char();
	if (src->kind == TY_PTR)
		return type_ptr(clone_type(src->base));
	if (src->kind == TY_ARRAY)
		return type_array(clone_type(src->base), src->array_len);
	if (src->kind == TY_STRUCT)
		return type_struct(src->struct_name, src->size);

	return src;
}

static Type *
find_typedef(const char *name)
{
	for (int i = 0; i < typedef_count; i++) {
		if (STRCMP(typedefs[i].name, name) == 0)
			return typedefs[i].type;
	}

	return NULL;
}

static int 
is_typedef_name(const char *name)
{
	return find_typedef(name) != NULL;
}

static void 
add_typedef_name(const char *name, Type *type)
{
	if (typedef_count >= 256) {
		fatal_cur("Too many typedefs\n");
		exit(1);
	}

	if (find_typedef(name)) {
		/*
		 * C permits a typedef name to be redeclared in the same scope when the
		 * redeclaration names the same type.  We do not yet have full structural
		 * type-compatibility checking here, but silently accepting the duplicate
		 * is better than rejecting common code such as a test file that does:
		 *
		 *     #include <stdio.h>   // pulls in the stub common size_t typedef
		 *     typedef unsigned long size_t;
		 */
		return;
	}

	STRNCPY(typedefs[typedef_count].name, name, sizeof(typedefs[typedef_count].name) - 1);
	typedefs[typedef_count].type = clone_type(type);
	typedef_count++;
}

static int eval_const_array_size(void);

static int
eval_const_array_size(void)
{
	int val = 0;
	if (lexer_peek()->kind == TOK_NUM) {
		val = lexer_peek()->value; lexer_next();
	} else if (lexer_peek()->kind == TOK_IDENT) {
		int ev = 0;
		if (find_enum_const(lexer_peek()->text, &ev)) val = ev;
		else val = 1;
		lexer_next();
	}
	/* Handle ternary in array sizes: "1 ? A : B" -- evaluate as A */
	if (lexer_peek()->kind == TOK_QUESTION) {
		lexer_next(); /* ? */
		int then_val = eval_const_array_size(); /* evaluate then branch */
		if (lexer_peek()->kind == TOK_COLON) {
			lexer_next(); /* : */
			eval_const_array_size(); /* consume else branch (discard) */
		}
		if (val) val = then_val; /* non-zero condition: use then branch */
	}
	while (lexer_peek()->kind == TOK_STAR || lexer_peek()->kind == TOK_PLUS ||
	       lexer_peek()->kind == TOK_MINUS || lexer_peek()->kind == TOK_SLASH ||
	       lexer_peek()->kind == TOK_AND || lexer_peek()->kind == TOK_OR ||
	       lexer_peek()->kind == TOK_SHL || lexer_peek()->kind == TOK_SHR) {
		TokenKind op = lexer_peek()->kind; lexer_next();
		int rhs = 1;
		if (lexer_peek()->kind == TOK_NUM) { rhs = lexer_peek()->value; lexer_next(); }
		else if (lexer_peek()->kind == TOK_IDENT) {
			int ev2 = 0;
			if (find_enum_const(lexer_peek()->text, &ev2)) rhs = ev2; else rhs = 1;
			lexer_next();
		}
		if (op == TOK_STAR) val *= rhs;
		else if (op == TOK_PLUS) val += rhs;
		else if (op == TOK_MINUS) val -= rhs;
		else if (op == TOK_SLASH && rhs != 0) val /= rhs;
		else if (op == TOK_AND) val &= rhs;
		else if (op == TOK_OR) val |= rhs;
		else if (op == TOK_SHL) val <<= rhs;
		else if (op == TOK_SHR) val >>= rhs;
	}
	return val;
}

static int
parse_array_dimensions(int dims[MAX_ARRAY_DIMS], int allow_unsized_first)
{
	int dim_count = 0;

	while (lexer_peek()->kind == TOK_LBRACKET) {
		lexer_next();

		int len = 0;
			/* Skip qualifiers inside array size: int x[volatile 5] or int x[static N] */
		while (lexer_peek()->kind == TOK_CONST ||
		       lexer_peek()->kind == TOK_STATIC ||
		       (lexer_peek()->kind == TOK_IDENT && lexer_peek()->text &&
		        (STRCMP(lexer_peek()->text, "volatile") == 0 ||
		         STRCMP(lexer_peek()->text, "restrict") == 0))) lexer_next();
		/* Also handle "*" for "int x[*]" (variable-length array marker) */
		if (lexer_peek()->kind == TOK_STAR && lexer_peek_next()->kind == TOK_RBRACKET) {
			lexer_next(); /* consume * */
		}
		/* Evaluate constant expression for array size: N, N*M, N+M, etc. */
		if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT) {
			/* Get first value */
			if (lexer_peek()->kind == TOK_NUM) {
				len = lexer_peek()->value; lexer_next();
			} else {
				int ev = 0;
				if (find_enum_const(lexer_peek()->text, &ev)) { len = ev; lexer_next(); }
				else {
					/* VLA or unknown ident: use size 1 for compilation */
					len = 1; lexer_next();
					/* skip any remaining arithmetic on the VLA expression */
					while (lexer_peek()->kind == TOK_STAR || lexer_peek()->kind == TOK_PLUS ||
					       lexer_peek()->kind == TOK_MINUS || lexer_peek()->kind == TOK_SLASH ||
					       lexer_peek()->kind == TOK_AND || lexer_peek()->kind == TOK_OR ||
					       lexer_peek()->kind == TOK_SHL || lexer_peek()->kind == TOK_SHR) {
						lexer_next();
						if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT)
							lexer_next();
					}
				}
			}
			/* Handle binary operators: *, +, -, /, &, |, <<, >> */
			while (lexer_peek()->kind == TOK_STAR || lexer_peek()->kind == TOK_PLUS ||
			       lexer_peek()->kind == TOK_MINUS || lexer_peek()->kind == TOK_SLASH ||
			       lexer_peek()->kind == TOK_AND || lexer_peek()->kind == TOK_OR ||
			       lexer_peek()->kind == TOK_SHL || lexer_peek()->kind == TOK_SHR) {
				TokenKind op = lexer_peek()->kind; lexer_next();
				int rhs = 1;
				if (lexer_peek()->kind == TOK_NUM) { rhs = lexer_peek()->value; lexer_next(); }
				else if (lexer_peek()->kind == TOK_IDENT) {
					int ev2 = 0;
					if (find_enum_const(lexer_peek()->text, &ev2)) rhs = ev2;
					lexer_next();
				}
				if (op == TOK_STAR) len *= rhs;
				else if (op == TOK_PLUS) len += rhs;
				else if (op == TOK_MINUS) len -= rhs;
				else if (op == TOK_SLASH && rhs != 0) len /= rhs;
				else if (op == TOK_AND) len &= rhs;
				else if (op == TOK_OR) len |= rhs;
				else if (op == TOK_SHL) len <<= rhs;
				else if (op == TOK_SHR) len >>= rhs;
			}
			/* Handle ternary: N ? A : B */
			if (lexer_peek()->kind == TOK_QUESTION) {
				lexer_next(); /* ? */
				int tv = 0;
				if (lexer_peek()->kind == TOK_NUM) { tv=lexer_peek()->value; lexer_next(); }
				else if (lexer_peek()->kind == TOK_IDENT) { lexer_next(); tv=1; }
				if (lexer_peek()->kind == TOK_COLON) {
					lexer_next(); /* : */
					if (lexer_peek()->kind == TOK_NUM || lexer_peek()->kind == TOK_IDENT)
						lexer_next(); /* discard else value */
				}
				if (len) len = tv;
			}
			if (len <= 0 && !(allow_unsized_first && dim_count == 0)) {
				fatal_cur("Array length must be positive\n");
				exit(1);
			}
		} else if (!(allow_unsized_first && dim_count == 0)) {
			fatal_cur("Expected numeric array length\n");
			exit(1);
		}

		expect(TOK_RBRACKET);

		if (dim_count >= MAX_ARRAY_DIMS) {
			fatal_cur("Too many array dimensions\n");
			exit(1);
		}

		dims[dim_count++] = len;
	}

	return dim_count;
}

static Type *
build_array_type_from_dims(Type *base_type, int *dims, int dim_count)
{
	Type *type = clone_type(base_type);

	for (int i = dim_count - 1; i >= 0; i--) {
		if (dims[i] <= 0) {
			fatal_cur("Array length must be known here\n");
			exit(1);
		}
		type = type_array(type, dims[i]);
	}

	return type;
}

static int 
consume_all_zero_initializer(void)
{
	if (lexer_peek()->kind != TOK_LBRACE)
		return 0;

	int depth = 0;
	int saw_value = 0;

	while (lexer_peek()->kind == TOK_LBRACE || depth > 0) {
		const Token *tok = lexer_peek();

		if (tok->kind == TOK_LBRACE) {
			depth++;
			lexer_next();
			continue;
		}

		if (tok->kind == TOK_RBRACE) {
			depth--;
			lexer_next();
			if (depth == 0)
				break;
			continue;
		}

		if (tok->kind == TOK_COMMA) {
			lexer_next();
			continue;
		}

		if (tok->kind == TOK_NUM && tok->value == 0) {
			saw_value = 1;
			lexer_next();
			continue;
		}

		return 0;
	}

	return saw_value;
}

static int 
type_elem_size(Type *type)
{
	if (!type)
		return 4;

	if (type->kind == TY_CHAR)
		return 1;
	if (type->kind == TY_ARRAY)
		return type->base ? type->base->size : type->size;
	if (type->kind == TY_PTR)
		return type->base ? type->base->size : 4;
	if (type->kind == TY_STRUCT)
		return type->size;

	return 4;
}

static Node *
parse_asm_statement(void)
{
	char text[256] = {0};
	int is_volatile = 0;

	lexer_next(); /* asm */

	/* v98: preserve optional volatile qualifier in asm volatile ("..."); */
	const Token *t = lexer_peek();
	if (t->kind == TOK_IDENT && t->text && STRCMP(lexer_peek()->text, "volatile") == 0) {
		is_volatile = 1;
		lexer_next();
	}

	if (lexer_peek()->kind == TOK_LPAREN) {
		lexer_next();

		if (lexer_peek()->kind == TOK_STRING) {
			const Token *value = lexer_peek();
			STRNCPY(text, value->text, sizeof(text) - 1);
			lexer_next();
		}

		/*
		 * Accept and skip the rest of the asm operand/clobber syntax for now:
		 * asm("..." : ... : ... : ...);
		 */
		int depth = 1;
		while (depth > 0 && lexer_peek()->kind != TOK_EOF) {
			const Token *t = lexer_peek();
			if (t->kind == TOK_LPAREN)
				depth++;
			else if (t->kind == TOK_RPAREN)
				depth--;
			lexer_next();
		}
	}

	expect(TOK_SEMI);
	return new_asm(text, is_volatile);
}

static Node *
parse_struct_return_assignment_statement(void)
{
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_ASSIGN ||
	        lexer_peek_after_next()->kind != TOK_IDENT ||
	        lexer_peek_third()->kind != TOK_LPAREN ||
	        lexer_peek_fourth()->kind != TOK_RPAREN)
		return NULL;

	const Token *dst_tok = lexer_peek();
	if (!is_struct_local(dst_tok->text))
		return NULL;

	const Token *func_tok = lexer_peek_after_next();
	FuncInfo *fi = find_func(func_tok->text);
	if (!fi || !fi->returns_struct)
		return NULL;

	const char *dst_struct = struct_name_local(dst_tok->text);
	if (STRCMP(dst_struct, fi->struct_name) != 0) {
		fatal_cur("Struct return assignment type mismatch\n");
		exit(1);
	}

	lexer_next(); /* dst */
	expect(TOK_ASSIGN);
	lexer_next(); /* func */
	expect(TOK_LPAREN);
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	StructDef *def = find_struct(dst_struct);

	Node *lhs = new_var(dst_tok->text, find_local(dst_tok->text));
	lhs->type = type_struct(dst_struct, def->size);
	lhs->elem_size = def->size;
	STRNCPY(lhs->struct_name, dst_struct, sizeof(lhs->struct_name) - 1);

	Node *call = new_call(func_tok->text, NULL);
	call->returns_struct = 1;
	call->struct_return_size = fi->struct_size;
	call->type = type_struct(fi->struct_name, fi->struct_size);
	STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);

	return new_assign(lhs, call);
}

static Node *
parse_struct_return_discard_statement(void)
{
	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN ||
	        lexer_peek_after_next()->kind != TOK_RPAREN)
		return NULL;

	const Token *func_tok = lexer_peek();
	FuncInfo *fi = find_func(func_tok->text);
	if (!fi || !fi->returns_struct)
		return NULL;

	lexer_next();
	expect(TOK_LPAREN);
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__struct_discard_%d", struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, fi->struct_name);
	StructDef *def = find_struct(fi->struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(fi->struct_name, def->size);

	Node *lhs = new_var(temp_name, offset);
	lhs->type = type_struct(fi->struct_name, def->size);
	lhs->elem_size = def->size;
	STRNCPY(lhs->struct_name, fi->struct_name, sizeof(lhs->struct_name) - 1);

	Node *call = new_call(func_tok->text, NULL);
	call->returns_struct = 1;
	call->struct_return_size = fi->struct_size;
	call->type = type_struct(fi->struct_name, fi->struct_size);
	STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);

	return new_block(append_node(decl, new_assign(lhs, call)));
}

static Node *
parse_return_struct_call_value(void)
{
	if (!current_returns_struct)
		return NULL;

	if (lexer_peek()->kind != TOK_IDENT ||
	        lexer_peek_next()->kind != TOK_LPAREN)
		return NULL;

	const Token *func = lexer_peek();
	FuncInfo *fi = find_func(func->text);
	if (!fi || !fi->returns_struct)
		return NULL;

	if (STRCMP(fi->struct_name, current_return_struct_name) != 0)
		return NULL;  /* type mismatch - don't handle here, let generic path deal with it */

	lexer_next(); /* func name */
	expect(TOK_LPAREN);
	Node *args = parse_arg_list();
	expect(TOK_RPAREN);
	expect(TOK_SEMI);

	char temp_name[64];
	snprintf(temp_name, sizeof(temp_name), "__struct_return_value_%d", struct_arg_temp_id++);

	int offset = add_struct_local(temp_name, fi->struct_name);
	StructDef *def = find_struct(fi->struct_name);

	Node *decl = new_struct_decl(temp_name, offset);
	decl->type = type_struct(fi->struct_name, def->size);

	Node *lhs = new_var(temp_name, offset);
	lhs->type = type_struct(fi->struct_name, def->size);
	lhs->elem_size = def->size;
	STRNCPY(lhs->struct_name, fi->struct_name, sizeof(lhs->struct_name) - 1);

	Node *call = new_call(func->text, args);
	call->returns_struct = 1;
	call->struct_return_size = fi->struct_size;
	call->type = type_struct(fi->struct_name, fi->struct_size);
	STRNCPY(call->return_struct_name, fi->struct_name, sizeof(call->return_struct_name) - 1);

	Node *assign = new_assign(lhs, call);

	Node *ret_var = new_var(temp_name, offset);
	ret_var->type = type_struct(fi->struct_name, def->size);
	ret_var->elem_size = def->size;
	STRNCPY(ret_var->struct_name, fi->struct_name, sizeof(ret_var->struct_name) - 1);

	Node *head = decl;
	head = append_node(head, assign);
	head = append_node(head, new_return(ret_var));

	return new_block(head);
}

static int v124_call_starts_with_struct_temp_arg(void)
{
	if (lexer_peek()->kind != TOK_IDENT || lexer_peek_next()->kind != TOK_LPAREN)
		return 0;

	const Token *a0 = lexer_peek_after_next();

	if (a0->kind == TOK_LPAREN && lexer_peek_third()->kind == TOK_STRUCT)
		return 1;

	if (a0->kind == TOK_IDENT && lexer_peek_third()->kind == TOK_LPAREN &&
	        lexer_peek_fourth()->kind == TOK_RPAREN) {
		FuncInfo *fi = find_func(a0->text);
		return fi && fi->returns_struct;
	}

	/*
	 * Limited but useful two-argument lookahead:
	 *   fn(scalar, (struct T){...})
	 *   fn(scalar, make_struct())
	 */
	if (a0->kind == TOK_IDENT || a0->kind == TOK_NUM) {
		if (lexer_peek_third()->kind == TOK_COMMA) {
			const Token *a1 = lexer_peek_fourth();
			if (a1->kind == TOK_LPAREN || a1->kind == TOK_IDENT)
				return 1;
		}
	}

	return 0;
}

