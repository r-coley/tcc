#define MAX_STRUCT_FIELDS 256
#define MAX_ARRAY_DIMS 8

typedef struct {
	char name[64];
	int offset;
	int size;
	int is_struct;
	int is_array;    /* field is an array (char[], int[], etc.) — decays to pointer */
	int elem_size;   /* element size for array fields */
	char struct_name[64];
	Type *type;
} Field;

typedef struct {
	char name[64];
	Field fields[MAX_STRUCT_FIELDS];
	int field_count;
	int size;
	int align;
	int is_union;
} StructDef;

typedef struct {
	char name[64];
	int offset;
	int is_array;
	int array_len;
	int is_pointer;
	int elem_size;
	int is_struct;
	char struct_name[64];
	Type *type;
	int struct_by_ref;
	int is_static;
	char static_global_name[64];
} Local;

typedef struct ParamCopy {
	char dst_name[64];
	char hidden_name[64];
	char struct_name[64];
} ParamCopy;

typedef struct PendingStructParam {
	char param_name[64];
	char hidden_name[64];
	char struct_name[64];
} PendingStructParam;

typedef struct {
	char name[64];
	int returns_struct;
	int struct_size;
	char struct_name[64];
	int returns_pointer;
	int return_elem_size;
	int is_variadic;       /* function has ... parameter */
	int fixed_param_count; /* number of named params before ... */
} FuncInfo;

typedef struct {
	char name[64];
	Type *type;
} TypedefName;

typedef struct {
	char name[64];
	int value;
} EnumConst;

